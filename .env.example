# Access Code for API authentication
# Users must provide this code to access the questions
ACCESS_CODE=JAMB2027

# Port for local development (ignored in production)
PORT=3000

# GitHub Configuration (optional)
# Set to 'true' to fetch questions from GitHub instead of local directory
USE_GITHUB=true

# GitHub repository containing questions (format: username/repo)
GITHUB_REPO=anointedthedeveloper/Q2

# GitHub branch to fetch from
GITHUB_BRANCH=main

# GitHub Personal Access Token (optional for public repos, required for private repos)
# Only needed if you want to avoid GitHub API rate limits (60 requests/hour for unauthenticated)
# Create one at: https://github.com/settings/tokens
# Select 'public_repo' scope for public repositories, 'repo' for private
# GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
