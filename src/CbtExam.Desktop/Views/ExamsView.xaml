<UserControl x:Class="CbtExam.Desktop.Views.ExamsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:CbtExam.Desktop.ViewModels">
    <Grid Background="{DynamicResource BgBrush}">
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="26">

                <!-- Header -->
                <Grid Margin="0,0,0,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="Exam Templates" FontSize="28" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                        <TextBlock Text="Create exam templates from your question bank. Select subjects, years, and question counts." FontSize="13" Foreground="#64748B" Margin="0,6,0,0"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                        <Button Command="{Binding RefreshCommand}" Style="{StaticResource PrimaryBtn}"
                                Background="#F1F5F9" Foreground="#111827" Padding="13,9" Margin="0,0,8,0">
                            <TextBlock Text="&#xE72C;" FontFamily="Segoe MDL2 Assets"/>
                        </Button>
                        <Button Command="{Binding ToggleCreateCommand}" Style="{StaticResource PrimaryBtn}"
                                Background="#047857" Padding="16,9">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="+" FontSize="16" Margin="0,0,7,0"/>
                                <TextBlock Text="New Template"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Grid>

                <!-- Search -->
                <Grid Height="44" Margin="0,0,0,16">
                    <TextBox Text="{Binding Search, UpdateSourceTrigger=PropertyChanged}" Padding="40,8,12,8"/>
                    <TextBlock Text="&#xE721;" FontFamily="Segoe MDL2 Assets" FontSize="14" Foreground="#94A3B8"
                               VerticalAlignment="Center" HorizontalAlignment="Left" Margin="14,0,0,0" IsHitTestVisible="False"/>
                    <TextBlock Text="Search templates..." FontSize="13" Foreground="#94A3B8"
                               VerticalAlignment="Center" HorizontalAlignment="Left" Margin="40,0,0,0"
                               IsHitTestVisible="False"
                               Visibility="{Binding Search, Converter={StaticResource EmptyStringToVis}}"/>
                </Grid>

                <!-- Create/Edit Form -->
                <Border Visibility="{Binding ShowCreateForm, Converter={StaticResource BoolToVis}}"
                        Background="{DynamicResource CardBrush}" CornerRadius="14" BorderBrush="#E5E7EB"
                        BorderThickness="1" Padding="24" Margin="0,0,0,20">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="20" ShadowDepth="3" Opacity="0.08" Color="#111827"/>
                    </Border.Effect>
                    <StackPanel>
                        <!-- Form header -->
                        <Grid Margin="0,0,0,18">
                            <TextBlock Text="{Binding FormTitle}" FontSize="18" FontWeight="Bold"
                                       Foreground="{DynamicResource TextPrimaryBrush}"/>
                            <Button HorizontalAlignment="Right" Command="{Binding ToggleCreateCommand}"
                                    Style="{StaticResource PrimaryBtn}" Background="Transparent"
                                    Foreground="{DynamicResource TextSecondaryBrush}" Padding="8">
                                <TextBlock Text="&#xE8BB;" FontFamily="Segoe MDL2 Assets" FontSize="14"/>
                            </Button>
                        </Grid>

                        <!-- Row 1: Name + Duration -->
                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="3*"/>
                                <ColumnDefinition Width="1*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Margin="0,0,12,0">
                                <TextBlock Text="Exam Name *" FontSize="12" FontWeight="SemiBold" Foreground="#64748B" Margin="0,0,0,6"/>
                                <TextBox Text="{Binding Title, UpdateSourceTrigger=PropertyChanged}" FontSize="14" Padding="12,10"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="Duration (minutes)" FontSize="12" FontWeight="SemiBold" Foreground="#64748B" Margin="0,0,0,6"/>
                                <TextBox Text="{Binding Duration, UpdateSourceTrigger=PropertyChanged}" FontSize="14" Padding="12,10"/>
                            </StackPanel>
                        </Grid>

                        <!-- Shuffle options -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,18">
                            <CheckBox Content="Shuffle Questions" IsChecked="{Binding ShuffleQuestions}" Margin="0,0,24,0" FontSize="13"/>
                            <CheckBox Content="Shuffle Options" IsChecked="{Binding ShuffleOptions}" FontSize="13"/>
                        </StackPanel>

                        <!-- Subject Configuration Section -->
                        <Border Background="{DynamicResource BgBrush}" CornerRadius="10" Padding="18" Margin="0,0,0,16">
                            <StackPanel>
                                <Grid Margin="0,0,0,14">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="&#xE8F1;" FontFamily="Segoe MDL2 Assets" FontSize="16" Foreground="{DynamicResource AccentBrush}" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                        <TextBlock Text="Subject Configuration" FontSize="15" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                                        <Border Background="#ECFDF5" CornerRadius="10" Padding="8,3" Margin="12,0,0,0" VerticalAlignment="Center">
                                            <TextBlock FontSize="11" FontWeight="Bold" Foreground="#047857">
                                                <Run Text="{Binding TotalSubjects, Mode=OneWay}"/>
                                                <Run Text=" / 4 subjects"/>
                                            </TextBlock>
                                        </Border>
                                    </StackPanel>
                                    <Button HorizontalAlignment="Right" Command="{Binding AddSubjectCommand}"
                                            Style="{StaticResource PrimaryBtn}" Background="#047857" Padding="12,7"
                                            IsEnabled="{Binding CanAddSubject}">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="+" FontSize="14" Margin="0,0,6,0"/>
                                            <TextBlock Text="Add Subject" FontSize="12"/>
                                        </StackPanel>
                                    </Button>
                                </Grid>

                                <!-- Empty state -->
                                <Border Visibility="{Binding SubjectConfigs.Count, Converter={StaticResource ZeroToVis}}"
                                        Background="{DynamicResource CardBrush}" CornerRadius="10" Padding="30">
                                    <StackPanel HorizontalAlignment="Center">
                                        <TextBlock Text="&#xE82D;" FontFamily="Segoe MDL2 Assets" FontSize="32"
                                                   Foreground="#CBD5E1" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                                        <TextBlock Text="No subjects added yet" FontSize="14" FontWeight="SemiBold"
                                                   Foreground="#94A3B8" HorizontalAlignment="Center"/>
                                        <TextBlock Text="Click 'Add Subject' to configure subjects and years for this exam."
                                                   FontSize="12" Foreground="#94A3B8" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                                    </StackPanel>
                                </Border>

                                <!-- Subject rows -->
                                <ItemsControl ItemsSource="{Binding SubjectConfigs}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate DataType="{x:Type vm:ExamSubjectConfigVM}">
                                            <Border Background="{DynamicResource CardBrush}" CornerRadius="10"
                                                    Padding="16" Margin="0,0,0,10" BorderBrush="#E5E7EB" BorderThickness="1">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>

                                                    <StackPanel>
                                                        <!-- Subject + Question Count row -->
                                                        <Grid Margin="0,0,0,12">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="2*"/>
                                                                <ColumnDefinition Width="1*"/>
                                                            </Grid.ColumnDefinitions>
                                                            <StackPanel Margin="0,0,12,0">
                                                                <TextBlock Text="Subject" FontSize="11" FontWeight="SemiBold" Foreground="#64748B" Margin="0,0,0,4"/>
                                                                <ComboBox ItemsSource="{Binding AvailableSubjects}"
                                                                          SelectedItem="{Binding SelectedSubject}"
                                                                          FontSize="13"/>
                                                            </StackPanel>
                                                            <StackPanel Grid.Column="1">
                                                                <TextBlock FontSize="11" FontWeight="SemiBold" Foreground="#64748B" Margin="0,0,0,4">
                                                                    <Run Text="Questions to pick"/>
                                                                </TextBlock>
                                                                <TextBox Text="{Binding QuestionCount, UpdateSourceTrigger=PropertyChanged}" FontSize="13" Padding="8,6"/>
                                                            </StackPanel>
                                                        </Grid>

                                                        <!-- Years section -->
                                                        <StackPanel Visibility="{Binding AvailableYears.Count, Converter={StaticResource IntToVis}}">
                                                            <Grid Margin="0,0,0,6">
                                                                <StackPanel Orientation="Horizontal">
                                                                    <TextBlock Text="Select Years" FontSize="11" FontWeight="SemiBold" Foreground="#64748B" VerticalAlignment="Center"/>
                                                                    <Border Background="#EFF6FF" CornerRadius="8" Padding="6,2" Margin="8,0,0,0">
                                                                        <TextBlock FontSize="10" FontWeight="Bold" Foreground="#2563EB">
                                                                            <Run Text="{Binding PoolSize, Mode=OneWay}"/>
                                                                            <Run Text=" years selected"/>
                                                                        </TextBlock>
                                                                    </Border>
                                                                </StackPanel>
                                                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                                                    <Button Content="All" Command="{Binding SelectAllYearsCommand}"
                                                                            Style="{StaticResource PrimaryBtn}"
                                                                            Background="#EFF6FF" Foreground="#2563EB"
                                                                            Padding="8,3" Margin="0,0,4,0" FontSize="10"/>
                                                                    <Button Content="None" Command="{Binding DeselectAllYearsCommand}"
                                                                            Style="{StaticResource PrimaryBtn}"
                                                                            Background="#F1F5F9" Foreground="#64748B"
                                                                            Padding="8,3" FontSize="10"/>
                                                                </StackPanel>
                                                            </Grid>
                                                            <!-- Year chips -->
                                                            <ItemsControl ItemsSource="{Binding AvailableYears}">
                                                                <ItemsControl.ItemsPanel>
                                                                    <ItemsPanelTemplate>
                                                                        <WrapPanel/>
                                                                    </ItemsPanelTemplate>
                                                                </ItemsControl.ItemsPanel>
                                                                <ItemsControl.ItemTemplate>
                                                                    <DataTemplate DataType="{x:Type vm:YearToggle}">
                                                                        <Border Margin="0,0,6,6" CornerRadius="6" Padding="10,5" Cursor="Hand"
                                                                                MouseLeftButtonDown="YearChip_Click">
                                                                            <Border.Style>
                                                                                <Style TargetType="Border">
                                                                                    <Setter Property="Background" Value="#F1F5F9"/>
                                                                                    <Setter Property="BorderBrush" Value="#E5E7EB"/>
                                                                                    <Setter Property="BorderThickness" Value="1"/>
                                                                                    <Style.Triggers>
                                                                                        <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                                                            <Setter Property="Background" Value="#ECFDF5"/>
                                                                                            <Setter Property="BorderBrush" Value="#10B981"/>
                                                                                        </DataTrigger>
                                                                                    </Style.Triggers>
                                                                                </Style>
                                                                            </Border.Style>
                                                                            <TextBlock Text="{Binding Year}" FontSize="12" FontWeight="SemiBold">
                                                                                <TextBlock.Style>
                                                                                    <Style TargetType="TextBlock">
                                                                                        <Setter Property="Foreground" Value="#64748B"/>
                                                                                        <Style.Triggers>
                                                                                            <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                                                                <Setter Property="Foreground" Value="#047857"/>
                                                                                            </DataTrigger>
                                                                                        </Style.Triggers>
                                                                                    </Style>
                                                                                </TextBlock.Style>
                                                                            </TextBlock>
                                                                        </Border>
                                                                    </DataTemplate>
                                                                </ItemsControl.ItemTemplate>
                                                            </ItemsControl>
                                                        </StackPanel>
                                                    </StackPanel>

                                                    <!-- Remove button -->
                                                    <Button Grid.Column="1" Command="{Binding RemoveCommand}"
                                                            Style="{StaticResource PrimaryBtn}" Background="#FEF2F2"
                                                            Foreground="#DC2626" Padding="8" VerticalAlignment="Top" Margin="10,0,0,0"
                                                            ToolTip="Remove subject">
                                                        <TextBlock Text="&#xE74D;" FontFamily="Segoe MDL2 Assets" FontSize="12"/>
                                                    </Button>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>

                        <!-- Summary bar -->
                        <Border Background="#F0FDF4" CornerRadius="8" Padding="16,10" Margin="0,0,0,16"
                                Visibility="{Binding SubjectConfigs.Count, Converter={StaticResource IntToVis}}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE946;" FontFamily="Segoe MDL2 Assets" FontSize="14" Foreground="#059669" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                <TextBlock VerticalAlignment="Center" FontSize="13" Foreground="#047857">
                                    <Run Text="{Binding TotalSubjects, Mode=OneWay}" FontWeight="Bold"/>
                                    <Run Text=" subject(s)  ·  "/>
                                    <Run Text="{Binding TotalQuestions, Mode=OneWay}" FontWeight="Bold"/>
                                    <Run Text=" total questions  ·  "/>
                                    <Run Text="{Binding Duration, Mode=OneWay}" FontWeight="Bold"/>
                                    <Run Text=" min duration"/>
                                </TextBlock>
                            </StackPanel>
                        </Border>

                        <!-- Actions -->
                        <StackPanel Orientation="Horizontal">
                            <Button Content="{Binding SubmitButtonText}" Command="{Binding CreateTemplateCommand}"
                                    Style="{StaticResource PrimaryBtn}" Background="#047857" Padding="20,10" Margin="0,0,10,0"
                                    FontSize="13" FontWeight="SemiBold"/>
                            <Button Content="Cancel" Command="{Binding ToggleCreateCommand}"
                                    Style="{StaticResource PrimaryBtn}" Background="#F1F5F9" Foreground="#111827" Padding="20,10"
                                    FontSize="13"/>
                            <TextBlock Text="{Binding CreateStatus}" VerticalAlignment="Center" Margin="14,0,0,0" FontSize="12" FontWeight="SemiBold">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="{StaticResource DangerBrush}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding StatusOk}" Value="True">
                                                <Setter Property="Foreground" Value="#059669"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Table header -->
                <Border Background="#F8FAFC" CornerRadius="8,8,0,0" Padding="16,0" Height="40">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2.5*"/>
                            <ColumnDefinition Width="2*"/>
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="90"/>
                            <ColumnDefinition Width="130"/>
                            <ColumnDefinition Width="100"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Template Name" VerticalAlignment="Center" FontSize="11" FontWeight="Bold" Foreground="#64748B"/>
                        <TextBlock Grid.Column="1" Text="Subjects" VerticalAlignment="Center" FontSize="11" FontWeight="Bold" Foreground="#64748B"/>
                        <TextBlock Grid.Column="2" Text="Duration" VerticalAlignment="Center" FontSize="11" FontWeight="Bold" Foreground="#64748B"/>
                        <TextBlock Grid.Column="3" Text="Questions" VerticalAlignment="Center" FontSize="11" FontWeight="Bold" Foreground="#64748B"/>
                        <TextBlock Grid.Column="4" Text="Created" VerticalAlignment="Center" FontSize="11" FontWeight="Bold" Foreground="#64748B"/>
                        <TextBlock Grid.Column="5" Text="Actions" VerticalAlignment="Center" FontSize="11" FontWeight="Bold" Foreground="#64748B"/>
                    </Grid>
                </Border>

                <!-- Empty state -->
                <Border BorderBrush="#E5E7EB" BorderThickness="1,0,1,1" CornerRadius="0,0,8,8"
                        Visibility="{Binding Filtered.Count, Converter={StaticResource ZeroToVis}}">
                    <StackPanel HorizontalAlignment="Center" Margin="0,40">
                        <Border Width="56" Height="56" CornerRadius="28" Background="#ECFDF5" HorizontalAlignment="Center" Margin="0,0,0,12">
                            <TextBlock Text="&#xE82D;" FontFamily="Segoe MDL2 Assets" FontSize="22"
                                       Foreground="#059669" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="No exam templates yet" FontSize="15" FontWeight="Bold"
                                   Foreground="{DynamicResource TextPrimaryBrush}" HorizontalAlignment="Center"/>
                        <TextBlock Text="Click 'New Template' to create your first exam from the question bank."
                                   FontSize="12" Foreground="#64748B" HorizontalAlignment="Center" Margin="0,6,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Exam rows -->
                <Border BorderBrush="#E5E7EB" BorderThickness="1,0,1,1" CornerRadius="0,0,8,8"
                        Visibility="{Binding Filtered.Count, Converter={StaticResource IntToVis}}">
                    <ItemsControl ItemsSource="{Binding Filtered}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Height="54">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="2.5*"/>
                                        <ColumnDefinition Width="2*"/>
                                        <ColumnDefinition Width="80"/>
                                        <ColumnDefinition Width="90"/>
                                        <ColumnDefinition Width="130"/>
                                        <ColumnDefinition Width="100"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.ColumnSpan="6" BorderBrush="#F1F5F9" BorderThickness="0,0,0,1"/>
                                    <TextBlock Text="{Binding Title}" Margin="16,0,0,0" VerticalAlignment="Center"
                                               FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                    <TextBlock Grid.Column="1" Text="{Binding Subject}" VerticalAlignment="Center"
                                               FontSize="12" Foreground="#64748B" TextTrimming="CharacterEllipsis"/>
                                    <TextBlock Grid.Column="2" Text="{Binding DurationMinutes, StringFormat='{}{0}m'}"
                                               VerticalAlignment="Center" FontSize="13" Foreground="#64748B"/>
                                    <Border Grid.Column="3" VerticalAlignment="Center" HorizontalAlignment="Left"
                                            Background="#EFF6FF" CornerRadius="6" Padding="8,3">
                                        <TextBlock Text="{Binding QuestionCount}" FontSize="12" FontWeight="Bold" Foreground="#2563EB"/>
                                    </Border>
                                    <TextBlock Grid.Column="4" Text="{Binding CreatedAt, StringFormat='dd/MM/yyyy'}"
                                               VerticalAlignment="Center" FontSize="12" Foreground="#94A3B8"/>
                                    <StackPanel Grid.Column="5" Orientation="Horizontal" VerticalAlignment="Center">
                                        <Button Style="{StaticResource PrimaryBtn}" Background="#F0F9FF" Foreground="#0284C7"
                                                Padding="8,5" Margin="0,0,5,0" ToolTip="Edit Template"
                                                Command="{Binding DataContext.EditCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                CommandParameter="{Binding}">
                                            <TextBlock Text="&#xE70F;" FontFamily="Segoe MDL2 Assets"/>
                                        </Button>
                                        <Button Style="{StaticResource PrimaryBtn}" Background="#FEF2F2" Foreground="#DC2626"
                                                Padding="8,5" ToolTip="Delete"
                                                Command="{Binding DataContext.DeleteCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                CommandParameter="{Binding}">
                                            <TextBlock Text="&#xE74D;" FontFamily="Segoe MDL2 Assets"/>
                                        </Button>
                                    </StackPanel>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <!-- Loading Overlay -->
        <Border Background="#40FFFFFF" Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <ProgressBar IsIndeterminate="True" Width="120" Height="3" Background="Transparent" BorderThickness="0" Foreground="{DynamicResource AccentBrush}"/>
                <TextBlock Text="{Binding BusyMessage}" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12" Margin="0,10,0,0" HorizontalAlignment="Center"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
