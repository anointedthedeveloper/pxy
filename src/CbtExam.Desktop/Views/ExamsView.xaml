<UserControl x:Class="CbtExam.Desktop.Views.ExamsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer Background="{StaticResource BgBrush}">
        <StackPanel Margin="26">
            <Grid Margin="0,0,0,22">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="Exams" FontSize="28" FontWeight="Bold" Foreground="#111827"/>
                    <TextBlock Text="Create, search, and manage all exam records."
                               FontSize="14" Foreground="#64748B" Margin="0,8,0,0"/>
                </StackPanel>
                <Button Grid.Column="1" Command="{Binding RefreshCommand}" Style="{StaticResource PrimaryBtn}"
                        Background="#059669" Padding="18,11" VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE72C;" FontFamily="Segoe MDL2 Assets" Margin="0,0,8,0"/>
                        <TextBlock Text="Refresh"/>
                    </StackPanel>
                </Button>
            </Grid>

            <Border Background="White" CornerRadius="14" BorderBrush="#E5E7EB" BorderThickness="1" Padding="18">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="18" ShadowDepth="2" Opacity="0.06" Color="#111827"/>
                </Border.Effect>
                <StackPanel>
                    <Grid Margin="0,0,0,18">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="190"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Grid Height="44" Margin="0,0,12,0">
                            <TextBox Text="{Binding Search, UpdateSourceTrigger=PropertyChanged}" Padding="40,8,12,8"/>
                            <TextBlock Text="&#xE721;" FontFamily="Segoe MDL2 Assets" FontSize="15" Foreground="#64748B"
                                       VerticalAlignment="Center" HorizontalAlignment="Left" Margin="14,0,0,0"/>
                            <TextBlock Text="Search exams..." FontSize="13" Foreground="#64748B"
                                       VerticalAlignment="Center" HorizontalAlignment="Left" Margin="40,0,0,0"
                                       IsHitTestVisible="False"
                                       Visibility="{Binding Search, Mode=OneWay, Converter={StaticResource EmptyStringToVis}}"/>
                        </Grid>
                        <ComboBox Grid.Column="1" Margin="0,0,12,0">
                            <ComboBoxItem Content="All subjects" IsSelected="True"/>
                        </ComboBox>
                        <Button Grid.Column="2" Command="{Binding RefreshCommand}" Style="{StaticResource PrimaryBtn}"
                                Background="#F8FAFC" Foreground="#111827" Padding="15,10">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE71C;" FontFamily="Segoe MDL2 Assets" Margin="0,0,8,0"/>
                                <TextBlock Text="Filters"/>
                            </StackPanel>
                        </Button>
                    </Grid>

                    <Border Background="#F8FAFC" CornerRadius="10,10,0,0" Height="42">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="2*"/>
                                <ColumnDefinition Width="1.2*"/>
                                <ColumnDefinition Width=".8*"/>
                                <ColumnDefinition Width=".8*"/>
                                <ColumnDefinition Width="1*"/>
                                <ColumnDefinition Width=".8*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Exam Title" Margin="16,0,0,0" VerticalAlignment="Center" FontSize="12" FontWeight="Bold"/>
                            <TextBlock Grid.Column="1" Text="Subject" VerticalAlignment="Center" FontSize="12" FontWeight="Bold"/>
                            <TextBlock Grid.Column="2" Text="Duration" VerticalAlignment="Center" FontSize="12" FontWeight="Bold"/>
                            <TextBlock Grid.Column="3" Text="Questions" VerticalAlignment="Center" FontSize="12" FontWeight="Bold"/>
                            <TextBlock Grid.Column="4" Text="Status" VerticalAlignment="Center" FontSize="12" FontWeight="Bold"/>
                            <TextBlock Grid.Column="5" Text="Actions" VerticalAlignment="Center" FontSize="12" FontWeight="Bold"/>
                        </Grid>
                    </Border>

                    <Border BorderBrush="#E5E7EB" BorderThickness="0,1,0,0"
                            Visibility="{Binding Filtered.Count, Mode=OneWay, Converter={StaticResource ZeroToVis}}">
                        <StackPanel HorizontalAlignment="Center" Margin="0,44">
                            <Border Width="58" Height="58" CornerRadius="29" Background="#ECFDF5" Margin="0,0,0,12">
                                <TextBlock Text="&#xE8A5;" FontFamily="Segoe MDL2 Assets" FontSize="24"
                                           Foreground="#059669" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="No exams found" FontSize="15" FontWeight="Bold" Foreground="#111827" HorizontalAlignment="Center"/>
                            <TextBlock Text="Create an exam from Dashboard or adjust your search."
                                       FontSize="13" Foreground="#64748B" Margin="0,6,0,0"/>
                        </StackPanel>
                    </Border>

                    <ItemsControl ItemsSource="{Binding Filtered, Mode=OneWay}"
                                  Visibility="{Binding Filtered.Count, Mode=OneWay, Converter={StaticResource IntToVis}}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Height="48">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="2*"/>
                                        <ColumnDefinition Width="1.2*"/>
                                        <ColumnDefinition Width=".8*"/>
                                        <ColumnDefinition Width=".8*"/>
                                        <ColumnDefinition Width="1*"/>
                                        <ColumnDefinition Width=".8*"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.ColumnSpan="6" BorderBrush="#E5E7EB" BorderThickness="0,0,0,1"/>
                                    <TextBlock Text="{Binding Title, Mode=OneWay}" Margin="16,0,0,0" VerticalAlignment="Center"
                                               FontSize="13" FontWeight="SemiBold" Foreground="#111827"/>
                                    <TextBlock Grid.Column="1" Text="{Binding Subject, Mode=OneWay}" VerticalAlignment="Center" Foreground="#334155"/>
                                    <TextBlock Grid.Column="2" Text="{Binding DurationMinutes, Mode=OneWay, StringFormat='{}{0} min'}" VerticalAlignment="Center" Foreground="#334155"/>
                                    <TextBlock Grid.Column="3" Text="{Binding QuestionCount, Mode=OneWay}" VerticalAlignment="Center" Foreground="#334155"/>
                                    <Border Grid.Column="4" CornerRadius="6" Background="#ECFDF5" BorderBrush="#BBF7D0" BorderThickness="1"
                                            Padding="9,4" HorizontalAlignment="Left" VerticalAlignment="Center">
                                        <TextBlock Text="Ready" FontSize="12" FontWeight="Bold" Foreground="#047857"/>
                                    </Border>
                                    <StackPanel Grid.Column="5" Orientation="Horizontal" VerticalAlignment="Center">
                                        <Button Style="{StaticResource PrimaryBtn}" Background="#EFF6FF" Foreground="#2563EB"
                                                Padding="8,5" Margin="0,0,5,0" ToolTip="Edit">
                                            <TextBlock Text="&#xE70F;" FontFamily="Segoe MDL2 Assets"/>
                                        </Button>
                                        <Button Style="{StaticResource PrimaryBtn}" Background="#FEF2F2" Foreground="#DC2626"
                                                Padding="8,5" ToolTip="Delete"
                                                Command="{Binding DataContext.DeleteCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                CommandParameter="{Binding}">
                                            <TextBlock Text="&#xE74D;" FontFamily="Segoe MDL2 Assets"/>
                                        </Button>
                                    </StackPanel>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
