<UserControl x:Class="CbtExam.Desktop.Views.ExamsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Background="{DynamicResource BgBrush}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="380" x:Name="DetailCol"/>
        </Grid.ColumnDefinitions>

        <!-- Left: exam list -->
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="26">
                <Grid Margin="0,0,0,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="Exams" FontSize="28" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                        <TextBlock Text="Create and manage exam papers with questions." FontSize="13" Foreground="#64748B" Margin="0,6,0,0"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                        <Button Command="{Binding RefreshCommand}" Style="{StaticResource PrimaryBtn}"
                                Background="#F1F5F9" Foreground="#111827" Padding="13,9" Margin="0,0,8,0">
                            <TextBlock Text="&#xE72C;" FontFamily="Segoe MDL2 Assets"/>
                        </Button>
                        <Button Command="{Binding ToggleCreateCommand}" Style="{StaticResource PrimaryBtn}"
                                Background="#047857" Padding="16,9">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="+" FontSize="16" Margin="0,0,7,0"/>
                                <TextBlock Text="New Exam"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Grid>

                <!-- Search -->
                <Grid Height="44" Margin="0,0,0,16">
                    <TextBox Text="{Binding Search, UpdateSourceTrigger=PropertyChanged}" Padding="40,8,12,8"/>
                    <TextBlock Text="&#xE721;" FontFamily="Segoe MDL2 Assets" FontSize="14" Foreground="#94A3B8"
                               VerticalAlignment="Center" HorizontalAlignment="Left" Margin="14,0,0,0" IsHitTestVisible="False"/>
                    <TextBlock Text="Search exams..." FontSize="13" Foreground="#94A3B8"
                               VerticalAlignment="Center" HorizontalAlignment="Left" Margin="40,0,0,0"
                               IsHitTestVisible="False"
                               Visibility="{Binding Search, Converter={StaticResource EmptyStringToVis}}"/>
                </Grid>

                <!-- Create form -->
                <Border Visibility="{Binding ShowCreateForm, Converter={StaticResource BoolToVis}}"
                        Background="{DynamicResource CardBrush}" CornerRadius="12" BorderBrush="#E5E7EB"
                        BorderThickness="1" Padding="18" Margin="0,0,0,16">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="14" ShadowDepth="2" Opacity="0.07" Color="#111827"/>
                    </Border.Effect>
                    <StackPanel>
                        <TextBlock Text="New Exam" FontSize="15" FontWeight="Bold"
                                   Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,14"/>
                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="2*"/>
                                <ColumnDefinition Width="1.5*"/>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="100"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="0,0,10,0">
                                <TextBlock Text="Exam Name *" FontSize="11" Foreground="#64748B" Margin="0,0,0,4"/>
                                <TextBox Text="{Binding Title, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Margin="0,0,10,0">
                                <TextBlock Text="Subject" FontSize="11" Foreground="#64748B" Margin="0,0,0,4"/>
                                <TextBox Text="{Binding Subject, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2" Margin="0,0,10,0">
                                <TextBlock Text="Year" FontSize="11" Foreground="#64748B" Margin="0,0,0,4"/>
                                <TextBox Text="{Binding Year, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="3">
                                <TextBlock Text="Duration (min)" FontSize="11" Foreground="#64748B" Margin="0,0,0,4"/>
                                <TextBox Text="{Binding Duration, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>
                        </Grid>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                            <CheckBox Content="Shuffle Questions" IsChecked="{Binding ShuffleQuestions}" Margin="0,0,20,0" FontSize="13"/>
                            <CheckBox Content="Shuffle Options" IsChecked="{Binding ShuffleOptions}" FontSize="13"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <Button Content="Save Exam" Command="{Binding CreateExamCommand}"
                                    Style="{StaticResource PrimaryBtn}" Background="#047857" Padding="16,8" Margin="0,0,8,0"/>
                            <Button Content="Cancel" Command="{Binding ToggleCreateCommand}"
                                    Style="{StaticResource PrimaryBtn}" Background="#F1F5F9" Foreground="#111827" Padding="16,8"/>
                            <TextBlock Text="{Binding CreateStatus}" Foreground="{StaticResource DangerBrush}"
                                       VerticalAlignment="Center" Margin="12,0,0,0" FontSize="12"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Table header -->
                <Border Background="#F8FAFC" CornerRadius="8,8,0,0" Padding="16,0" Height="40">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*"/>
                            <ColumnDefinition Width="1.2*"/>
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="90"/>
                            <ColumnDefinition Width="80"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Exam Name" VerticalAlignment="Center" FontSize="11" FontWeight="Bold" Foreground="#64748B"/>
                        <TextBlock Grid.Column="1" Text="Subject" VerticalAlignment="Center" FontSize="11" FontWeight="Bold" Foreground="#64748B"/>
                        <TextBlock Grid.Column="2" Text="Year" VerticalAlignment="Center" FontSize="11" FontWeight="Bold" Foreground="#64748B"/>
                        <TextBlock Grid.Column="3" Text="Duration" VerticalAlignment="Center" FontSize="11" FontWeight="Bold" Foreground="#64748B"/>
                        <TextBlock Grid.Column="4" Text="Questions" VerticalAlignment="Center" FontSize="11" FontWeight="Bold" Foreground="#64748B"/>
                        <TextBlock Grid.Column="5" Text="Shuffle" VerticalAlignment="Center" FontSize="11" FontWeight="Bold" Foreground="#64748B"/>
                        <TextBlock Grid.Column="6" Text="Actions" VerticalAlignment="Center" FontSize="11" FontWeight="Bold" Foreground="#64748B"/>
                    </Grid>
                </Border>

                <!-- Empty state -->
                <Border BorderBrush="#E5E7EB" BorderThickness="1,0,1,1" CornerRadius="0,0,8,8"
                        Visibility="{Binding Filtered.Count, Converter={StaticResource ZeroToVis}}">
                    <StackPanel HorizontalAlignment="Center" Margin="0,40">
                        <Border Width="56" Height="56" CornerRadius="28" Background="#ECFDF5" HorizontalAlignment="Center" Margin="0,0,0,12">
                            <TextBlock Text="&#xE8A5;" FontFamily="Segoe MDL2 Assets" FontSize="22"
                                       Foreground="#059669" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="No exams yet" FontSize="15" FontWeight="Bold"
                                   Foreground="{DynamicResource TextPrimaryBrush}" HorizontalAlignment="Center"/>
                        <TextBlock Text="Click New Exam to create your first exam paper."
                                   FontSize="12" Foreground="#64748B" HorizontalAlignment="Center" Margin="0,6,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Exam rows -->
                <Border BorderBrush="#E5E7EB" BorderThickness="1,0,1,1" CornerRadius="0,0,8,8"
                        Visibility="{Binding Filtered.Count, Converter={StaticResource IntToVis}}">
                    <ItemsControl ItemsSource="{Binding Filtered}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Height="50">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="2*"/>
                                        <ColumnDefinition Width="1.2*"/>
                                        <ColumnDefinition Width="80"/>
                                        <ColumnDefinition Width="80"/>
                                        <ColumnDefinition Width="80"/>
                                        <ColumnDefinition Width="90"/>
                                        <ColumnDefinition Width="80"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.ColumnSpan="7" BorderBrush="#F1F5F9" BorderThickness="0,0,0,1"/>
                                    <TextBlock Text="{Binding Title}" Margin="16,0,0,0" VerticalAlignment="Center"
                                               FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                    <TextBlock Grid.Column="1" Text="{Binding SubjectDisplay}" VerticalAlignment="Center"
                                               FontSize="13" Foreground="#64748B"/>
                                    <TextBlock Grid.Column="2" Text="{Binding Year}" VerticalAlignment="Center"
                                               FontSize="13" Foreground="#64748B"/>
                                    <TextBlock Grid.Column="3" Text="{Binding DurationMinutes, StringFormat='{}{0}m'}"
                                               VerticalAlignment="Center" FontSize="13" Foreground="#64748B"/>
                                    <TextBlock Grid.Column="4" Text="{Binding QuestionCount}" VerticalAlignment="Center"
                                               FontSize="13" Foreground="#64748B"/>
                                    <StackPanel Grid.Column="5" Orientation="Horizontal" VerticalAlignment="Center">
                                        <Border CornerRadius="4" Padding="6,3" Margin="0,0,4,0"
                                                Visibility="{Binding ShuffleQuestions, Converter={StaticResource BoolToVis}}">
                                            <Border.Background><SolidColorBrush Color="#DCFCE7"/></Border.Background>
                                            <TextBlock Text="Q" FontSize="10" FontWeight="Bold" Foreground="#047857"/>
                                        </Border>
                                        <Border CornerRadius="4" Padding="6,3"
                                                Visibility="{Binding ShuffleOptions, Converter={StaticResource BoolToVis}}">
                                            <Border.Background><SolidColorBrush Color="#EFF6FF"/></Border.Background>
                                            <TextBlock Text="O" FontSize="10" FontWeight="Bold" Foreground="#2563EB"/>
                                        </Border>
                                    </StackPanel>
                                    <StackPanel Grid.Column="6" Orientation="Horizontal" VerticalAlignment="Center">
                                        <Button Style="{StaticResource PrimaryBtn}" Background="#EFF6FF" Foreground="#2563EB"
                                                Padding="8,5" Margin="0,0,5,0" ToolTip="View Questions"
                                                Command="{Binding DataContext.SelectExamCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                CommandParameter="{Binding}">
                                            <TextBlock Text="&#xE736;" FontFamily="Segoe MDL2 Assets"/>
                                        </Button>
                                        <Button Style="{StaticResource PrimaryBtn}" Background="#FEF2F2" Foreground="#DC2626"
                                                Padding="8,5" ToolTip="Delete"
                                                Command="{Binding DataContext.DeleteCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                CommandParameter="{Binding}">
                                            <TextBlock Text="&#xE74D;" FontFamily="Segoe MDL2 Assets"/>
                                        </Button>
                                    </StackPanel>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <!-- Right: Detail panel for selected exam (Read-only questions list) -->
        <Border Grid.Column="1" Background="{DynamicResource CardBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1,0,0,0"
                Visibility="{Binding SelectedExamStr, Converter={StaticResource NonEmptyToVis}}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Border.Effect>
                    <DropShadowEffect BlurRadius="12" ShadowDepth="0" Opacity="0.05" Color="#000000"/>
                </Border.Effect>

                <!-- Panel header -->
                <Border Grid.Row="0" Padding="20,24" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="{Binding SelectedExam.Title}" FontSize="18" FontWeight="Bold"
                                       Foreground="{DynamicResource TextPrimaryBrush}" TextTrimming="CharacterEllipsis"/>
                            <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                <Border Background="{DynamicResource NavActiveBrush}" CornerRadius="4" Padding="6,2" Margin="0,0,8,0">
                                    <TextBlock Text="{Binding SelectedExam.SubjectDisplay}" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource NavActiveFgBrush}"/>
                                </Border>
                                <TextBlock FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center">
                                    <Run Text="{Binding SelectedExam.QuestionCount}"/>
                                    <Run Text=" questions"/>
                                </TextBlock>
                            </StackPanel>
                        </StackPanel>
                        <Button Grid.Column="1" Command="{Binding CloseDetailCommand}"
                                Style="{StaticResource PrimaryBtn}" Background="Transparent"
                                Foreground="{DynamicResource TextSecondaryBrush}" Padding="8" VerticalAlignment="Top">
                            <TextBlock Text="&#xE8BB;" FontFamily="Segoe MDL2 Assets" FontSize="14"/>
                        </Button>
                    </Grid>
                </Border>

                <!-- Question list (Read-only) -->
                <Grid Grid.Row="1">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="0,0,0,24">
                            <Border Padding="24,40" Visibility="{Binding ExamQuestions.Count, Converter={StaticResource ZeroToVis}}">
                                <StackPanel HorizontalAlignment="Center">
                                    <TextBlock Text="&#xE9CE;" FontFamily="Segoe MDL2 Assets" FontSize="48" Foreground="{DynamicResource BorderBrush}" HorizontalAlignment="Center" Margin="0,0,0,16"/>
                                    <TextBlock Text="No questions in this exam" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource TextSecondaryBrush}" HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                            
                            <ItemsControl ItemsSource="{Binding ExamQuestions}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Padding="20,16" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <Border Width="28" Height="28" CornerRadius="14" Background="{DynamicResource NavActiveBrush}"
                                                        Margin="0,0,12,0" VerticalAlignment="Top">
                                                    <TextBlock Text="{Binding QuestionNumber}" FontSize="12" FontWeight="Bold"
                                                               Foreground="{DynamicResource NavActiveFgBrush}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                                <StackPanel Grid.Column="1">
                                                    <TextBlock Text="{Binding Text}" FontSize="13" TextWrapping="Wrap"
                                                               Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,8" LineHeight="18"/>
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="Correct Answer: " Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12"/>
                                                        <TextBlock Text="{Binding CorrectAnswer}" Foreground="{DynamicResource GreenBrush}"
                                                                   FontSize="12" FontWeight="Bold"/>
                                                    </StackPanel>
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</UserControl>
