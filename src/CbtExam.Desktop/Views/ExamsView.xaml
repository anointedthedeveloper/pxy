<UserControl x:Class="CbtExam.Desktop.Views.ExamsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:CbtExam.Desktop.ViewModels">
    <Grid Background="{DynamicResource BgBrush}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Top Header & Search (Always Visible) -->
            <Grid Grid.Row="0" Margin="26,24,26,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="Exam Templates" FontSize="28" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                    <TextBlock Text="Design and manage your exam configurations. Configure subjects, pooling logic, and timing." FontSize="13" Foreground="#64748B" Margin="0,4,0,0"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <!-- Inline Search Bar (Constrained Width) -->
                    <Grid Width="280" Height="38" Margin="0,0,12,0" VerticalAlignment="Center">
                        <Border Background="{DynamicResource CardBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="10">
                            <TextBox Text="{Binding Search, UpdateSourceTrigger=PropertyChanged}" Padding="36,8,12,8" FontSize="13"
                                     Background="Transparent" BorderThickness="0" VerticalAlignment="Center" Foreground="{DynamicResource TextPrimaryBrush}"/>
                        </Border>
                        <TextBlock Text="&#xE721;" FontFamily="Segoe MDL2 Assets" FontSize="13" Foreground="#94A3B8"
                                   VerticalAlignment="Center" HorizontalAlignment="Left" Margin="12,0,0,0" IsHitTestVisible="False"/>
                        <TextBlock Text="Search templates..." FontSize="13" Foreground="#94A3B8"
                                   VerticalAlignment="Center" HorizontalAlignment="Left" Margin="36,0,0,0"
                                   IsHitTestVisible="False"
                                   Visibility="{Binding Search, Converter={StaticResource EmptyStringToVis}}"/>
                    </Grid>
                    
                    <Button Command="{Binding RefreshCommand}" Style="{StaticResource PrimaryBtn}"
                            Background="#F1F5F9" Foreground="#111827" Padding="12,8" Margin="0,0,8,0">
                        <TextBlock Text="&#xE72C;" FontFamily="Segoe MDL2 Assets" FontSize="13"/>
                    </Button>
                    <Button Command="{Binding ToggleCreateCommand}" Style="{StaticResource PrimaryBtn}"
                            Background="#047857" Padding="16,8">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE710;" FontFamily="Segoe MDL2 Assets" FontSize="12" Margin="0,0,7,0" VerticalAlignment="Center"/>
                            <TextBlock Text="New Template" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>

            <!-- Main Content Area -->
            <Grid Grid.Row="1">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="26,0,26,26">
                        
                        <!-- Create/Edit Form (Unified Single-Screen Form) -->
                        <Border Visibility="{Binding ShowCreateForm, Converter={StaticResource BoolToVis}}"
                                Background="{DynamicResource CardBrush}" CornerRadius="16" BorderBrush="#E2E8F0"
                                BorderThickness="1" Margin="0,0,0,20">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="30" ShadowDepth="4" Opacity="0.05" Color="#000000"/>
                            </Border.Effect>
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/> <!-- Header -->
                                    <RowDefinition Height="*"/>    <!-- Content -->
                                    <RowDefinition Height="Auto"/> <!-- Footer -->
                                </Grid.RowDefinitions>

                                <!-- Form Header & Close -->
                                <Border Background="#F8FAFC" CornerRadius="16,16,0,0" Padding="24,16" BorderBrush="#E2E8F0" BorderThickness="0,0,0,1">
                                    <Grid>
                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding FormTitle}" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                                            <Border Margin="16,0,0,0" Background="#ECFDF5" CornerRadius="8" Padding="10,4" VerticalAlignment="Center">
                                                <TextBlock FontSize="11" FontWeight="Bold" Foreground="#047857">Unified Builder</TextBlock>
                                            </Border>
                                        </StackPanel>
                                        <Button HorizontalAlignment="Right" Command="{Binding ToggleCreateCommand}"
                                                Style="{StaticResource PrimaryBtn}" Background="Transparent"
                                                Foreground="{DynamicResource TextSecondaryBrush}" Padding="8">
                                            <TextBlock Text="&#xE8BB;" FontFamily="Segoe MDL2 Assets" FontSize="14"/>
                                        </Button>
                                    </Grid>
                                </Border>

                                <!-- Content Container -->
                                <Border Grid.Row="1" Padding="24">
                                    <StackPanel>
                                        <!-- General Settings (Exam Name & Duration side-by-side) -->
                                        <Grid Margin="0,0,0,20">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="3*"/>
                                                <ColumnDefinition Width="2*"/>
                                            </Grid.ColumnDefinitions>
                                            
                                            <!-- Exam Name -->
                                            <StackPanel Margin="0,0,20,0">
                                                <TextBlock Text="Exam Name *" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,6"/>
                                                <Border Height="40" Background="{DynamicResource CardBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="10" Padding="12,0">
                                                    <Grid>
                                                        <TextBox x:Name="TitleInput" Text="{Binding Title, UpdateSourceTrigger=PropertyChanged}" Background="Transparent" BorderThickness="0" Padding="0" FontSize="13" Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                                                        <TextBlock Text="e.g. JAMB Mock Exam 2026" FontSize="13" Foreground="#94A3B8" IsHitTestVisible="False" VerticalAlignment="Center"
                                                                   Visibility="{Binding Title, Converter={StaticResource EmptyStringToVis}}"/>
                                                    </Grid>
                                                </Border>
                                            </StackPanel>
                                            
                                            <!-- Duration -->
                                            <StackPanel Grid.Column="1">
                                                <TextBlock Text="Duration (minutes) *" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,6"/>
                                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                    <!-- Compact Input -->
                                                    <Border Width="70" Height="40" Background="{DynamicResource CardBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="10" Padding="8,0">
                                                        <TextBox Text="{Binding Duration, UpdateSourceTrigger=PropertyChanged}" Background="Transparent" BorderThickness="0" Padding="0" FontSize="13" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}" HorizontalContentAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                    
                                                    <!-- Compact Duration Badges -->
                                                    <StackPanel Orientation="Horizontal" Margin="10,0,0,0" VerticalAlignment="Center">
                                                        <StackPanel.Resources>
                                                            <Style x:Key="DurationBadgeBtn" TargetType="Button">
                                                                <Setter Property="Padding" Value="10,6"/>
                                                                <Setter Property="FontSize" Value="11"/>
                                                                <Setter Property="FontWeight" Value="SemiBold"/>
                                                                <Setter Property="Cursor" Value="Hand"/>
                                                                <Setter Property="Template">
                                                                    <Setter.Value>
                                                                        <ControlTemplate TargetType="Button">
                                                                            <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="12" Padding="{TemplateBinding Padding}" SnapsToDevicePixels="True">
                                                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                            </Border>
                                                                            <ControlTemplate.Triggers>
                                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                                    <Setter TargetName="bd" Property="Opacity" Value="0.85"/>
                                                                                </Trigger>
                                                                            </ControlTemplate.Triggers>
                                                                        </ControlTemplate>
                                                                    </Setter.Value>
                                                                </Setter>
                                                            </Style>
                                                        </StackPanel.Resources>
                                                        
                                                        <Button Command="{Binding SetDuration30}" Margin="0,0,5,0">
                                                            <Button.Style>
                                                                <Style TargetType="Button" BasedOn="{StaticResource DurationBadgeBtn}">
                                                                    <Setter Property="Background" Value="#F1F5F9"/>
                                                                    <Setter Property="Foreground" Value="#475569"/>
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding Duration}" Value="30">
                                                                            <Setter Property="Background" Value="{DynamicResource AccentBrush}"/>
                                                                            <Setter Property="Foreground" Value="White"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </Button.Style>
                                                            30m
                                                        </Button>
                                                        
                                                        <Button Command="{Binding SetDuration45}" Margin="0,0,5,0">
                                                            <Button.Style>
                                                                <Style TargetType="Button" BasedOn="{StaticResource DurationBadgeBtn}">
                                                                    <Setter Property="Background" Value="#F1F5F9"/>
                                                                    <Setter Property="Foreground" Value="#475569"/>
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding Duration}" Value="45">
                                                                            <Setter Property="Background" Value="{DynamicResource AccentBrush}"/>
                                                                            <Setter Property="Foreground" Value="White"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </Button.Style>
                                                            45m
                                                        </Button>
                                                        
                                                        <Button Command="{Binding SetDuration60}" Margin="0,0,5,0">
                                                            <Button.Style>
                                                                <Style TargetType="Button" BasedOn="{StaticResource DurationBadgeBtn}">
                                                                    <Setter Property="Background" Value="#F1F5F9"/>
                                                                    <Setter Property="Foreground" Value="#475569"/>
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding Duration}" Value="60">
                                                                            <Setter Property="Background" Value="{DynamicResource AccentBrush}"/>
                                                                            <Setter Property="Foreground" Value="White"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </Button.Style>
                                                            60m
                                                        </Button>
                                                        
                                                        <Button Command="{Binding SetDuration90}" Margin="0,0,5,0">
                                                            <Button.Style>
                                                                <Style TargetType="Button" BasedOn="{StaticResource DurationBadgeBtn}">
                                                                    <Setter Property="Background" Value="#F1F5F9"/>
                                                                    <Setter Property="Foreground" Value="#475569"/>
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding Duration}" Value="90">
                                                                            <Setter Property="Background" Value="{DynamicResource AccentBrush}"/>
                                                                            <Setter Property="Foreground" Value="White"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </Button.Style>
                                                            90m
                                                        </Button>
                                                        
                                                        <Button Command="{Binding SetDuration120}">
                                                            <Button.Style>
                                                                <Style TargetType="Button" BasedOn="{StaticResource DurationBadgeBtn}">
                                                                    <Setter Property="Background" Value="#F1F5F9"/>
                                                                    <Setter Property="Foreground" Value="#475569"/>
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding Duration}" Value="120">
                                                                            <Setter Property="Background" Value="{DynamicResource AccentBrush}"/>
                                                                            <Setter Property="Foreground" Value="White"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </Button.Style>
                                                            120m
                                                        </Button>
                                                    </StackPanel>
                                                </StackPanel>
                                            </StackPanel>
                                        </Grid>

                                        <!-- Subject Configuration Title & Add Button -->
                                        <Border BorderBrush="#E2E8F0" BorderThickness="0,1,0,0" Padding="0,16,0,0" Margin="0,0,0,16">
                                            <Grid>
                                                <StackPanel>
                                                    <TextBlock Text="Subject Configuration" FontSize="15" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                                    <TextBlock Text="Add subjects and configure question pooling per subject and source year." FontSize="12" Foreground="#64748B" Margin="0,2,0,0"/>
                                                </StackPanel>
                                                
                                                <!-- Add Subject Button -->
                                                <Button HorizontalAlignment="Right" Command="{Binding AddSubjectCommand}"
                                                        Style="{StaticResource PrimaryBtn}" Background="#047857" Padding="12,6"
                                                        IsEnabled="{Binding CanAddSubject}"
                                                        ToolTip="Left click for single, Right click for batch selection">
                                                    <Button.ContextMenu>
                                                        <ContextMenu ItemsSource="{Binding AvailableSubjects}">
                                                            <ContextMenu.ItemContainerStyle>
                                                                <Style TargetType="MenuItem">
                                                                    <Setter Property="Header" Value="{Binding}"/>
                                                                    <Setter Property="Command" Value="{Binding DataContext.BatchAddSubjectsCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                                                    <Setter Property="CommandParameter">
                                                                        <Setter.Value>
                                                                            <MultiBinding Converter="{StaticResource PassThroughConverter}">
                                                                                <Binding/>
                                                                            </MultiBinding>
                                                                        </Setter.Value>
                                                                    </Setter>
                                                                </Style>
                                                            </ContextMenu.ItemContainerStyle>
                                                        </ContextMenu>
                                                    </Button.ContextMenu>
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="&#xE710;" FontFamily="Segoe MDL2 Assets" FontSize="11" Margin="0,0,5,0" VerticalAlignment="Center"/>
                                                        <TextBlock Text="Add Subject" FontSize="11" VerticalAlignment="Center"/>
                                                    </StackPanel>
                                                </Button>
                                            </Grid>
                                        </Border>

                                        <!-- Subject Rows (Compact, Premium Cards) -->
                                        <ItemsControl ItemsSource="{Binding SubjectConfigs}" Margin="0,0,0,12">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate DataType="{x:Type vm:ExamSubjectConfigVM}">
                                                    <Border Background="#F8FAFC" CornerRadius="12" Padding="16,14" Margin="0,0,0,12" BorderBrush="#E2E8F0" BorderThickness="1">
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="Auto"/> <!-- Remove button -->
                                                            </Grid.ColumnDefinitions>
                                                            
                                                            <StackPanel>
                                                                <!-- Subject & Questions Grid -->
                                                                <Grid Margin="0,0,0,10">
                                                                    <Grid.ColumnDefinitions>
                                                                        <ColumnDefinition Width="2*"/>
                                                                        <ColumnDefinition Width="1*"/>
                                                                    </Grid.ColumnDefinitions>
                                                                    
                                                                    <!-- Subject Dropdown -->
                                                                    <StackPanel Margin="0,0,12,0">
                                                                        <TextBlock Text="Select Subject" FontSize="11" FontWeight="SemiBold" Foreground="#64748B" Margin="0,0,0,4"/>
                                                                        <ComboBox ItemsSource="{Binding AvailableSubjects}" SelectedItem="{Binding SelectedSubject}" Height="36" Padding="8,4"/>
                                                                    </StackPanel>
                                                                    
                                                                    <!-- Questions Count -->
                                                                    <StackPanel Grid.Column="1">
                                                                        <TextBlock Text="Questions to Pick" FontSize="11" FontWeight="SemiBold" Foreground="#64748B" Margin="0,0,0,4"/>
                                                                        <Border Height="36" CornerRadius="8" BorderThickness="1">
                                                                            <Border.Style>
                                                                                <Style TargetType="Border">
                                                                                    <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
                                                                                    <Setter Property="Background" Value="White"/>
                                                                                    <Style.Triggers>
                                                                                        <DataTrigger Binding="{Binding HasPoolWarning}" Value="True">
                                                                                            <Setter Property="BorderBrush" Value="#EF4444"/>
                                                                                            <Setter Property="Background" Value="#FFF5F5"/>
                                                                                        </DataTrigger>
                                                                                    </Style.Triggers>
                                                                                </Style>
                                                                            </Border.Style>
                                                                            <TextBox Text="{Binding QuestionCount, UpdateSourceTrigger=PropertyChanged}" Background="Transparent" BorderThickness="0" Padding="8,0" FontSize="13" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center" HorizontalContentAlignment="Center"/>
                                                                        </Border>
                                                                    </StackPanel>
                                                                </Grid>
                                                                
                                                                <!-- Years Selector -->
                                                                <StackPanel Visibility="{Binding AvailableYears.Count, Converter={StaticResource IntToVis}}">
                                                                    <Grid Margin="0,0,0,6">
                                                                        <StackPanel Orientation="Horizontal">
                                                                            <TextBlock Text="Source Years" FontSize="11" FontWeight="SemiBold" Foreground="#64748B" VerticalAlignment="Center"/>
                                                                            <Border Background="#EFF6FF" CornerRadius="8" Padding="6,1" Margin="8,0,0,0">
                                                                                <TextBlock FontSize="10" FontWeight="Bold" Foreground="#2563EB">
                                                                                    Pool: <Run Text="{Binding PoolSize, Mode=OneWay}"/> Qs
                                                                                </TextBlock>
                                                                            </Border>
                                                                        </StackPanel>
                                                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                                                            <Button Content="All" Command="{Binding SelectAllYearsCommand}" Style="{StaticResource PrimaryBtn}" Background="Transparent" Foreground="#2563EB" BorderThickness="0" Padding="6,0" FontSize="9"/>
                                                                            <Button Content="None" Command="{Binding DeselectAllYearsCommand}" Style="{StaticResource PrimaryBtn}" Background="Transparent" Foreground="#64748B" BorderThickness="0" Padding="6,0" FontSize="9"/>
                                                                        </StackPanel>
                                                                    </Grid>
                                                                    
                                                                    <ItemsControl ItemsSource="{Binding AvailableYears}">
                                                                        <ItemsControl.ItemsPanel>
                                                                            <ItemsPanelTemplate>
                                                                                <WrapPanel/>
                                                                            </ItemsPanelTemplate>
                                                                        </ItemsControl.ItemsPanel>
                                                                        <ItemsControl.ItemTemplate>
                                                                            <DataTemplate DataType="{x:Type vm:YearToggle}">
                                                                                <Button Command="{Binding DataContext.ToggleYearCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                                                        CommandParameter="{Binding}"
                                                                                        Background="Transparent" BorderThickness="0" Padding="0" Margin="0,0,4,4">
                                                                                    <Border CornerRadius="6" Padding="8,4" Cursor="Hand">
                                                                                        <Border.Style>
                                                                                            <Style TargetType="Border">
                                                                                                <Setter Property="Background" Value="White"/>
                                                                                                <Setter Property="BorderBrush" Value="#CBD5E1"/>
                                                                                                <Setter Property="BorderThickness" Value="1"/>
                                                                                                <Style.Triggers>
                                                                                                    <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                                                                        <Setter Property="Background" Value="#ECFDF4"/>
                                                                                                        <Setter Property="BorderBrush" Value="#10B981"/>
                                                                                                    </DataTrigger>
                                                                                                </Style.Triggers>
                                                                                            </Style>
                                                                                        </Border.Style>
                                                                                        <TextBlock Text="{Binding Label}" FontSize="11">
                                                                                            <TextBlock.Style>
                                                                                                <Style TargetType="TextBlock">
                                                                                                    <Setter Property="Foreground" Value="#64748B"/>
                                                                                                    <Style.Triggers>
                                                                                                        <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                                                                            <Setter Property="Foreground" Value="#047857"/>
                                                                                                            <Setter Property="FontWeight" Value="SemiBold"/>
                                                                                                        </DataTrigger>
                                                                                                    </Style.Triggers>
                                                                                                </Style>
                                                                                            </TextBlock.Style>
                                                                                        </TextBlock>
                                                                                    </Border>
                                                                                </Button>
                                                                            </DataTemplate>
                                                                        </ItemsControl.ItemTemplate>
                                                                    </ItemsControl>
                                                                </StackPanel>
                                                            </StackPanel>
                                                            
                                                            <!-- Remove row button -->
                                                            <Button Grid.Column="1" Command="{Binding RemoveCommand}" VerticalAlignment="Center" Margin="12,0,0,0"
                                                                    Style="{StaticResource PrimaryBtn}" Background="Transparent" Foreground="#94A3B8" Padding="6">
                                                                <TextBlock Text="&#xE74D;" FontFamily="Segoe MDL2 Assets" FontSize="13"/>
                                                            </Button>
                                                        </Grid>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>

                                        <!-- Shuffling Options -->
                                        <Border BorderBrush="#E2E8F0" BorderThickness="0,1,0,0" Padding="0,14,0,0" Margin="0,4,0,0">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                
                                                <StackPanel>
                                                    <TextBlock Text="Shuffling Options" FontSize="14" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                                    <TextBlock Text="Configure random ordering of questions and choices." FontSize="11" Foreground="#64748B" Margin="0,2,0,0"/>
                                                </StackPanel>
                                                
                                                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                                    <CheckBox IsChecked="{Binding ShuffleQuestions}" Content="Shuffle Questions" Margin="0,0,16,0" FontSize="12" FontWeight="SemiBold"/>
                                                    <CheckBox IsChecked="{Binding ShuffleOptions}" Content="Shuffle Options" FontSize="12" FontWeight="SemiBold"/>
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </StackPanel>
                                </Border>

                                <!-- Form Footer (Unified Save) -->
                                <Border Grid.Row="2" Background="#F8FAFC" CornerRadius="0,0,16,16" Padding="24,14" BorderBrush="#E2E8F0" BorderThickness="0,1,0,0">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        
                                        <!-- Configuration Summary & Status -->
                                        <StackPanel VerticalAlignment="Center">
                                            <TextBlock Text="{Binding CreateStatus}" VerticalAlignment="Center" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,2">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Foreground" Value="{StaticResource DangerBrush}"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding StatusOk}" Value="True">
                                                                <Setter Property="Foreground" Value="#059669"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="Summary: " FontSize="11" Foreground="#64748B"/>
                                                <TextBlock FontSize="11" FontWeight="Bold" Foreground="#1E293B">
                                                    <Run Text="{Binding TotalSubjects, Mode=OneWay}"/> Subject(s) | <Run Text="{Binding TotalQuestions, Mode=OneWay}"/> Question(s) | <Run Text="{Binding Duration, Mode=OneWay}"/> Min(s)
                                                </TextBlock>
                                            </StackPanel>
                                        </StackPanel>
                                        
                                        <!-- Save Button -->
                                        <Button Grid.Column="1" Command="{Binding SaveCommand}"
                                                Style="{StaticResource PrimaryBtn}" Background="{DynamicResource AccentBrush}" Padding="28,8" Height="36">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="&#xE73E;" FontFamily="Segoe MDL2 Assets" FontSize="11" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                                <TextBlock Text="Save Configuration" FontSize="12" FontWeight="Bold" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </Button>
                                    </Grid>
                                </Border>
                            </Grid>
                        </Border>

                        <!-- Templates Table Header -->
                        <Border Background="#F8FAFC" CornerRadius="8,8,0,0" Padding="16,0" Height="40">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="2.5*"/>
                                    <ColumnDefinition Width="2*"/>
                                    <ColumnDefinition Width="80"/>
                                    <ColumnDefinition Width="90"/>
                                    <ColumnDefinition Width="130"/>
                                    <ColumnDefinition Width="100"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="TEMPLATE NAME" VerticalAlignment="Center" FontSize="11" FontWeight="Bold" Foreground="#64748B"/>
                                <TextBlock Grid.Column="1" Text="SUBJECTS" VerticalAlignment="Center" FontSize="11" FontWeight="Bold" Foreground="#64748B"/>
                                <TextBlock Grid.Column="2" Text="DUR." VerticalAlignment="Center" FontSize="11" FontWeight="Bold" Foreground="#64748B"/>
                                <TextBlock Grid.Column="3" Text="QUESTIONS" VerticalAlignment="Center" FontSize="11" FontWeight="Bold" Foreground="#64748B"/>
                                <TextBlock Grid.Column="4" Text="CREATED" VerticalAlignment="Center" FontSize="11" FontWeight="Bold" Foreground="#64748B"/>
                                <TextBlock Grid.Column="5" Text="ACTIONS" VerticalAlignment="Center" FontSize="11" FontWeight="Bold" Foreground="#64748B"/>
                            </Grid>
                        </Border>

                        <!-- Templates Table Content -->
                        <Border BorderBrush="#E5E7EB" BorderThickness="1,0,1,1" CornerRadius="0,0,8,8">
                            <StackPanel>
                                <!-- Empty state -->
                                <Border Visibility="{Binding Filtered.Count, Converter={StaticResource ZeroToVis}}" Padding="60">
                                    <StackPanel HorizontalAlignment="Center">
                                        <Border Width="64" Height="64" CornerRadius="32" Background="#F1F5F9" Margin="0,0,0,16">
                                            <TextBlock Text="&#xE82D;" FontFamily="Segoe MDL2 Assets" FontSize="28" Foreground="#94A3B8" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <TextBlock Text="No exam templates found" FontSize="16" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}" HorizontalAlignment="Center"/>
                                        <TextBlock Text="Try adjusting your search or create a new template." FontSize="13" Foreground="#64748B" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                                    </StackPanel>
                                </Border>

                                <!-- Table Rows -->
                                <ItemsControl ItemsSource="{Binding Filtered}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border BorderBrush="#F1F5F9" BorderThickness="0,0,0,1" Height="60">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="2.5*"/>
                                                        <ColumnDefinition Width="2*"/>
                                                        <ColumnDefinition Width="80"/>
                                                        <ColumnDefinition Width="90"/>
                                                        <ColumnDefinition Width="130"/>
                                                        <ColumnDefinition Width="100"/>
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel VerticalAlignment="Center" Margin="16,0,0,0">
                                                        <TextBlock Text="{Binding Title}" FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                                        <TextBlock Text="{Binding SubjectDisplay}" FontSize="11" Foreground="#94A3B8" Visibility="Collapsed"/>
                                                    </StackPanel>
                                                    <TextBlock Grid.Column="1" Text="{Binding Subject}" VerticalAlignment="Center" FontSize="12" Foreground="#64748B" TextTrimming="CharacterEllipsis"/>
                                                    <TextBlock Grid.Column="2" Text="{Binding DurationMinutes, StringFormat='{}{0}m'}" VerticalAlignment="Center" FontSize="13" Foreground="#64748B"/>
                                                    <Border Grid.Column="3" VerticalAlignment="Center" HorizontalAlignment="Left" Background="#EFF6FF" CornerRadius="6" Padding="8,4">
                                                        <TextBlock Text="{Binding QuestionCount}" FontSize="12" FontWeight="Bold" Foreground="#2563EB"/>
                                                    </Border>
                                                    <TextBlock Grid.Column="4" Text="{Binding CreatedAt, StringFormat='dd MMM yyyy'}" VerticalAlignment="Center" FontSize="12" Foreground="#94A3B8"/>
                                                    <StackPanel Grid.Column="5" Orientation="Horizontal" VerticalAlignment="Center">
                                                        <Button Style="{StaticResource PrimaryBtn}" Background="#F0F9FF" Foreground="#0284C7" Padding="8" Margin="0,0,6,0" ToolTip="Edit"
                                                                Command="{Binding DataContext.EditCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}" CommandParameter="{Binding}">
                                                            <TextBlock Text="&#xE70F;" FontFamily="Segoe MDL2 Assets"/>
                                                        </Button>
                                                        <Button Style="{StaticResource PrimaryBtn}" Background="#FEF2F2" Foreground="#DC2626" Padding="8" ToolTip="Delete"
                                                                Command="{Binding DataContext.DeleteCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}" CommandParameter="{Binding}">
                                                            <TextBlock Text="&#xE74D;" FontFamily="Segoe MDL2 Assets"/>
                                                        </Button>
                                                    </StackPanel>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>

                <!-- Loading Overlay -->
                <Border Background="#40FFFFFF" Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}" IsHitTestVisible="True">
                    <Border Background="White" CornerRadius="12" Padding="30" HorizontalAlignment="Center" VerticalAlignment="Center" BorderBrush="#E2E8F0" BorderThickness="1">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="20" ShadowDepth="0" Opacity="0.1"/>
                        </Border.Effect>
                        <StackPanel>
                            <ProgressBar IsIndeterminate="True" Width="180" Height="4" Foreground="{DynamicResource AccentBrush}" Background="#F1F5F9" BorderThickness="0"/>
                            <TextBlock Text="{Binding BusyMessage}" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="13" FontWeight="SemiBold" Margin="0,16,0,0" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</UserControl>
