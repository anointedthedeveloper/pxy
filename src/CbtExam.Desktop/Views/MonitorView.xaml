<UserControl x:Class="CbtExam.Desktop.Views.MonitorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer Background="{StaticResource BgBrush}">
        <StackPanel Margin="26">
            <Grid Margin="0,0,0,22">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="Students" FontSize="28" FontWeight="Bold" Foreground="#111827"/>
                    <TextBlock Text="{Binding SessionInfo, Mode=OneWay}" FontSize="14" Foreground="#64748B" Margin="0,8,0,0"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Border CornerRadius="9" Background="#ECFDF5" BorderBrush="#BBF7D0" BorderThickness="1"
                            Padding="11,6" Margin="0,0,10,0">
                        <TextBlock Text="Auto-refresh every 5s" FontSize="12" FontWeight="SemiBold" Foreground="#047857"/>
                    </Border>
                    <Button Command="{Binding RefreshCommand}" Style="{StaticResource PrimaryBtn}" Background="#059669" Padding="18,11">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE72C;" FontFamily="Segoe MDL2 Assets" Margin="0,0,8,0"/>
                            <TextBlock Text="Refresh"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>

            <UniformGrid Columns="2" Margin="0,0,0,20">
                <Border Background="White" CornerRadius="14" BorderBrush="#E5E7EB" BorderThickness="1" Padding="18" Margin="0,0,12,0">
                    <StackPanel>
                        <TextBlock Text="Total Students" FontSize="13" Foreground="#64748B"/>
                        <TextBlock Text="{Binding Students.Count, Mode=OneWay}" FontSize="32" FontWeight="Bold" Foreground="#111827" Margin="0,8,0,0"/>
                    </StackPanel>
                </Border>
                <Border Background="White" CornerRadius="14" BorderBrush="#E5E7EB" BorderThickness="1" Padding="18">
                    <StackPanel>
                        <TextBlock Text="In Progress" FontSize="13" Foreground="#64748B"/>
                        <TextBlock Text="{Binding Students.Count, Mode=OneWay}" FontSize="32" FontWeight="Bold" Foreground="#059669" Margin="0,8,0,0"/>
                    </StackPanel>
                </Border>
            </UniformGrid>

            <Border Background="White" CornerRadius="14" BorderBrush="#E5E7EB" BorderThickness="1" Padding="18">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="18" ShadowDepth="2" Opacity="0.06" Color="#111827"/>
                </Border.Effect>
                <StackPanel>
                    <Grid Margin="0,0,0,18">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Grid Width="360" Height="44">
                            <TextBox Padding="40,8,12,8"/>
                            <TextBlock Text="&#xE721;" FontFamily="Segoe MDL2 Assets" FontSize="15" Foreground="#64748B"
                                       VerticalAlignment="Center" Margin="14,0,0,0"/>
                            <TextBlock Text="Search students..." FontSize="13" Foreground="#64748B"
                                       VerticalAlignment="Center" Margin="40,0,0,0" IsHitTestVisible="False"/>
                        </Grid>
                        <Button Grid.Column="1" Style="{StaticResource PrimaryBtn}" Background="#F8FAFC" Foreground="#111827" Padding="15,10">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE71C;" FontFamily="Segoe MDL2 Assets" Margin="0,0,8,0"/>
                                <TextBlock Text="Filters"/>
                            </StackPanel>
                        </Button>
                    </Grid>

                    <DataGrid ItemsSource="{Binding Students, Mode=OneWay}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Name" Binding="{Binding FullName, Mode=OneWay}" Width="*"/>
                            <DataGridTextColumn Header="Student ID" Binding="{Binding StudentId, Mode=OneWay}" Width="130"/>
                            <DataGridTextColumn Header="Joined" Binding="{Binding JoinedAt, Mode=OneWay, StringFormat='HH:mm:ss'}" Width="100"/>
                            <DataGridTextColumn Header="Answered" Binding="{Binding AnsweredCount, Mode=OneWay}" Width="100"/>
                            <DataGridTextColumn Header="Tab Switches" Binding="{Binding TabSwitchCount, Mode=OneWay}" Width="120"/>
                            <DataGridTemplateColumn Header="Status" Width="130">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Border CornerRadius="6" Padding="9,4" HorizontalAlignment="Left">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Background" Value="#ECFDF5"/>
                                                    <Setter Property="BorderBrush" Value="#BBF7D0"/>
                                                    <Setter Property="BorderThickness" Value="1"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsSubmitted, Mode=OneWay}" Value="True">
                                                            <Setter Property="Background" Value="#EFF6FF"/>
                                                            <Setter Property="BorderBrush" Value="#BFDBFE"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <TextBlock FontSize="12" FontWeight="Bold">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Text" Value="In Progress"/>
                                                        <Setter Property="Foreground" Value="#047857"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsSubmitted, Mode=OneWay}" Value="True">
                                                                <Setter Property="Text" Value="Submitted"/>
                                                                <Setter Property="Foreground" Value="#2563EB"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </Border>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
