<UserControl x:Class="CbtExam.Desktop.Views.SessionView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer Background="{DynamicResource BgBrush}">
        <StackPanel Margin="32">

            <!-- Header -->
            <Grid Margin="0,0,0,32">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="Live Exam Sessions" FontSize="28" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                    <TextBlock Text="Manage active rooms and monitor candidate connectivity in real-time." FontSize="14" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,6,0,0"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Command="{Binding EndAllCommand}" Style="{StaticResource PrimaryBtn}"
                            Background="#991B1B" Foreground="White" Padding="18,10" Margin="0,0,12,0"
                            Visibility="{Binding HasActiveSessions, Converter={StaticResource BoolToVis}}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE71A;" FontFamily="Segoe MDL2 Assets" Margin="0,0,10,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Terminate All" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button Command="{Binding RefreshCommand}" Style="{StaticResource PrimaryBtn}"
                            Background="{DynamicResource CardBrush}" Foreground="{DynamicResource TextPrimaryBrush}" Padding="16,10">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE72C;" FontFamily="Segoe MDL2 Assets" Margin="0,0,10,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Refresh" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>

            <!-- Active sessions cards -->
            <ItemsControl ItemsSource="{Binding ActiveSessions}" Margin="0,0,0,24">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border CornerRadius="20" Padding="32" Margin="0,0,0,16">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#064E3B" Offset="0"/>
                                    <GradientStop Color="#059669" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="25" ShadowDepth="8" Opacity="0.15" Color="#064E3B"/>
                            </Border.Effect>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                                        <!-- Pulse dot -->
                                        <Grid Width="16" Height="16" Margin="0,0,12,0" VerticalAlignment="Center">
                                            <Ellipse Width="16" Height="16" Fill="#40FFFFFF"/>
                                            <Ellipse Width="8" Height="8" Fill="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Grid>
                                        <TextBlock Text="LIVE SESSION" FontSize="11" FontWeight="Black" Foreground="#A7F3D0" VerticalAlignment="Center" LetterSpacing="1.5"/>
                                    </StackPanel>
                                    <TextBlock Text="{Binding ExamTitle}" FontSize="26" FontWeight="Bold" Foreground="White"/>
                                    <StackPanel Orientation="Horizontal" Margin="0,20,0,0">
                                        <StackPanel Margin="0,0,48,0">
                                            <TextBlock Text="ACCESS CODE" FontSize="10" Foreground="#A7F3D0" FontWeight="Black" LetterSpacing="1"/>
                                            <TextBlock Text="{Binding SessionCode}"
                                                       FontSize="32" FontWeight="Black" Foreground="White" FontFamily="Consolas" Margin="0,6,0,0"/>
                                        </StackPanel>
                                        <StackPanel>
                                            <TextBlock Text="CANDIDATES" FontSize="10" Foreground="#A7F3D0" FontWeight="Black" LetterSpacing="1"/>
                                            <TextBlock Text="{Binding StudentCount}"
                                                       FontSize="32" FontWeight="Black" Foreground="White" Margin="0,6,0,0"/>
                                        </StackPanel>
                                    </StackPanel>
                                    <!-- Join URL / Info -->
                                    <Border Background="#1AFFFFFF" CornerRadius="12" Padding="16,10" Margin="0,24,0,0"
                                            HorizontalAlignment="Left">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="&#xE774;" FontFamily="Segoe MDL2 Assets" Foreground="#A7F3D0"
                                                       FontSize="14" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                            <TextBlock FontFamily="Consolas" FontSize="13" Foreground="White" VerticalAlignment="Center">
                                                <Run Text="Session Room: "/><Run Text="{Binding SessionCode, Mode=OneWay}" FontWeight="Bold"/>
                                            </TextBlock>
                                            <Button Command="{Binding DataContext.CopyJoinUrlCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                    CommandParameter="{Binding}"
                                                    Style="{StaticResource PrimaryBtn}" Background="Transparent"
                                                    Padding="8" Margin="14,0,0,0" ToolTip="Copy Join Code">
                                                <TextBlock Text="&#xE8C8;" FontFamily="Segoe MDL2 Assets" FontSize="14" Foreground="White"/>
                                            </Button>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                                <!-- End session button -->
                                <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="24,0,0,0">
                                    <Button Command="{Binding DataContext.StopSessionCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                            CommandParameter="{Binding}"
                                            Style="{StaticResource PrimaryBtn}"
                                            Background="#DC2626" Padding="24,12" HorizontalAlignment="Stretch">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="&#xE71A;" FontFamily="Segoe MDL2 Assets" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                            <TextBlock Text="Terminate Session" FontWeight="Bold" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Button>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- Open room panel (start new session) -->
            <Border Style="{StaticResource Card}" Padding="32" Margin="0,0,0,24">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="Initialize New Session" FontSize="20" FontWeight="Bold"
                                   Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,8"/>
                        <TextBlock Text="Select an exam configuration to deploy a new live session room."
                                   FontSize="14" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,24"/>
                        
                        <TextBlock Text="CHOOSE EXAM TEMPLATE" FontSize="10" FontWeight="Bold" Foreground="{DynamicResource TextSecondaryBrush}" Margin="2,0,0,8" LetterSpacing="1"/>
                        <ComboBox ItemsSource="{Binding Exams}" SelectedItem="{Binding SelectedExam}"
                                  DisplayMemberPath="Title" Width="380" HorizontalAlignment="Left" Height="46"/>
                    </StackPanel>
                    <Button Grid.Column="1" Command="{Binding StartCommand}" Style="{StaticResource PrimaryBtn}"
                            Background="{DynamicResource AccentBrush}" Padding="32,14" VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE768;" FontFamily="Segoe MDL2 Assets" Margin="0,0,12,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Launch Session" FontWeight="Bold" FontSize="15" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </Grid>
            </Border>

            <!-- Session history -->
            <Border Style="{StaticResource Card}" Padding="0">
                <StackPanel>
                    <Border Background="{DynamicResource HeaderBgBrush}" CornerRadius="16,16,0,0" Padding="24,14">
                        <TextBlock Text="Session Audit Log" FontSize="14" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                    </Border>
                    
                    <Border Padding="12">
                         <DataGrid ItemsSource="{Binding Sessions}" AutoGenerateColumns="False" CanUserAddRows="False"
                                  Background="Transparent" BorderThickness="0" RowHeight="50" GridLinesVisibility="None"
                                  HeadersVisibility="Column">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="SESSION CODE" Binding="{Binding SessionCode}" Width="140">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="FontFamily" Value="Consolas"/>
                                            <Setter Property="FontWeight" Value="Bold"/>
                                            <Setter Property="VerticalAlignment" Value="Center"/>
                                            <Setter Property="Padding" Value="12,0"/>
                                            <Setter Property="Foreground" Value="{DynamicResource AccentBrush}"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                <DataGridTextColumn Header="EXAM TITLE" Binding="{Binding ExamTitle}" Width="*">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="FontWeight" Value="SemiBold"/>
                                            <Setter Property="VerticalAlignment" Value="Center"/>
                                            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                <DataGridTextColumn Header="STARTED" Binding="{Binding StartedAt, StringFormat='dd MMM yyyy HH:mm'}" Width="180">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="VerticalAlignment" Value="Center"/>
                                            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                <DataGridTextColumn Header="COUNT" Binding="{Binding StudentCount}" Width="80">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="FontWeight" Value="Bold"/>
                                            <Setter Property="VerticalAlignment" Value="Center"/>
                                            <Setter Property="HorizontalAlignment" Value="Center"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                <DataGridTemplateColumn Header="STATUS" Width="120">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Border CornerRadius="8" Padding="12,6" HorizontalAlignment="Left" VerticalAlignment="Center">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Background" Value="{DynamicResource CardBrush}"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsActive}" Value="True">
                                                                <Setter Property="Background" Value="#1016A34A"/>
                                                                <Setter Property="BorderBrush" Value="#3016A34A"/>
                                                                <Setter Property="BorderThickness" Value="1"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <TextBlock FontSize="11" FontWeight="Bold">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Text" Value="ARCHIVED"/>
                                                            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsActive}" Value="True">
                                                                    <Setter Property="Text" Value="ACTIVE"/>
                                                                    <Setter Property="Foreground" Value="#16A34A"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </Border>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Border>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
