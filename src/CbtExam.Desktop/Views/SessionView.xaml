<UserControl x:Class="CbtExam.Desktop.Views.SessionView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <!-- Dashboard View -->
        <ScrollViewer Background="{DynamicResource BgBrush}" Visibility="{Binding IsNotManagingRoom, Converter={StaticResource BoolToVis}}">
        <StackPanel Margin="32">

            <!-- Header -->
            <Grid Margin="0,0,0,32">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="Live Exam Sessions" FontSize="28" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                    <TextBlock Text="Manage active rooms and monitor candidate connectivity in real-time." FontSize="14" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,6,0,0"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Command="{Binding EndAllCommand}" Style="{StaticResource PrimaryBtn}"
                            Background="#991B1B" Foreground="White" Padding="18,10" Margin="0,0,12,0"
                            Visibility="{Binding HasActiveSessions, Converter={StaticResource BoolToVis}}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE71A;" FontFamily="Segoe MDL2 Assets" Margin="0,0,10,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Terminate All" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button Command="{Binding RefreshCommand}" Style="{StaticResource PrimaryBtn}"
                            Background="{DynamicResource CardBrush}" Foreground="{DynamicResource TextPrimaryBrush}" Padding="16,10">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE72C;" FontFamily="Segoe MDL2 Assets" Margin="0,0,10,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Refresh" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>

            <!-- Active sessions cards -->
            <ItemsControl ItemsSource="{Binding ActiveSessions}" Margin="0,0,0,24">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel Orientation="Horizontal"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border CornerRadius="16" Padding="20" Margin="0,0,12,12" Width="320">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#064E3B" Offset="0"/>
                                    <GradientStop Color="#059669" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="16" ShadowDepth="4" Opacity="0.15" Color="#064E3B"/>
                            </Border.Effect>
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <!-- Live badge + title -->
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                    <Grid Width="10" Height="10" Margin="0,0,8,0" VerticalAlignment="Center">
                                        <Ellipse Width="10" Height="10" Fill="#40FFFFFF"/>
                                        <Ellipse Width="6" Height="6" Fill="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Grid>
                                    <TextBlock Text="LIVE" FontSize="10" FontWeight="Black" Foreground="#A7F3D0" VerticalAlignment="Center"/>
                                </StackPanel>
                                <TextBlock Grid.Row="1" Text="{Binding ExamTitle}" FontSize="16" FontWeight="Bold" Foreground="White"
                                           TextTrimming="CharacterEllipsis" Margin="0,0,0,12"/>
                                <!-- Stats row -->
                                <Grid Grid.Row="2">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <Border Background="#1AFFFFFF" CornerRadius="8" Padding="10,5" Margin="0,0,8,0">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="&#xE716;" FontFamily="Segoe MDL2 Assets" Foreground="#A7F3D0" FontSize="12" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                                <TextBlock Text="{Binding StudentCount}" FontSize="13" FontWeight="Bold" Foreground="White" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </Border>
                                        <Button Command="{Binding DataContext.CopyJoinUrlCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                CommandParameter="{Binding}"
                                                Style="{StaticResource PrimaryBtn}" Background="#1AFFFFFF"
                                                Padding="10,5" ToolTip="Copy Join URL">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="&#xE8C8;" FontFamily="Segoe MDL2 Assets" FontSize="12" Foreground="White" Margin="0,0,4,0" VerticalAlignment="Center"/>
                                                <TextBlock Text="Copy URL" FontSize="11" FontWeight="SemiBold" Foreground="White" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </Button>
                                    </StackPanel>
                                    <Button Grid.Column="1"
                                            Command="{Binding DataContext.ManageRoomCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                            CommandParameter="{Binding}"
                                            Style="{StaticResource PrimaryBtn}"
                                            Background="{DynamicResource AccentBrush}" Padding="14,7">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="&#xE713;" FontFamily="Segoe MDL2 Assets" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                            <TextBlock Text="Manage" FontWeight="Bold" FontSize="12" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Button>
                                </Grid>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- Open room panel (start new session) -->
            <Border Style="{StaticResource Card}" Padding="32" Margin="0,0,0,24">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="Initialize New Session" FontSize="20" FontWeight="Bold"
                                   Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,8"/>
                        <TextBlock Text="Select an exam configuration to deploy a new live session room."
                                   FontSize="14" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,24"/>
                        
                        <TextBlock Text="CHOOSE EXAM TEMPLATE" FontSize="10" FontWeight="Bold" Foreground="{DynamicResource TextSecondaryBrush}" Margin="2,0,0,8"/>
                        <ComboBox ItemsSource="{Binding Exams}" SelectedItem="{Binding SelectedExam}"
                                  DisplayMemberPath="Title" Width="380" HorizontalAlignment="Left" Height="46"/>
                    </StackPanel>
                    <Button Grid.Column="1" Command="{Binding StartCommand}" Style="{StaticResource PrimaryBtn}"
                            Background="{DynamicResource AccentBrush}" Padding="32,14" VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE768;" FontFamily="Segoe MDL2 Assets" Margin="0,0,12,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Launch Session" FontWeight="Bold" FontSize="15" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </Grid>
            </Border>

            <!-- Session history -->
            <Border Style="{StaticResource Card}" Padding="0">
                <StackPanel>
                    <Border Background="{DynamicResource HeaderBgBrush}" CornerRadius="16,16,0,0" Padding="24,14">
                        <TextBlock Text="Session Audit Log" FontSize="14" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                    </Border>
                    
                    <Border Padding="12">
                         <DataGrid ItemsSource="{Binding Sessions}" AutoGenerateColumns="False" CanUserAddRows="False"
                                  Background="Transparent" BorderThickness="0" RowHeight="50" GridLinesVisibility="None"
                                  HeadersVisibility="Column">
                            <DataGrid.Columns>

                                <DataGridTextColumn Header="EXAM TITLE" Binding="{Binding ExamTitle}" Width="*">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="FontWeight" Value="SemiBold"/>
                                            <Setter Property="VerticalAlignment" Value="Center"/>
                                            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                <DataGridTextColumn Header="STARTED" Binding="{Binding StartedAt, StringFormat='dd MMM yyyy HH:mm'}" Width="180">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="VerticalAlignment" Value="Center"/>
                                            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                <DataGridTextColumn Header="COUNT" Binding="{Binding StudentCount}" Width="80">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="FontWeight" Value="Bold"/>
                                            <Setter Property="VerticalAlignment" Value="Center"/>
                                            <Setter Property="HorizontalAlignment" Value="Center"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                <DataGridTemplateColumn Header="STATUS" Width="120">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Border CornerRadius="8" Padding="12,6" HorizontalAlignment="Left" VerticalAlignment="Center">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Background" Value="{DynamicResource CardBrush}"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsActive}" Value="True">
                                                                <Setter Property="Background" Value="#1016A34A"/>
                                                                <Setter Property="BorderBrush" Value="#3016A34A"/>
                                                                <Setter Property="BorderThickness" Value="1"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <TextBlock FontSize="11" FontWeight="Bold">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Text" Value="ARCHIVED"/>
                                                            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsActive}" Value="True">
                                                                    <Setter Property="Text" Value="ACTIVE"/>
                                                                    <Setter Property="Foreground" Value="#16A34A"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </Border>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Border>
                </StackPanel>
            </Border>
        </StackPanel>
        </ScrollViewer>

        <!-- Manage Room View -->
        <Grid Visibility="{Binding IsManagingRoom, Converter={StaticResource BoolToVis}}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <Border Background="{DynamicResource CardBrush}" Padding="24" BorderThickness="0,0,0,1" BorderBrush="{DynamicResource BorderBrush}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Button Command="{Binding CloseRoomCommand}" Style="{StaticResource PrimaryBtn}" Background="Transparent" Padding="8" Margin="0,0,16,0">
                        <TextBlock Text="&#xE72B;" FontFamily="Segoe MDL2 Assets" FontSize="18" Foreground="{DynamicResource TextPrimaryBrush}"/>
                    </Button>
                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock Text="{Binding CurrentRoom.ExamTitle}" FontSize="24" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                        <TextBlock Text="Waiting Room Management" FontSize="14" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,4,0,0"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                        <Button Command="{Binding StopSessionCommand}" CommandParameter="{Binding CurrentRoom}" Style="{StaticResource PrimaryBtn}" Background="#DC2626" Foreground="White" Padding="16,10" Margin="0,0,12,0">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE71A;" FontFamily="Segoe MDL2 Assets" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                <TextBlock Text="Terminate" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        <Button Command="{Binding BeginExamCommand}" Background="{DynamicResource AccentBrush}" Foreground="White" Padding="24,10">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource PrimaryBtn}">
                                    <Setter Property="Visibility" Value="Visible"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding CurrentRoom.IsStarted}" Value="True">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE768;" FontFamily="Segoe MDL2 Assets" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                <TextBlock Text="START EXAM" FontWeight="Black" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        <Border BorderBrush="#3016A34A" BorderThickness="1" CornerRadius="8" Padding="16,10">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Setter Property="Background" Value="#1016A34A"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding CurrentRoom.IsStarted}" Value="True">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <TextBlock Text="EXAM IN PROGRESS" Foreground="#16A34A" FontWeight="Bold" VerticalAlignment="Center"/>
                        </Border>
                    </StackPanel>
                </Grid>
            </Border>
            
            <Border Grid.Row="1" Background="#F8FAFC" Padding="32">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    
                    <!-- 1. Statistics Cards Row -->
                    <Grid Margin="0,0,0,24">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="24"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="24"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        
                        <!-- Connected -->
                        <Border Background="White" BorderBrush="#F1F5F9" BorderThickness="1" CornerRadius="16" Padding="20">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="10" ShadowDepth="2" Opacity="0.05" Color="Black"/>
                            </Border.Effect>
                            <Grid>
                                <StackPanel>
                                    <TextBlock Text="Connected Candidates" FontSize="14" FontWeight="SemiBold" Foreground="#64748B"/>
                                    <TextBlock Text="{Binding ConnectedCandidatesCount}" FontSize="36" FontWeight="Bold" Foreground="#0D9488" Margin="0,4,0,0"/>
                                </StackPanel>
                                <Border Background="#F0FDFA" CornerRadius="12" Padding="12" HorizontalAlignment="Right" VerticalAlignment="Top">
                                    <TextBlock Text="&#xE716;" FontFamily="Segoe MDL2 Assets" FontSize="20" Foreground="#0D9488"/>
                                </Border>
                            </Grid>
                        </Border>
                        
                        <!-- System Ready -->
                        <Border Grid.Column="2" Background="White" BorderBrush="#F1F5F9" BorderThickness="1" CornerRadius="16" Padding="20">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="10" ShadowDepth="2" Opacity="0.05" Color="Black"/>
                            </Border.Effect>
                            <Grid>
                                <StackPanel>
                                    <TextBlock Text="System Ready" FontSize="14" FontWeight="SemiBold" Foreground="#64748B"/>
                                    <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                        <TextBlock Text="{Binding SystemReadyPercent}" FontSize="36" FontWeight="Bold" Foreground="#1E293B"/>
                                        <TextBlock Text="%" FontSize="24" FontWeight="Bold" Foreground="#1E293B" VerticalAlignment="Bottom" Margin="2,0,0,6"/>
                                    </StackPanel>
                                </StackPanel>
                                <Border Background="#F8FAFC" CornerRadius="12" Padding="12" HorizontalAlignment="Right" VerticalAlignment="Top">
                                    <TextBlock Text="&#xEA18;" FontFamily="Segoe MDL2 Assets" FontSize="20" Foreground="#475569"/>
                                </Border>
                            </Grid>
                        </Border>

                        <!-- Issues Flagged -->
                        <Border Grid.Column="4" Background="White" BorderBrush="#F1F5F9" BorderThickness="1" CornerRadius="16" Padding="20">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="10" ShadowDepth="2" Opacity="0.05" Color="Black"/>
                            </Border.Effect>
                            <Grid>
                                <StackPanel>
                                    <TextBlock Text="Issues Flagged" FontSize="14" FontWeight="SemiBold" Foreground="#64748B"/>
                                    <TextBlock Text="{Binding IssuesFlaggedCount}" FontSize="36" FontWeight="Bold" Foreground="#E11D48" Margin="0,4,0,0"/>
                                </StackPanel>
                                <Border Background="#FFF1F2" CornerRadius="12" Padding="12" HorizontalAlignment="Right" VerticalAlignment="Top">
                                    <TextBlock Text="&#xE783;" FontFamily="Segoe MDL2 Assets" FontSize="20" Foreground="#E11D48"/>
                                </Border>
                            </Grid>
                        </Border>
                    </Grid>

                    <!-- 2. Controls & Search Bar -->
                    <Border Grid.Row="1" Background="White" BorderBrush="#F1F5F9" BorderThickness="1" CornerRadius="16" Padding="16" Margin="0,0,0,24">
                         <Border.Effect>
                             <DropShadowEffect BlurRadius="10" ShadowDepth="2" Opacity="0.05" Color="Black"/>
                         </Border.Effect>
                         <Grid>
                             <Grid.ColumnDefinitions>
                                 <ColumnDefinition Width="300"/>
                                 <ColumnDefinition Width="*"/>
                                 <ColumnDefinition Width="Auto"/>
                             </Grid.ColumnDefinitions>
                             <Border Background="#F8FAFC" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="12" Padding="12,8">
                                 <Grid>
                                     <Grid.ColumnDefinitions>
                                         <ColumnDefinition Width="Auto"/>
                                         <ColumnDefinition Width="*"/>
                                     </Grid.ColumnDefinitions>
                                     <TextBlock Text="&#xE721;" FontFamily="Segoe MDL2 Assets" FontSize="14" Foreground="#94A3B8" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                     <TextBox Grid.Column="1" Text="{Binding SearchQuery, UpdateSourceTrigger=PropertyChanged}" Background="Transparent" BorderThickness="0" FontSize="14" Foreground="#334155" VerticalAlignment="Center"/>
                                 </Grid>
                             </Border>
                             
                             <StackPanel Grid.Column="2" Orientation="Horizontal">
                                 <!-- Auto-Approve Toggle -->
                                 <Border Background="#F8FAFC" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="12" Padding="12,8" Margin="0,0,10,0">
                                     <StackPanel Orientation="Horizontal">
                                         <TextBlock Text="Auto-Approve" FontSize="13" FontWeight="SemiBold" Foreground="#475569" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                         <CheckBox IsChecked="{Binding CurrentRoomAutoApprove}" Command="{Binding ToggleAutoApproveCommand}" VerticalAlignment="Center" ToolTip="Automatically approve students who join an ongoing exam"/>
                                     </StackPanel>
                                 </Border>
                                 <Button Command="{Binding BroadcastCommand}" Background="Transparent" BorderBrush="#E2E8F0" BorderThickness="1" Foreground="#475569" Padding="14,8" Margin="0,0,10,0">
                                     <Button.Resources>
                                         <Style TargetType="Border"><Setter Property="CornerRadius" Value="12"/></Style>
                                     </Button.Resources>
                                     <StackPanel Orientation="Horizontal">
                                         <TextBlock Text="&#xE789;" FontFamily="Segoe MDL2 Assets" FontSize="13" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                         <TextBlock Text="Broadcast" FontWeight="SemiBold"/>
                                     </StackPanel>
                                 </Button>
                                 <Button Command="{Binding SyncListCommand}" Background="Transparent" BorderBrush="#E2E8F0" BorderThickness="1" Foreground="#475569" Padding="14,8">
                                     <Button.Resources>
                                         <Style TargetType="Border"><Setter Property="CornerRadius" Value="12"/></Style>
                                     </Button.Resources>
                                     <StackPanel Orientation="Horizontal">
                                         <TextBlock Text="&#xE72C;" FontFamily="Segoe MDL2 Assets" FontSize="13" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                         <TextBlock Text="Sync List" FontWeight="SemiBold"/>
                                     </StackPanel>
                                 </Button>
                             </StackPanel>
                         </Grid>
                    </Border>
                    
                    <!-- 3. Candidate Grid -->
                    <ListBox Grid.Row="2" ItemsSource="{Binding FilteredRoomStudents}" Background="Transparent" BorderThickness="0"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListBox.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel ItemWidth="320" ItemHeight="140"/>
                            </ItemsPanelTemplate>
                        </ListBox.ItemsPanel>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Background="White" BorderBrush="#F1F5F9" BorderThickness="1" CornerRadius="16" Padding="20" Margin="8">
                                    <Border.Effect>
                                        <DropShadowEffect BlurRadius="8" ShadowDepth="1" Opacity="0.04" Color="Black"/>
                                    </Border.Effect>
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="*"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        
                                        <!-- Avatar -->
                                        <Border Grid.RowSpan="2" Width="48" Height="48" CornerRadius="24" Background="#F8FAFC" VerticalAlignment="Top" Margin="0,0,16,0">
                                            <TextBlock Text="&#xE77B;" FontFamily="Segoe MDL2 Assets" FontSize="20" Foreground="#94A3B8" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        
                                        <!-- Name & ID -->
                                        <StackPanel Grid.Column="1" VerticalAlignment="Top">
                                            <TextBlock Text="{Binding FullName}" FontWeight="Bold" FontSize="15" Foreground="#1E293B" TextTrimming="CharacterEllipsis"/>
                                            <TextBlock Text="{Binding StudentId}" FontSize="12" Foreground="#64748B" Margin="0,2,0,0"/>
                                        </StackPanel>

                                        <!-- Status Pill -->
                                        <Border Grid.Column="2" CornerRadius="12" Padding="10,4" VerticalAlignment="Top">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Background" Value="#F1F5F9"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsOnline}" Value="True">
                                                            <Setter Property="Background" Value="#F0FDFA"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <StackPanel Orientation="Horizontal">
                                                <Ellipse Width="6" Height="6" VerticalAlignment="Center" Margin="0,0,6,0">
                                                    <Ellipse.Style>
                                                        <Style TargetType="Ellipse">
                                                            <Setter Property="Fill" Value="#94A3B8"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsOnline}" Value="True">
                                                                    <Setter Property="Fill" Value="#10B981"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Ellipse.Style>
                                                </Ellipse>
                                                <TextBlock FontSize="12" FontWeight="SemiBold">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Text" Value="Disconnected"/>
                                                            <Setter Property="Foreground" Value="#64748B"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsOnline}" Value="True">
                                                                    <Setter Property="Text" Value="Ready"/>
                                                                    <Setter Property="Foreground" Value="#0F766E"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </StackPanel>
                                        </Border>
                                        
                                        <!-- Telemetry -->
                                        <Border Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="2" BorderThickness="0,1,0,0" BorderBrush="#F1F5F9" Margin="0,12,0,0" Padding="0,12,0,0">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                
                                                <StackPanel Orientation="Horizontal" Margin="0,0,16,0" ToolTip="Device Type">
                                                    <TextBlock Text="&#xE975;" FontFamily="Segoe MDL2 Assets" FontSize="12" Foreground="#94A3B8" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                                    <TextBlock Text="{Binding DeviceName}" FontSize="12" Foreground="#64748B" VerticalAlignment="Center" MaxWidth="80" TextTrimming="CharacterEllipsis"/>
                                                </StackPanel>
                                                
                                                <StackPanel Grid.Column="1" Orientation="Horizontal" ToolTip="Battery Level">
                                                    <TextBlock Text="&#xEBB8;" FontFamily="Segoe MDL2 Assets" FontSize="12" Foreground="#94A3B8" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                                    <TextBlock FontSize="12" Foreground="#64748B" VerticalAlignment="Center">
                                                        <Run Text="{Binding BatteryLevel, Mode=OneWay}"/><Run Text="%"/>
                                                    </TextBlock>
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
