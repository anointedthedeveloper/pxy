<UserControl x:Class="CbtExam.Desktop.Views.SessionView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer Background="{StaticResource BgBrush}">
        <StackPanel Margin="26">
            <Grid Margin="0,0,0,22">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="Sessions" FontSize="28" FontWeight="Bold" Foreground="#111827"/>
                    <TextBlock Text="Start, stop, and review exam sessions." FontSize="14" Foreground="#64748B" Margin="0,8,0,0"/>
                </StackPanel>
                <Button Grid.Column="1" Command="{Binding RefreshCommand}" Style="{StaticResource PrimaryBtn}"
                        Background="#059669" Padding="18,11" VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE72C;" FontFamily="Segoe MDL2 Assets" Margin="0,0,8,0"/>
                        <TextBlock Text="Refresh"/>
                    </StackPanel>
                </Button>
            </Grid>

            <Grid Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.1*"/>
                    <ColumnDefinition Width="1*"/>
                </Grid.ColumnDefinitions>
                <Border Background="White" CornerRadius="14" BorderBrush="#E5E7EB" BorderThickness="1" Padding="18" Margin="0,0,16,0">
                    <StackPanel>
                        <TextBlock Text="Start New Session" FontSize="18" FontWeight="Bold" Foreground="#111827"/>
                        <TextBlock Text="Select an exam and open it for student access." FontSize="13" Foreground="#64748B" Margin="0,6,0,16"/>
                        <TextBlock Text="Exam" FontSize="12" FontWeight="SemiBold" Foreground="#64748B" Margin="0,0,0,6"/>
                        <ComboBox ItemsSource="{Binding Exams, Mode=OneWay}" SelectedItem="{Binding SelectedExam}" DisplayMemberPath="Title" Margin="0,0,0,14"/>
                        <StackPanel Orientation="Horizontal">
                            <Button Command="{Binding StartCommand}" Style="{StaticResource PrimaryBtn}" Background="#059669" Padding="16,10" Margin="0,0,8,0">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE768;" FontFamily="Segoe MDL2 Assets" Margin="0,0,8,0"/>
                                    <TextBlock Text="Start Session"/>
                                </StackPanel>
                            </Button>
                            <Button Command="{Binding StopCommand}" Style="{StaticResource PrimaryBtn}" Background="#FEF2F2" Foreground="#DC2626" Padding="16,10">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE71A;" FontFamily="Segoe MDL2 Assets" Margin="0,0,8,0"/>
                                    <TextBlock Text="Stop Session"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <Border Grid.Column="1" Background="White" CornerRadius="14" BorderBrush="#E5E7EB" BorderThickness="1" Padding="18">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                            <Border CornerRadius="7" Background="#ECFDF5" BorderBrush="#BBF7D0" BorderThickness="1" Padding="9,4" Margin="0,0,10,0">
                                <TextBlock Text="Active Session" FontSize="12" FontWeight="Bold" Foreground="#047857"/>
                            </Border>
                        </StackPanel>
                        <TextBlock Text="{Binding ActiveSession.ExamTitle, Mode=OneWay, TargetNullValue='No active session'}"
                                   FontSize="18" FontWeight="Bold" Foreground="#111827"/>
                        <Grid Margin="0,16,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <TextBlock Text="Code" FontSize="12" Foreground="#64748B" Margin="0,0,0,10"/>
                            <TextBlock Grid.Column="1" Text="{Binding ActiveSession.SessionCode, Mode=OneWay, TargetNullValue='--'}"
                                       FontFamily="Consolas" FontWeight="Bold" Foreground="#059669" Margin="0,0,0,10"/>
                            <TextBlock Grid.Row="1" Text="Join URL" FontSize="12" Foreground="#64748B"/>
                            <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding JoinUrl, Mode=OneWay}" FontFamily="Consolas"
                                       Foreground="#2563EB" TextWrapping="Wrap"/>
                        </Grid>
                    </StackPanel>
                </Border>
            </Grid>

            <Border Background="White" CornerRadius="14" BorderBrush="#E5E7EB" BorderThickness="1" Padding="18">
                <StackPanel>
                    <TextBlock Text="Session History" FontSize="18" FontWeight="Bold" Foreground="#111827" Margin="0,0,0,14"/>
                    <DataGrid ItemsSource="{Binding Sessions, Mode=OneWay}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Code" Binding="{Binding SessionCode, Mode=OneWay}" Width="120"/>
                            <DataGridTextColumn Header="Exam" Binding="{Binding ExamTitle, Mode=OneWay}" Width="*"/>
                            <DataGridTextColumn Header="Started" Binding="{Binding StartedAt, Mode=OneWay, StringFormat='dd/MM/yyyy HH:mm'}" Width="160"/>
                            <DataGridTextColumn Header="Students" Binding="{Binding StudentCount, Mode=OneWay}" Width="100"/>
                            <DataGridTemplateColumn Header="Status" Width="110">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Border CornerRadius="6" Padding="9,4" HorizontalAlignment="Left">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Background" Value="#F3F4F6"/>
                                                    <Setter Property="BorderBrush" Value="#E5E7EB"/>
                                                    <Setter Property="BorderThickness" Value="1"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsActive, Mode=OneWay}" Value="True">
                                                            <Setter Property="Background" Value="#ECFDF5"/>
                                                            <Setter Property="BorderBrush" Value="#BBF7D0"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <TextBlock FontSize="12" FontWeight="Bold">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Text" Value="Ended"/>
                                                        <Setter Property="Foreground" Value="#64748B"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsActive, Mode=OneWay}" Value="True">
                                                                <Setter Property="Text" Value="Active"/>
                                                                <Setter Property="Foreground" Value="#047857"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </Border>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
