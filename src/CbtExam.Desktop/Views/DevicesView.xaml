<UserControl x:Class="CbtExam.Desktop.Views.DevicesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="32,28,32,28">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Margin="0,0,0,24">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel>
                <TextBlock Text="Live Devices" FontSize="28" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                <TextBlock Text="{Binding SessionInfo, Mode=OneWay}" FontSize="14"
                           Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,4,0,0"/>
            </StackPanel>
            <Button Grid.Column="1" Command="{Binding RefreshCommand}"
                    Style="{StaticResource PrimaryBtn}" Background="{DynamicResource CardBrush}"
                    Foreground="{DynamicResource TextPrimaryBrush}" Padding="16,10" VerticalAlignment="Center">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="&#xE72C;" FontFamily="Segoe MDL2 Assets" Margin="0,0,8,0" VerticalAlignment="Center"/>
                    <TextBlock Text="Refresh Nodes" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>
        </Grid>

        <!-- Stat pills -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,24">
            <Border CornerRadius="16" Background="{DynamicResource CardBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                    Padding="24,16" Margin="0,0,16,0" MinWidth="180">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="15" ShadowDepth="1" Opacity="0.03" Color="#000000"/>
                </Border.Effect>
                <StackPanel>
                    <TextBlock Text="TOTAL NODES" FontSize="10" FontWeight="Bold" Foreground="{DynamicResource TextSecondaryBrush}"/>
                    <TextBlock Text="{Binding Total, Mode=OneWay}" FontSize="32" FontWeight="Bold"
                               Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,4,0,0"/>
                </StackPanel>
            </Border>
            <Border CornerRadius="16" Background="{DynamicResource CardBrush}" BorderBrush="{DynamicResource PremiumGradient}" BorderThickness="1"
                    Padding="24,16" MinWidth="180">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="15" ShadowDepth="1" Opacity="0.08" Color="#0D9488"/>
                </Border.Effect>
                <Grid>
                    <StackPanel>
                        <TextBlock Text="ONLINE NOW" FontSize="10" FontWeight="Bold" Foreground="{DynamicResource TextSecondaryBrush}"/>
                        <TextBlock Text="{Binding Online, Mode=OneWay}" FontSize="32" FontWeight="Bold" Foreground="{DynamicResource AccentBrush}" Margin="0,4,0,0"/>
                    </StackPanel>
                    
                    <!-- Soft organic breathing green pulse dot -->
                    <Ellipse Width="10" Height="10" Fill="#10B981" HorizontalAlignment="Right" VerticalAlignment="Top">
                        <Ellipse.RenderTransform>
                            <ScaleTransform CenterX="5" CenterY="5"/>
                        </Ellipse.RenderTransform>
                        <Ellipse.Style>
                            <Style TargetType="Ellipse">
                                <Style.Triggers>
                                    <EventTrigger RoutedEvent="Loaded">
                                        <BeginStoryboard>
                                            <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                                                                 From="0.8" To="1.4" Duration="0:0:1.2"/>
                                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                                                                 From="0.8" To="1.4" Duration="0:0:1.2"/>
                                                <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                 From="0.5" To="1.0" Duration="0:0:1.2"/>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </EventTrigger>
                                </Style.Triggers>
                            </Style>
                        </Ellipse.Style>
                        <Ellipse.Effect>
                            <DropShadowEffect BlurRadius="12" Color="#10B981" Opacity="0.8" ShadowDepth="0"/>
                        </Ellipse.Effect>
                    </Ellipse>
                </Grid>
            </Border>
        </StackPanel>

        <!-- Table -->
        <Border Grid.Row="2" Style="{StaticResource Card}" Padding="0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                
                <!-- Table header -->
                <Border Background="{DynamicResource HeaderBgBrush}" CornerRadius="14,14,0,0" Padding="0,0,0,0">
                    <Grid Height="44">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1.5*"/>
                            <ColumnDefinition Width="1.5*"/>
                            <ColumnDefinition Width="1.5*"/>
                            <ColumnDefinition Width="1.2*"/>
                            <ColumnDefinition Width="1.2*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="DEVICE (ID / IP / BROWSER)" Margin="24,0,0,0" VerticalAlignment="Center" FontSize="10" FontWeight="Bold" Foreground="{DynamicResource TextSecondaryBrush}"/>
                        <TextBlock Grid.Column="1" Text="CANDIDATE (NAME / ID)" VerticalAlignment="Center" FontSize="10" FontWeight="Bold" Foreground="{DynamicResource TextSecondaryBrush}"/>
                        <TextBlock Grid.Column="2" Text="EXAM SESSION" VerticalAlignment="Center" FontSize="10" FontWeight="Bold" Foreground="{DynamicResource TextSecondaryBrush}"/>
                        <TextBlock Grid.Column="3" Text="EXAM STATUS" VerticalAlignment="Center" FontSize="10" FontWeight="Bold" Foreground="{DynamicResource TextSecondaryBrush}"/>
                        <TextBlock Grid.Column="4" Text="CONNECTION" VerticalAlignment="Center" FontSize="10" FontWeight="Bold" Foreground="{DynamicResource TextSecondaryBrush}"/>
                    </Grid>
                </Border>
                
                <Grid Grid.Row="1">
                    <!-- Virtualized List of Devices -->
                    <ListBox ItemsSource="{Binding Devices}" 
                             Visibility="{Binding HasDevices, Converter={StaticResource BoolToVis}}"
                             Background="Transparent" BorderThickness="0"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                             ScrollViewer.CanContentScroll="True"
                             VirtualizingStackPanel.IsVirtualizing="True"
                             VirtualizingStackPanel.VirtualizationMode="Recycling"
                             HorizontalContentAlignment="Stretch">
                        
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Padding" Value="0"/>
                                <Setter Property="Margin" Value="0"/>
                                <Setter Property="BorderThickness" Value="0"/>
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListBoxItem">
                                            <ContentPresenter />
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListBox.ItemContainerStyle>

                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1" Background="Transparent">
                                    <Grid Height="66">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="1.5*"/>
                                            <ColumnDefinition Width="1.5*"/>
                                            <ColumnDefinition Width="1.5*"/>
                                            <ColumnDefinition Width="1.2*"/>
                                            <ColumnDefinition Width="1.2*"/>
                                        </Grid.ColumnDefinitions>
                                        
                                        <!-- DEVICE -->
                                        <StackPanel Orientation="Horizontal" Margin="24,0,10,0" VerticalAlignment="Center">
                                            <Border Width="40" Height="40" CornerRadius="12" Background="{DynamicResource NavActiveBrush}" Margin="0,0,14,0">
                                                <TextBlock Text="&#xE7F4;" FontFamily="Segoe MDL2 Assets" FontSize="18" Foreground="{DynamicResource AccentBrush}"
                                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <StackPanel VerticalAlignment="Center" MaxWidth="160">
                                                <TextBlock Text="{Binding Name}" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" TextTrimming="CharacterEllipsis"/>
                                                <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                                    <TextBlock Text="{Binding DeviceName, TargetNullValue='CBT Node'}" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}" MaxWidth="60" TextTrimming="CharacterEllipsis"/>
                                                    <TextBlock Text=" · " FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                                    <TextBlock Text="{Binding IpAddress, TargetNullValue='unknown'}" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}" MaxWidth="80" TextTrimming="CharacterEllipsis"/>
                                                </StackPanel>
                                            </StackPanel>
                                        </StackPanel>

                                        <!-- CANDIDATE -->
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="0,0,10,0">
                                            <TextBlock Text="{Binding StudentName}" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" TextTrimming="CharacterEllipsis"/>
                                            <TextBlock Text="{Binding StudentId}" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,2,0,0" FontFamily="Consolas" TextTrimming="CharacterEllipsis"/>
                                        </StackPanel>
                                        
                                        <!-- EXAM -->
                                        <TextBlock Grid.Column="2" Text="{Binding ExamTitle}" VerticalAlignment="Center" FontSize="13" Foreground="{DynamicResource TextPrimaryBrush}" TextTrimming="CharacterEllipsis" Margin="0,0,10,0"/>
                                        
                                        <!-- EXAM STATUS -->
                                        <Grid Grid.Column="3" VerticalAlignment="Center" HorizontalAlignment="Left">
                                            <Border CornerRadius="8" Padding="10,4" BorderThickness="1">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Background" Value="#F1F5F9"/>
                                                        <Setter Property="BorderBrush" Value="#E2E8F0"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding ExamStatus}" Value="Selecting Exam">
                                                                <Setter Property="Background" Value="#E0F2FE"/>
                                                                <Setter Property="BorderBrush" Value="#BAE6FD"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding ExamStatus}" Value="Waiting Room">
                                                                <Setter Property="Background" Value="#FEF3C7"/>
                                                                <Setter Property="BorderBrush" Value="#FDE68A"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding ExamStatus}" Value="Examining">
                                                                <Setter Property="Background" Value="#DCFCE7"/>
                                                                <Setter Property="BorderBrush" Value="#BBF7D0"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding ExamStatus}" Value="Submitted">
                                                                <Setter Property="Background" Value="#F3E8FF"/>
                                                                <Setter Property="BorderBrush" Value="#E9D5FF"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                
                                                <TextBlock Text="{Binding ExamStatus}" FontSize="11" FontWeight="Bold">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Foreground" Value="#64748B"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding ExamStatus}" Value="Selecting Exam">
                                                                    <Setter Property="Foreground" Value="#0369A1"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding ExamStatus}" Value="Waiting Room">
                                                                    <Setter Property="Foreground" Value="#B45309"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding ExamStatus}" Value="Examining">
                                                                    <Setter Property="Foreground" Value="#15803D"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding ExamStatus}" Value="Submitted">
                                                                    <Setter Property="Foreground" Value="#6B21A8"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </Border>
                                        </Grid>
                                        
                                        <!-- CONNECTION STATUS -->
                                        <Border Grid.Column="4" CornerRadius="12" Padding="12,5" HorizontalAlignment="Left" VerticalAlignment="Center">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Background" Value="#FEF2F2"/>
                                                    <Setter Property="BorderBrush" Value="#FCA5A5"/>
                                                    <Setter Property="BorderThickness" Value="1"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Status}" Value="Connected">
                                                            <Setter Property="Background" Value="#E6F4EA"/>
                                                            <Setter Property="BorderBrush" Value="#A3E2D7"/>
                                                            <Setter Property="BorderThickness" Value="1"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                <Ellipse Width="6" Height="6" Margin="0,0,6,0" VerticalAlignment="Center">
                                                    <Ellipse.Style>
                                                        <Style TargetType="Ellipse">
                                                            <Setter Property="Fill" Value="#EF4444"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding Status}" Value="Connected">
                                                                    <Setter Property="Fill" Value="#137333"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Ellipse.Style>
                                                </Ellipse>
                                                <TextBlock Text="{Binding Status}" FontSize="11" FontWeight="Bold">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Foreground" Value="#EF4444"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding Status}" Value="Connected">
                                                                    <Setter Property="Foreground" Value="#137333"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </StackPanel>
                                        </Border>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                    
                    <!-- Empty State Panel -->
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Margin="48"
                                Visibility="{Binding HasDevices, Converter={StaticResource BoolToVisInverse}}">
                        <Grid HorizontalAlignment="Center" Margin="0,0,0,20">
                            <Ellipse Width="80" Height="80" Fill="#F8FAFC"/>
                            <TextBlock Text="&#xE7F4;" FontFamily="Segoe MDL2 Assets" FontSize="40" Foreground="#94A3B8" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            <TextBlock Text="&#xE701;" FontFamily="Segoe MDL2 Assets" FontSize="20" Foreground="{DynamicResource AccentBrush}" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,12,12,0">
                                <TextBlock.RenderTransform>
                                    <TranslateTransform X="5" Y="-5"/>
                                </TextBlock.RenderTransform>
                            </TextBlock>
                        </Grid>
                        <TextBlock Text="Scanning for local station nodes..." FontSize="18" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}" HorizontalAlignment="Center"/>
                        <TextBlock Text="Devices connecting to your local network server IP will automatically register here in real time." FontSize="13" Foreground="{DynamicResource TextSecondaryBrush}" HorizontalAlignment="Center" Margin="0,8,0,0" TextAlignment="Center" MaxWidth="380" TextWrapping="Wrap"/>
                    </StackPanel>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</UserControl>
