<UserControl x:Class="CbtExam.Desktop.Views.DevicesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="32,28,32,28">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Margin="0,0,0,20">
            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
            <StackPanel>
                <TextBlock Text="Devices" FontSize="22" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}"/>
                <TextBlock Text="{Binding SessionInfo, Mode=OneWay}" FontSize="13"
                           Foreground="{StaticResource TextSecondaryBrush}" Margin="0,3,0,0"/>
            </StackPanel>
            <Button Grid.Column="1" Content="↻  Refresh" Command="{Binding RefreshCommand}"
                    Style="{StaticResource PrimaryBtn}" Padding="14,8" VerticalAlignment="Center"/>
        </Grid>

        <!-- Stat pills -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,16">
            <Border CornerRadius="8" Background="White" BorderBrush="#E2E8F0" BorderThickness="1"
                    Padding="20,12" Margin="0,0,12,0">
                <StackPanel>
                    <TextBlock Text="Total Devices" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"/>
                    <TextBlock Text="{Binding Total, Mode=OneWay}" FontSize="28" FontWeight="Bold"
                               Foreground="{StaticResource TextPrimaryBrush}"/>
                </StackPanel>
            </Border>
            <Border CornerRadius="8" Background="#F0FDF4" BorderBrush="#BBF7D0" BorderThickness="1"
                    Padding="20,12">
                <StackPanel>
                    <TextBlock Text="Online" FontSize="11" Foreground="#16A34A"/>
                    <TextBlock Text="{Binding Online, Mode=OneWay}" FontSize="28" FontWeight="Bold" Foreground="#16A34A"/>
                </StackPanel>
            </Border>
        </StackPanel>

        <!-- Table -->
        <Border Grid.Row="2" Style="{StaticResource Card}">
            <DataGrid ItemsSource="{Binding Devices, Mode=OneWay}">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Student Name" Binding="{Binding Name,        Mode=OneWay}" Width="*"/>
                    <DataGridTextColumn Header="Student ID"   Binding="{Binding StudentId,   Mode=OneWay}" Width="130"/>
                    <DataGridTextColumn Header="Connected At" Binding="{Binding ConnectedAt, Mode=OneWay}" Width="110"/>
                    <DataGridTemplateColumn Header="Status" Width="110">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Border CornerRadius="5" Padding="10,4" HorizontalAlignment="Left">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Status, Mode=OneWay}" Value="Online">
                                                    <Setter Property="Background" Value="#F0FDF4"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Status, Mode=OneWay}" Value="Submitted">
                                                    <Setter Property="Background" Value="#EFF6FF"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <TextBlock Text="{Binding Status, Mode=OneWay}" FontSize="11" FontWeight="SemiBold">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Status, Mode=OneWay}" Value="Online">
                                                        <Setter Property="Foreground" Value="#16A34A"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Status, Mode=OneWay}" Value="Submitted">
                                                        <Setter Property="Foreground" Value="#2563EB"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Border>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTemplateColumn Header="Violations" Width="100">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock FontSize="12" VerticalAlignment="Center">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Violations, Mode=OneWay}" Value="0">
                                                    <Setter Property="Text"       Value="—"/>
                                                    <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                            <Setter Property="Text"       Value="{Binding Violations, Mode=OneWay, StringFormat='⚠ {0}'}"/>
                                            <Setter Property="Foreground" Value="{StaticResource DangerBrush}"/>
                                            <Setter Property="FontWeight" Value="SemiBold"/>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTextColumn Header="Battery" Binding="{Binding BatteryLevel, Mode=OneWay, StringFormat='{}{0}%'}" Width="90"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</UserControl>
