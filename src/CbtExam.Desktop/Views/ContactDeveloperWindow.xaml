<Window x:Class="CbtExam.Desktop.Views.ContactDeveloperWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Contact Developer" Height="450" Width="500"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        FontFamily="Segoe UI">

    <Window.Resources>
        <SolidColorBrush x:Key="TextMain" Color="#18181B"/>
        <SolidColorBrush x:Key="TextSub" Color="#71717A"/>
        <SolidColorBrush x:Key="FieldBg" Color="White"/>
        <SolidColorBrush x:Key="FieldBorder" Color="#E4E4E7"/>
    </Window.Resources>

    <Border Background="{DynamicResource BgBrush}" CornerRadius="20" BorderThickness="1" BorderBrush="{DynamicResource BorderBrush}">
        <Border.Effect>
            <DropShadowEffect BlurRadius="40" Color="Black" Opacity="0.15" ShadowDepth="10"/>
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Border Grid.Row="0" Background="{DynamicResource AccentBrush}" CornerRadius="20,20,0,0" Padding="32,24">
                <Grid>
                    <StackPanel>
                        <TextBlock Text="Support Center" FontSize="24" FontWeight="Black" Foreground="White"/>
                        <TextBlock Text="We're here to help you succeed." FontSize="14" Foreground="White" Opacity="0.8" Margin="0,4,0,0"/>
                    </StackPanel>
                    <Button Width="32" Height="32" Background="#33FFFFFF" BorderThickness="0" 
                            HorizontalAlignment="Right" VerticalAlignment="Top" Click="CloseButton_Click" Cursor="Hand">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" CornerRadius="16">
                                    <TextBlock Text="&#xE8BB;" FontFamily="Segoe MDL2 Assets" FontSize="12" 
                                               Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Grid>
            </Border>

            <!-- Content -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="32">
                    <TextBlock Text="Reach out to our technical team for assistance or feedback." 
                               FontSize="15" Foreground="{DynamicResource TextSecondaryBrush}" 
                               Margin="0,0,0,24" TextWrapping="Wrap"/>

                    <!-- WhatsApp 1 -->
                    <Border Style="{StaticResource Card}" Padding="20" Margin="0,0,0,16" Cursor="Hand" Background="{DynamicResource NavActiveBrush}" BorderBrush="{DynamicResource AccentBrush}" BorderThickness="1.5">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Border Width="48" Height="48" CornerRadius="14" Background="{DynamicResource AccentBrush}">
                                <TextBlock Text="&#xE8B1;" FontFamily="Segoe MDL2 Assets" FontSize="22" 
                                           Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel Grid.Column="1" Margin="16,0,0,0" VerticalAlignment="Center">
                                <TextBlock Text="Technical Support" FontSize="15" FontWeight="Bold" 
                                           Foreground="{DynamicResource AccentBrush}" Margin="0,0,0,4"/>
                                <TextBlock Text="+234 810 120 9470" FontSize="13" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextPrimaryBrush}"/>
                            </StackPanel>
                            <Button Grid.Column="2" Style="{StaticResource PrimaryBtn}" Content="Chat Now" Padding="16,8" Click="WhatsApp1_Click"/>
                        </Grid>
                    </Border>

                    <!-- WhatsApp 2 -->
                    <Border Style="{StaticResource Card}" Padding="20" Margin="0,0,0,16" Cursor="Hand">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Border Width="48" Height="48" CornerRadius="14" Background="#16A34A">
                                <TextBlock Text="&#xE8B1;" FontFamily="Segoe MDL2 Assets" FontSize="22" 
                                           Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel Grid.Column="1" Margin="16,0,0,0" VerticalAlignment="Center">
                                <TextBlock Text="Alternative Line" FontSize="15" FontWeight="Bold" 
                                           Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,4"/>
                                <TextBlock Text="+234 901 647 1351" FontSize="13" 
                                           Foreground="{DynamicResource TextSecondaryBrush}"/>
                            </StackPanel>
                            <Button Grid.Column="2" Style="{StaticResource PrimaryBtn}" Background="#16A34A" Content="Chat" Padding="16,8" Click="WhatsApp2_Click"/>
                        </Grid>
                    </Border>

                    <!-- Email -->
                    <Border Style="{StaticResource Card}" Padding="20" Margin="0,0,0,24" Cursor="Hand">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Border Width="48" Height="48" CornerRadius="14" Background="#2563EB">
                                <TextBlock Text="&#xE77B;" FontFamily="Segoe MDL2 Assets" FontSize="22" 
                                           Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel Grid.Column="1" Margin="16,0,0,0" VerticalAlignment="Center">
                                <TextBlock Text="Email Support" FontSize="15" FontWeight="Bold" 
                                           Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,4"/>
                                <TextBlock Text="anointedthedeveloper@gmail.com" FontSize="13" 
                                           Foreground="{DynamicResource TextSecondaryBrush}"/>
                            </StackPanel>
                            <Button Grid.Column="2" Style="{StaticResource PrimaryBtn}" Background="#2563EB" Content="Send" Padding="16,8" Click="Email_Click"/>
                        </Grid>
                    </Border>

                    <!-- Branding -->
                    <StackPanel HorizontalAlignment="Center" Opacity="0.5">
                        <TextBlock Text="Powered by Anobyte Technologies" 
                                   FontSize="12" FontWeight="Bold" 
                                   Foreground="{DynamicResource TextSecondaryBrush}" 
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="Excellence in Educational Technology" 
                                   FontSize="10" 
                                   Foreground="{DynamicResource TextSecondaryBrush}" 
                                   HorizontalAlignment="Center" Margin="0,2,0,0"/>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Border>
</Window>

