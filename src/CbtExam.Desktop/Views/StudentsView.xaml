<UserControl x:Class="CbtExam.Desktop.Views.StudentsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Background="{DynamicResource BgBrush}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="300"/>
        </Grid.ColumnDefinitions>

        <!-- Left: list + toolbar -->
        <Grid Margin="24,24,12,24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Grid Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="Students" FontSize="28" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                    <TextBlock Text="Manage student roster. IDs are auto-assigned." FontSize="13"
                               Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,4,0,0"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Command="{Binding RefreshCommand}" Style="{StaticResource PrimaryBtn}"
                            Background="{DynamicResource CardBrush}" Foreground="{DynamicResource TextPrimaryBrush}"
                            Padding="12,9" Margin="0,0,8,0" ToolTip="Refresh">
                        <TextBlock Text="&#xE72C;" FontFamily="Segoe MDL2 Assets"/>
                    </Button>
                    <Button Command="{Binding PrintCommand}" Style="{StaticResource PrimaryBtn}"
                            Background="{StaticResource GreenBrush}" Padding="14,9">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE749;" FontFamily="Segoe MDL2 Assets" Margin="0,0,7,0"/>
                            <TextBlock Text="Print List"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>

            <!-- Search + sort toolbar -->
            <Grid Grid.Row="1" Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Grid Height="42">
                    <TextBox Text="{Binding Search, UpdateSourceTrigger=PropertyChanged}" Padding="38,8,12,8"/>
                    <TextBlock Text="&#xE721;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               VerticalAlignment="Center" HorizontalAlignment="Left" Margin="12,0,0,0" IsHitTestVisible="False"/>
                    <TextBlock Text="Search students..." FontSize="13" Foreground="{DynamicResource TextSecondaryBrush}"
                               VerticalAlignment="Center" HorizontalAlignment="Left" Margin="38,0,0,0"
                               IsHitTestVisible="False"
                               Visibility="{Binding Search, Converter={StaticResource EmptyStringToVis}}"/>
                </Grid>
                <ComboBox Grid.Column="1" ItemsSource="{Binding SortOptions}" SelectedItem="{Binding SelectedSort}"
                          Width="180" Margin="8,0,0,0"/>
                <Border Grid.Column="2" Background="{DynamicResource CardBrush}" CornerRadius="8"
                        BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Margin="8,0,0,0" Padding="10,0">
                    <TextBlock VerticalAlignment="Center" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}">
                        <Run Text="{Binding Students.Count, Mode=OneWay}"/><Run Text=" students"/>
                    </TextBlock>
                </Border>
            </Grid>

            <!-- Student table -->
            <Border Grid.Row="2" Style="{StaticResource Card}" Padding="0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <!-- Table header -->
                    <Border Background="{DynamicResource HeaderBgBrush}" CornerRadius="14,14,0,0" Padding="0,0,0,0">
                        <Grid Height="40">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="50"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="130"/>
                                <ColumnDefinition Width="70"/>
                                <ColumnDefinition Width="60"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="#" Margin="16,0,0,0" VerticalAlignment="Center" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource TextSecondaryBrush}"/>
                            <TextBlock Grid.Column="1" Text="Full Name" Margin="12,0,0,0" VerticalAlignment="Center" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource TextSecondaryBrush}"/>
                            <TextBlock Grid.Column="2" Text="Student ID" VerticalAlignment="Center" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource TextSecondaryBrush}"/>
                            <TextBlock Grid.Column="3" Text="Active" VerticalAlignment="Center" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource TextSecondaryBrush}"/>
                            <TextBlock Grid.Column="4" Text="Edit" VerticalAlignment="Center" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource TextSecondaryBrush}"/>
                        </Grid>
                    </Border>
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding Students}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1"
                                            Background="Transparent">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Style.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="{DynamicResource RowHoverBrush}"/>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <Grid Height="46">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="50"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="130"/>
                                                <ColumnDefinition Width="70"/>
                                                <ColumnDefinition Width="60"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="{Binding Serial}" Margin="16,0,0,0" VerticalAlignment="Center"
                                                       FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                            <TextBlock Grid.Column="1" Text="{Binding FullName}" Margin="12,0,0,0"
                                                       VerticalAlignment="Center" FontSize="13" FontWeight="SemiBold"
                                                       Foreground="{DynamicResource TextPrimaryBrush}"/>
                                            <TextBlock Grid.Column="2" Text="{Binding StudentId}" VerticalAlignment="Center"
                                                       FontSize="12" FontFamily="Consolas" Foreground="{DynamicResource AccentBrush}"/>
                                            <Ellipse Grid.Column="3" Width="8" Height="8" VerticalAlignment="Center">
                                                <Ellipse.Style>
                                                    <Style TargetType="Ellipse">
                                                        <Setter Property="Fill" Value="#DC2626"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsActive}" Value="True">
                                                                <Setter Property="Fill" Value="#16A34A"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Ellipse.Style>
                                            </Ellipse>
                                            <Button Grid.Column="4" Style="{StaticResource PrimaryBtn}"
                                                    Background="Transparent" Foreground="{DynamicResource AccentBrush}"
                                                    Padding="6,4" ToolTip="Edit"
                                                    Command="{Binding DataContext.PickCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                    CommandParameter="{Binding}">
                                                <TextBlock Text="&#xE70F;" FontFamily="Segoe MDL2 Assets" FontSize="13"/>
                                            </Button>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>

        <!-- Right panel: Add/Edit + Bulk -->
        <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto" Margin="0,24,24,24">
            <StackPanel>
                <!-- Add / Edit card -->
                <Border Style="{StaticResource Card}" Margin="0,0,0,14">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                            <Border Width="30" Height="30" CornerRadius="8" Background="{DynamicResource NavActiveBrush}" Margin="0,0,10,0">
                                <TextBlock Text="&#xE716;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                                           Foreground="{DynamicResource NavActiveFgBrush}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock VerticalAlignment="Center" FontSize="15" FontWeight="Bold"
                                       Foreground="{DynamicResource TextPrimaryBrush}">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Text" Value="Add Student"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                                <Setter Property="Text" Value="Edit Student"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>

                        <TextBlock Text="Full Name *" FontSize="11" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                        <TextBox Text="{Binding FullName, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,12"/>

                        <TextBlock Text="Username (auto if blank)" FontSize="11" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                        <TextBox Text="{Binding StudentId, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,12"/>

                        <TextBlock Text="Password (auto if blank)" FontSize="11" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                        <TextBox Text="{Binding NewPassword, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,12"/>

                        <CheckBox Content="Active" IsChecked="{Binding IsActive}" Margin="0,0,0,14"/>

                        <!-- Password — only shown when editing -->
                        <StackPanel Visibility="{Binding IsEditing, Converter={StaticResource BoolToVis}}">
                            <Border Background="{DynamicResource BgBrush}" CornerRadius="8"
                                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                                    Padding="12" Margin="0,0,0,12">
                                <StackPanel>
                                    <TextBlock Text="Reset Password" FontSize="11" FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,6"/>
                                    <TextBox Text="{Binding NewPassword, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8"/>
                                    <Button Content="Set Password" Command="{Binding PasswordCommand}"
                                            Style="{StaticResource PrimaryBtn}" Background="{StaticResource GreenBrush}"
                                            Padding="12,7" HorizontalAlignment="Left"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <Button Command="{Binding SaveCommand}" Style="{StaticResource PrimaryBtn}"
                                    Background="{DynamicResource AccentBrush}" Padding="16,9" Margin="0,0,8,0">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE74E;" FontFamily="Segoe MDL2 Assets" Margin="0,0,6,0"/>
                                    <TextBlock Text="Save"/>
                                </StackPanel>
                            </Button>
                            <Button Command="{Binding DeleteCommand}" Style="{StaticResource DangerBtn}"
                                    Padding="14,9" Margin="0,0,8,0"
                                    Visibility="{Binding IsEditing, Converter={StaticResource BoolToVis}}">
                                <TextBlock Text="&#xE74D;" FontFamily="Segoe MDL2 Assets"/>
                            </Button>
                            <Button Command="{Binding ClearCommand}" Style="{StaticResource PrimaryBtn}"
                                    Background="{DynamicResource CardBrush}" Foreground="{DynamicResource TextPrimaryBrush}"
                                    Padding="14,9" Visibility="{Binding IsEditing, Converter={StaticResource BoolToVis}}">
                                <TextBlock Text="Cancel"/>
                            </Button>
                        </StackPanel>
                        <TextBlock Text="{Binding Status}" FontSize="12" TextWrapping="Wrap"
                                   Foreground="{Binding StatusOk, Converter={StaticResource BoolToColor}}"/>
                    </StackPanel>
                </Border>

                <!-- Bulk enrol card -->
                <Border Style="{StaticResource Card}">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                            <Border Width="30" Height="30" CornerRadius="8" Background="#EFF6FF" Margin="0,0,10,0">
                                <TextBlock Text="&#xE8A3;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                                           Foreground="#2563EB" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="Bulk Enrol" FontSize="15" FontWeight="Bold"
                                       Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                        </StackPanel>

                        <TextBlock FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}"
                                   Margin="0,0,0,8" TextWrapping="Wrap">
                            CSV format: <Run FontWeight="Bold" FontFamily="Consolas">Full Name,Username,Password</Run>
                            <LineBreak/>
                            • Username auto-assigned if blank (STU-0001, STU-0002…)
                            <LineBreak/>
                            • Duplicate usernames are rejected
                        </TextBlock>

                        <!-- Copyable sample -->
                        <Border Background="{DynamicResource BgBrush}" CornerRadius="6"
                                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                                Padding="10,8" Margin="0,0,0,10">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock FontFamily="Consolas" FontSize="11"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           Text="John Doe,johndoe,1234&#x0a;Jane Smith,janesmith,abcd&#x0a;Peter Okafor,,password123" TextWrapping="Wrap"/>
                                <Button Grid.Column="1" Command="{Binding CopySampleCommand}"
                                        Style="{StaticResource PrimaryBtn}" Background="Transparent"
                                        Foreground="{DynamicResource AccentBrush}" Padding="6,4"
                                        ToolTip="Copy sample format" VerticalAlignment="Top">
                                    <TextBlock Text="&#xE8C8;" FontFamily="Segoe MDL2 Assets" FontSize="12"/>
                                </Button>
                            </Grid>
                        </Border>

                        <TextBox Text="{Binding BulkCsv, UpdateSourceTrigger=PropertyChanged}"
                                 AcceptsReturn="True" Height="120" TextWrapping="Wrap"
                                 FontFamily="Consolas" FontSize="11" Margin="0,0,0,10"/>
                        <Grid Margin="0,0,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Button Command="{Binding BulkImportCommand}" Style="{StaticResource PrimaryBtn}"
                                    Background="#2563EB" Padding="14,9" HorizontalAlignment="Stretch">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE8A3;" FontFamily="Segoe MDL2 Assets" Margin="0,0,7,0"/>
                                    <TextBlock Text="Import Students"/>
                                </StackPanel>
                            </Button>
                            <Button Grid.Column="2" Command="{Binding UploadCsvCommand}" Style="{StaticResource PrimaryBtn}"
                                    Background="{DynamicResource CardBrush}" Foreground="{DynamicResource TextPrimaryBrush}"
                                    Padding="14,9" ToolTip="Upload CSV File">
                                <TextBlock Text="&#xE8B5;" FontFamily="Segoe MDL2 Assets"/>
                            </Button>
                        </Grid>
                        <TextBlock Text="{Binding BulkStatus}" FontSize="12" Margin="0,8,0,0" TextWrapping="Wrap"
                                   Foreground="{Binding BulkSuccess, Converter={StaticResource BoolToColor}}"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
