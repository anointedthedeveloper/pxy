<UserControl x:Class="CbtExam.Desktop.Views.StudentsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Background="{DynamicResource BgBrush}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="340"/>
        </Grid.ColumnDefinitions>

        <!-- Left: list + toolbar -->
        <Grid Margin="32,32,16,32">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Grid Margin="0,0,0,24">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="Student Directory" FontSize="28" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                    <TextBlock Text="Manage candidate roster and credentials. IDs are auto-assigned." FontSize="14"
                               Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,4,0,0"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Command="{Binding RefreshCommand}" Style="{StaticResource PrimaryBtn}"
                            Background="{DynamicResource CardBrush}" Foreground="{DynamicResource TextPrimaryBrush}"
                            Padding="14,10" Margin="0,0,12,0" ToolTip="Refresh List">
                        <TextBlock Text="&#xE72C;" FontFamily="Segoe MDL2 Assets"/>
                    </Button>
                    <Button Command="{Binding ForceLogoutAllCommand}" Style="{StaticResource PrimaryBtn}"
                            Background="#FEF2F2" Foreground="#DC2626" Padding="16,10" Margin="0,0,12,0"
                            ToolTip="Force all logged-in students to log out (clears session locks)">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE8FB;" FontFamily="Segoe MDL2 Assets" Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Logout All" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button Command="{Binding PrintCommand}" Style="{StaticResource PrimaryBtn}"
                            Background="{DynamicResource PremiumGradient}" Padding="20,10">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE749;" FontFamily="Segoe MDL2 Assets" Margin="0,0,10,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Export Roster" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>

            <!-- Search + sort toolbar -->
            <Grid Grid.Row="1" Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Grid Height="46">
                    <TextBox Text="{Binding Search, UpdateSourceTrigger=PropertyChanged}" Padding="42,10,14,10"
                             Style="{StaticResource {x:Type TextBox}}" BorderBrush="{DynamicResource BorderBrush}"/>
                    <TextBlock Text="&#xE721;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               VerticalAlignment="Center" HorizontalAlignment="Left" Margin="16,0,0,0" IsHitTestVisible="False"/>
                    <TextBlock Text="Search by name or student ID..." FontSize="14" Foreground="{DynamicResource TextSecondaryBrush}"
                               VerticalAlignment="Center" HorizontalAlignment="Left" Margin="42,0,0,0"
                               IsHitTestVisible="False"
                               Visibility="{Binding Search, Converter={StaticResource EmptyStringToVis}}"/>
                </Grid>
                <ComboBox Grid.Column="1" ItemsSource="{Binding SortOptions}" SelectedItem="{Binding SelectedSort}"
                          Width="200" Margin="12,0,0,0" Height="46"/>
                <Border Grid.Column="2" Background="{DynamicResource CardBrush}" CornerRadius="12"
                        BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Margin="12,0,0,0" Padding="16,0">
                    <TextBlock VerticalAlignment="Center" FontSize="13" Foreground="{DynamicResource TextSecondaryBrush}">
                        <Run Text="{Binding Students.Count, Mode=OneWay}" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                        <Run Text=" Students Found"/>
                    </TextBlock>
                </Border>
            </Grid>

            <!-- Student table -->
            <Border Grid.Row="2" Style="{StaticResource Card}" Padding="0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <!-- Table header -->
                    <Border Background="{DynamicResource HeaderBgBrush}" CornerRadius="14,14,0,0" Padding="0,0,0,0">
                        <Grid Height="44">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="50"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="130"/>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="60"/>
                                <ColumnDefinition Width="110"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="#" Margin="16,0,0,0" VerticalAlignment="Center" FontSize="10" FontWeight="Bold" Foreground="{DynamicResource TextSecondaryBrush}"/>
                            <TextBlock Grid.Column="1" Text="FULL NAME" Margin="16,0,0,0" VerticalAlignment="Center" FontSize="10" FontWeight="Bold" Foreground="{DynamicResource TextSecondaryBrush}"/>
                            <TextBlock Grid.Column="2" Text="USERNAME" VerticalAlignment="Center" FontSize="10" FontWeight="Bold" Foreground="{DynamicResource TextSecondaryBrush}"/>
                            <TextBlock Grid.Column="3" Text="PASSWORD" VerticalAlignment="Center" FontSize="10" FontWeight="Bold" Foreground="{DynamicResource TextSecondaryBrush}"/>
                            <TextBlock Grid.Column="4" Text="STATUS" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="10" FontWeight="Bold" Foreground="{DynamicResource TextSecondaryBrush}"/>
                            <TextBlock Grid.Column="5" Text="ACTIONS" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="10" FontWeight="Bold" Foreground="{DynamicResource TextSecondaryBrush}"/>
                        </Grid>
                    </Border>
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding Students}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1"
                                            Background="Transparent">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Style.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="{DynamicResource RowHoverBrush}"/>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <Grid Height="54">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="50"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="130"/>
                                                <ColumnDefinition Width="100"/>
                                                <ColumnDefinition Width="60"/>
                                                <ColumnDefinition Width="110"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="{Binding DisplayNo}" Margin="16,0,0,0" VerticalAlignment="Center"
                                                       FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                            <TextBlock Grid.Column="1" Text="{Binding FullName}" Margin="16,0,0,0"
                                                       VerticalAlignment="Center" FontSize="14" FontWeight="SemiBold"
                                                       Foreground="{DynamicResource TextPrimaryBrush}"/>
                                            <TextBlock Grid.Column="2" Text="{Binding StudentId}" VerticalAlignment="Center"
                                                       FontSize="13" FontFamily="Consolas" Foreground="{DynamicResource AccentBrush}"/>
                                            <TextBlock Grid.Column="3" Text="{Binding Password}" VerticalAlignment="Center"
                                                       FontSize="13" FontFamily="Consolas" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                            
                                            <Border Grid.Column="4" Width="10" Height="10" CornerRadius="5" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Background" Value="#DC2626"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsActive}" Value="True">
                                                                <Setter Property="Background" Value="#16A34A"/>
                                                                <Setter Property="Effect">
                                                                    <Setter.Value>
                                                                        <DropShadowEffect BlurRadius="8" Color="#16A34A" Opacity="0.5" ShadowDepth="0"/>
                                                                    </Setter.Value>
                                                                </Setter>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                            </Border>

                                            <StackPanel Grid.Column="5" Orientation="Horizontal" VerticalAlignment="Center">
                                                <Button Style="{StaticResource PrimaryBtn}"
                                                        Background="Transparent" Foreground="{DynamicResource AccentBrush}"
                                                        Padding="10,6" ToolTip="Edit Candidate"
                                                        Command="{Binding DataContext.PickCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                        CommandParameter="{Binding}">
                                                    <TextBlock Text="&#xE70F;" FontFamily="Segoe MDL2 Assets" FontSize="14"/>
                                                </Button>
                                                <Button Style="{StaticResource PrimaryBtn}"
                                                        Background="Transparent" Foreground="#DC2626"
                                                        Padding="10,6" Margin="2,0,0,0" ToolTip="Force Logout — clear this student's session lock"
                                                        Command="{Binding DataContext.ForceLogoutOneCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                        CommandParameter="{Binding}">
                                                    <TextBlock Text="&#xE8FB;" FontFamily="Segoe MDL2 Assets" FontSize="14"/>
                                                </Button>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>

        <!-- Right panel: Add/Edit + Bulk -->
        <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto" Margin="0,32,32,32">
            <StackPanel>
                <!-- Add / Edit card -->
                <Border Style="{StaticResource Card}" Margin="0,0,0,20">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                            <Border Width="36" Height="36" CornerRadius="10" Background="{DynamicResource NavActiveBrush}" Margin="0,0,14,0">
                                <TextBlock Text="&#xE716;" FontFamily="Segoe MDL2 Assets" FontSize="16"
                                           Foreground="{DynamicResource NavActiveFgBrush}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock VerticalAlignment="Center" FontSize="18" FontWeight="Bold"
                                       Foreground="{DynamicResource TextPrimaryBrush}">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Text" Value="Add Student"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                                <Setter Property="Text" Value="Edit Student"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>

                        <TextBlock Text="FULL NAME *" FontSize="10" FontWeight="Bold"
                                   Foreground="{DynamicResource TextSecondaryBrush}" Margin="2,0,0,6"/>
                        <TextBox Text="{Binding FullName, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,16" Height="42"/>

                        <TextBlock Text="STUDENT ID (AUTO IF BLANK)" FontSize="10" FontWeight="Bold"
                                   Foreground="{DynamicResource TextSecondaryBrush}" Margin="2,0,0,6"/>
                        <TextBox Text="{Binding StudentId, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,16" Height="42"/>

                        <TextBlock Text="PASSWORD (AUTO IF BLANK)" FontSize="10" FontWeight="Bold"
                                   Foreground="{DynamicResource TextSecondaryBrush}" Margin="2,0,0,6"/>
                        <TextBox Text="{Binding NewPassword, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,24" Height="42"/>

                        <!-- Password — only shown when editing -->
                        <StackPanel Visibility="{Binding IsEditing, Converter={StaticResource BoolToVis}}">
                            <Border Background="{DynamicResource BgBrush}" CornerRadius="12"
                                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                                    Padding="16" Margin="0,0,0,20">
                                <StackPanel>
                                    <TextBlock Text="SECURITY" FontSize="10" FontWeight="Bold"
                                               Foreground="{DynamicResource TextSecondaryBrush}" Margin="2,0,0,10"/>
                                    <TextBlock Text="Update Password" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,6"/>
                                    <TextBox Text="{Binding NewPassword, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,12" Height="36"/>
                                    <Button Content="Set New Password" Command="{Binding PasswordCommand}"
                                            Style="{StaticResource PrimaryBtn}" Background="{DynamicResource CardBrush}"
                                            Foreground="{DynamicResource TextPrimaryBrush}"
                                            Padding="14,8" HorizontalAlignment="Stretch"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Button Command="{Binding SaveCommand}" Style="{StaticResource PrimaryBtn}"
                                    Background="{DynamicResource AccentBrush}" Padding="20,12">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE74E;" FontFamily="Segoe MDL2 Assets" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="Commit" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <Button Grid.Column="1" Command="{Binding DeleteCommand}" Style="{StaticResource DangerBtn}"
                                    Padding="16,12" Margin="10,0,0,0"
                                    Visibility="{Binding IsEditing, Converter={StaticResource BoolToVis}}"
                                    ToolTip="Delete Candidate">
                                <TextBlock Text="&#xE74D;" FontFamily="Segoe MDL2 Assets"/>
                            </Button>
                            <Button Grid.Column="2" Command="{Binding ClearCommand}" Style="{StaticResource PrimaryBtn}"
                                    Background="{DynamicResource CardBrush}" Foreground="{DynamicResource TextPrimaryBrush}"
                                    Padding="16,12" Margin="10,0,0,0" Visibility="{Binding IsEditing, Converter={StaticResource BoolToVis}}"
                                    ToolTip="Cancel Edit">
                                <TextBlock Text="&#xE711;" FontFamily="Segoe MDL2 Assets"/>
                            </Button>
                        </Grid>
                        <TextBlock Text="{Binding Status}" FontSize="12" TextWrapping="Wrap" Margin="4,0,0,0"
                                   Foreground="{Binding StatusOk, Converter={StaticResource BoolToColor}}"/>
                    </StackPanel>
                </Border>

                <!-- Bulk enrol card -->
                <Border Style="{StaticResource Card}">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                            <Border Width="36" Height="36" CornerRadius="10" Background="#103B82F6" Margin="0,0,14,0">
                                <TextBlock Text="&#xE8A3;" FontFamily="Segoe MDL2 Assets" FontSize="16"
                                           Foreground="#3B82F6" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="Bulk Import" FontSize="18" FontWeight="Bold"
                                       Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                        </StackPanel>

                        <TextBlock FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}"
                                   Margin="2,0,0,12" TextWrapping="Wrap">
                            Use CSV format: <Run FontWeight="Bold" FontFamily="Consolas" Foreground="{DynamicResource TextPrimaryBrush}">Full Name,Username,Password</Run>
                        </TextBlock>

                        <!-- Copyable sample -->
                        <Border Background="{DynamicResource BgBrush}" CornerRadius="10"
                                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                                Padding="16,12" Margin="0,0,0,16">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock FontFamily="Consolas" FontSize="11"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           Text="John Doe,johndoe,1234&#x0a;Jane Smith,janesmith,abcd" TextWrapping="Wrap"/>
                                <Button Grid.Column="1" Command="{Binding CopySampleCommand}"
                                        Style="{StaticResource PrimaryBtn}" Background="Transparent"
                                        Foreground="{DynamicResource AccentBrush}" Padding="8,6"
                                        ToolTip="Copy Sample" VerticalAlignment="Top">
                                    <TextBlock Text="&#xE8C8;" FontFamily="Segoe MDL2 Assets" FontSize="14"/>
                                </Button>
                            </Grid>
                        </Border>

                        <TextBox Text="{Binding BulkCsv, UpdateSourceTrigger=PropertyChanged}"
                                 AcceptsReturn="True" Height="140" TextWrapping="Wrap"
                                 FontFamily="Consolas" FontSize="12" Margin="0,0,0,16"
                                 Style="{StaticResource {x:Type TextBox}}" BorderBrush="{DynamicResource BorderBrush}"/>
                        
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Button Command="{Binding BulkImportCommand}" Style="{StaticResource PrimaryBtn}"
                                    Background="#3B82F6" Padding="20,12" HorizontalAlignment="Stretch">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE8A3;" FontFamily="Segoe MDL2 Assets" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="Import Candidates" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <Button Grid.Column="1" Command="{Binding UploadCsvCommand}" Style="{StaticResource PrimaryBtn}"
                                    Background="{DynamicResource CardBrush}" Foreground="{DynamicResource TextPrimaryBrush}"
                                    Padding="18,12" Margin="10,0,0,0" ToolTip="Upload CSV File">
                                <TextBlock Text="&#xE8B5;" FontFamily="Segoe MDL2 Assets" FontSize="16"/>
                            </Button>
                        </Grid>
                        <TextBlock Text="{Binding BulkStatus}" FontSize="12" Margin="4,12,0,0" TextWrapping="Wrap"
                                   Foreground="{Binding BulkSuccess, Converter={StaticResource BoolToColor}}"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
