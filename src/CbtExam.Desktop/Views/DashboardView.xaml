<UserControl x:Class="CbtExam.Desktop.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer VerticalScrollBarVisibility="Auto" Background="{StaticResource BgBrush}">
        <StackPanel Margin="26">

            <Border Background="White" BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="10"
                    Padding="18,12" Margin="0,0,0,26">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="14" ShadowDepth="1" Opacity="0.05" Color="#111827"/>
                </Border.Effect>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Border Width="30" Height="30" CornerRadius="15" Background="#ECFDF5">
                            <TextBlock Text="&#xE83D;" FontFamily="Segoe MDL2 Assets" Foreground="#059669"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="System Health" FontSize="13" FontWeight="Bold" Foreground="#047857"
                                   Margin="12,0,10,0" VerticalAlignment="Center"/>
                        <TextBlock Text="All systems operational" FontSize="12" Foreground="#374151" VerticalAlignment="Center"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="&#xE7BA;" FontFamily="Segoe MDL2 Assets" Foreground="#F59E0B"
                                   FontSize="16" VerticalAlignment="Center" Margin="0,0,8,0"
                                   Visibility="{Binding DataContext.StartupStatus, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource NonEmptyToVis}}"/>
                        <TextBlock Text="{Binding DataContext.StartupStatus, RelativeSource={RelativeSource AncestorType=Window}, Mode=OneWay}"
                                   FontSize="12" Foreground="#92400E" FontWeight="SemiBold" Margin="0,0,22,0"
                                   VerticalAlignment="Center"
                                   Visibility="{Binding DataContext.StartupStatus, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource NonEmptyToVis}}"/>
                        <Ellipse Width="8" Height="8" Fill="{Binding DataContext.ServerRunning, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource BoolToColor}}"
                                 VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBlock Text="{Binding DataContext.ServerStatusText, RelativeSource={RelativeSource AncestorType=Window}, Mode=OneWay}"
                                   FontSize="12" FontWeight="Bold"
                                   Foreground="{Binding DataContext.ServerRunning, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource BoolToColor}}"/>
                    </StackPanel>
                </Grid>
            </Border>

            <Grid Margin="0,0,0,22">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="Dashboard" FontSize="28" FontWeight="Bold" Foreground="#111827"/>
                    <TextBlock Text="Offline exam control, live session health, and exam operations."
                               FontSize="14" Foreground="#475569" Margin="0,8,0,0"/>
                </StackPanel>
                <Button Grid.Column="1" Command="{Binding RefreshCommand}" Style="{StaticResource PrimaryBtn}"
                        Padding="18,11" Background="#0F6FEA" VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE72C;" FontFamily="Segoe MDL2 Assets" Margin="0,0,8,0"/>
                        <TextBlock Text="Refresh"/>
                    </StackPanel>
                </Button>
            </Grid>

            <StackPanel Orientation="Horizontal" Margin="0,0,0,22">
                <Border CornerRadius="9" Background="#ECFDF5" BorderBrush="#BBF7D0" BorderThickness="1" Padding="11,6" Margin="0,0,8,0">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE9F5;" FontFamily="Segoe MDL2 Assets" FontSize="12" Foreground="#047857" Margin="0,0,6,0"/>
                        <TextBlock Text="Offline Mode" FontSize="12" FontWeight="SemiBold" Foreground="#047857"/>
                    </StackPanel>
                </Border>
                <Border CornerRadius="9" Background="#EFF6FF" BorderBrush="#BFDBFE" BorderThickness="1" Padding="11,6" Margin="0,0,8,0">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE774;" FontFamily="Segoe MDL2 Assets" FontSize="12" Foreground="#2563EB" Margin="0,0,6,0"/>
                        <TextBlock Text="LAN Ready" FontSize="12" FontWeight="SemiBold" Foreground="#2563EB"/>
                    </StackPanel>
                </Border>
                <Border CornerRadius="9" Background="#FFFBEB" BorderBrush="#FDE68A" BorderThickness="1" Padding="11,6">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE8CF;" FontFamily="Segoe MDL2 Assets" FontSize="12" Foreground="#B45309" Margin="0,0,6,0"/>
                        <TextBlock Text="SQLite Local" FontSize="12" FontWeight="SemiBold" Foreground="#B45309"/>
                    </StackPanel>
                </Border>
            </StackPanel>

            <Grid Margin="0,0,0,22">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.35*"/>
                    <ColumnDefinition Width="1*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Background="#047857" CornerRadius="14" Padding="22" Margin="0,0,18,0">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="20" ShadowDepth="3" Opacity="0.13" Color="#065F46"/>
                    </Border.Effect>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="160"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,36">
                                <Border Width="40" Height="40" CornerRadius="11" Background="#26FFFFFF" Margin="0,0,12,0">
                                    <TextBlock Text="&#xE8A5;" FontFamily="Segoe MDL2 Assets" Foreground="White" FontSize="18"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock Text="{Binding ActiveSession.ExamTitle, Mode=OneWay, TargetNullValue='No active exam'}"
                                           FontSize="17" FontWeight="Bold" Foreground="White" VerticalAlignment="Center"/>
                            </StackPanel>

                            <Grid Width="360" HorizontalAlignment="Left" Margin="0,0,0,22">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="1*"/>
                                    <ColumnDefinition Width="1*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="Session code" FontSize="13" FontWeight="Bold" Foreground="#D1FAE5"/>
                                    <TextBlock Text="{Binding ActiveSession.SessionCode, Mode=OneWay, TargetNullValue='--'}"
                                               FontSize="15" Foreground="White" FontWeight="SemiBold" Margin="0,8,0,0"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="Started" FontSize="13" FontWeight="Bold" Foreground="#D1FAE5"/>
                                    <TextBlock Text="{Binding ActiveSession.StartedAt, Mode=OneWay, StringFormat='HH:mm', TargetNullValue='--'}"
                                               FontSize="15" Foreground="White" FontWeight="SemiBold" Margin="0,8,0,0"/>
                                </StackPanel>
                            </Grid>

                            <Border Height="1" Background="#55FFFFFF" Width="360" HorizontalAlignment="Left" Margin="0,0,0,14"/>
                            <TextBlock Text="{Binding SubmittedPercent, Mode=OneWay, StringFormat='{}{0}% submitted'}"
                                       Foreground="White" FontSize="13" FontWeight="Bold" Margin="0,0,0,8"/>
                            <Grid Width="360" HorizontalAlignment="Left">
                                <Border Height="8" CornerRadius="4" Background="#40FFFFFF"/>
                                <Border Height="8" CornerRadius="4" Background="#CFFAEA" HorizontalAlignment="Left"
                                        Width="{Binding SubmittedPercent, Mode=OneWay, Converter={StaticResource PctToWidth}, ConverterParameter=360}"/>
                            </Grid>
                        </StackPanel>

                        <Grid Grid.Column="1" Width="150" Height="150" VerticalAlignment="Center">
                            <Ellipse Stroke="#5EEAD4" StrokeThickness="12" Opacity="0.55"/>
                            <Ellipse Stroke="#D1FAE5" StrokeThickness="12"/>
                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                <TextBlock Text="{Binding ActiveCount, Mode=OneWay}" FontSize="36" FontWeight="Bold"
                                           Foreground="White" HorizontalAlignment="Center"/>
                                <TextBlock Text="active now" FontSize="14" Foreground="White" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Grid>
                    </Grid>
                </Border>

                <UniformGrid Grid.Column="1" Columns="2" Rows="2">
                    <Border Background="White" CornerRadius="14" Padding="18" BorderBrush="#E5E7EB" BorderThickness="1" Margin="0,0,18,18">
                        <StackPanel>
                            <Border Width="42" Height="42" CornerRadius="12" Background="#F3F4F6" HorizontalAlignment="Left">
                                <TextBlock Text="&#xE716;" FontFamily="Segoe MDL2 Assets" Foreground="#64748B" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="Total Students" FontSize="13" Foreground="#334155" Margin="0,12,0,2"/>
                            <TextBlock Text="{Binding TotalStudents, Mode=OneWay}" FontSize="32" FontWeight="Bold" Foreground="#111827"/>
                        </StackPanel>
                    </Border>
                    <Border Background="White" CornerRadius="14" Padding="18" BorderBrush="#E5E7EB" BorderThickness="1" Margin="0,0,0,18">
                        <StackPanel>
                            <Border Width="42" Height="42" CornerRadius="12" Background="#ECFDF5" HorizontalAlignment="Left">
                                <TextBlock Text="&#xE9D9;" FontFamily="Segoe MDL2 Assets" Foreground="#059669" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="Active" FontSize="13" Foreground="#334155" Margin="0,12,0,2"/>
                            <TextBlock Text="{Binding ActiveCount, Mode=OneWay}" FontSize="32" FontWeight="Bold" Foreground="#111827"/>
                        </StackPanel>
                    </Border>
                    <Border Background="White" CornerRadius="14" Padding="18" BorderBrush="#E5E7EB" BorderThickness="1" Margin="0,0,18,0">
                        <StackPanel>
                            <Border Width="42" Height="42" CornerRadius="12" Background="#EFF6FF" HorizontalAlignment="Left">
                                <TextBlock Text="&#xE724;" FontFamily="Segoe MDL2 Assets" Foreground="#2563EB" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="Submitted" FontSize="13" Foreground="#334155" Margin="0,12,0,2"/>
                            <TextBlock Text="{Binding SubmittedCount, Mode=OneWay}" FontSize="32" FontWeight="Bold" Foreground="#111827"/>
                        </StackPanel>
                    </Border>
                    <Border Background="White" CornerRadius="14" Padding="18" BorderBrush="#E5E7EB" BorderThickness="1">
                        <StackPanel>
                            <Border Width="42" Height="42" CornerRadius="12" Background="#FFFBEB" HorizontalAlignment="Left">
                                <TextBlock Text="&#xE769;" FontFamily="Segoe MDL2 Assets" Foreground="#D97706" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="Paused" FontSize="13" Foreground="#334155" Margin="0,12,0,2"/>
                            <TextBlock Text="{Binding PausedCount, Mode=OneWay}" FontSize="32" FontWeight="Bold" Foreground="#111827"/>
                        </StackPanel>
                    </Border>
                </UniformGrid>
            </Grid>

            <Border Background="White" CornerRadius="14" BorderBrush="#E5E7EB" BorderThickness="1" Padding="18">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="18" ShadowDepth="2" Opacity="0.06" Color="#111827"/>
                </Border.Effect>
                <StackPanel>
                    <StackPanel Margin="0,0,0,18">
                        <TextBlock Text="Exams" FontSize="20" FontWeight="Bold" Foreground="#111827"/>
                        <TextBlock Text="Search, filter, create, and maintain offline exam records."
                                   FontSize="13" Foreground="#475569" Margin="0,6,0,0"/>
                    </StackPanel>

                    <Grid Margin="0,0,0,18">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="190"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Grid Height="44" Margin="0,0,12,0">
                            <TextBox Text="{Binding ExamSearch, UpdateSourceTrigger=PropertyChanged}" Padding="40,8,12,8"/>
                            <TextBlock Text="&#xE721;" FontFamily="Segoe MDL2 Assets" FontSize="15" Foreground="#64748B"
                                       VerticalAlignment="Center" HorizontalAlignment="Left" Margin="14,0,0,0"/>
                            <TextBlock Text="Search exams..." FontSize="13" Foreground="#64748B"
                                       VerticalAlignment="Center" HorizontalAlignment="Left" Margin="40,0,0,0"
                                       IsHitTestVisible="False"
                                       Visibility="{Binding ExamSearch, Mode=OneWay, Converter={StaticResource EmptyStringToVis}}"/>
                        </Grid>
                        <ComboBox Grid.Column="1" ItemsSource="{Binding SubjectFilters, Mode=OneWay}"
                                  SelectedItem="{Binding SelectedSubject, Mode=TwoWay}" Margin="0,0,12,0"/>
                        <Button Grid.Column="2" Command="{Binding ToggleFormCommand}" Style="{StaticResource PrimaryBtn}"
                                Background="#0F6FEA" Padding="16,10" Margin="0,0,8,0">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="+" FontSize="18" Margin="0,0,8,0"/>
                                <TextBlock Text="Create Exam"/>
                            </StackPanel>
                        </Button>
                        <Button Grid.Column="3" Command="{Binding RefreshCommand}" Style="{StaticResource PrimaryBtn}"
                                Background="#F8FAFC" Foreground="#111827" Padding="13,10" Margin="0,0,8,0" ToolTip="Refresh">
                            <TextBlock Text="&#xE72C;" FontFamily="Segoe MDL2 Assets"/>
                        </Button>
                        <Button Grid.Column="4" Style="{StaticResource PrimaryBtn}" Background="#F8FAFC" Foreground="#111827"
                                Padding="13,10" ToolTip="Filter">
                            <TextBlock Text="&#xE71C;" FontFamily="Segoe MDL2 Assets"/>
                        </Button>
                    </Grid>

                    <Border Visibility="{Binding ShowCreateForm, Converter={StaticResource BoolToVis}}"
                            Background="#F8FAFC" CornerRadius="12" BorderBrush="#E5E7EB" BorderThickness="1"
                            Padding="16" Margin="0,0,0,16">
                        <StackPanel>
                            <TextBlock Text="New Exam" FontSize="14" FontWeight="Bold" Foreground="#111827" Margin="0,0,0,12"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="120"/>
                                </Grid.ColumnDefinitions>
                                <TextBox Grid.Column="0" Text="{Binding Title, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,10,0"/>
                                <TextBox Grid.Column="1" Text="{Binding Subject, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,10,0"/>
                                <TextBox Grid.Column="2" Text="{Binding Duration, UpdateSourceTrigger=PropertyChanged}"/>
                            </Grid>
                            <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                                <CheckBox Content="Shuffle Questions" IsChecked="{Binding ShuffleQuestions}" Margin="0,0,20,0"/>
                                <CheckBox Content="Shuffle Options" IsChecked="{Binding ShuffleOptions}"/>
                                <Button Content="Save Exam" Command="{Binding CreateExamCommand}" Style="{StaticResource PrimaryBtn}"
                                        Background="#0F6FEA" Padding="16,8" Margin="24,0,8,0"/>
                                <Button Content="Cancel" Command="{Binding ToggleFormCommand}" Style="{StaticResource PrimaryBtn}"
                                        Background="#E5E7EB" Foreground="#111827" Padding="16,8"/>
                                <TextBlock Text="{Binding CreateStatus, Mode=OneWay}" Foreground="{StaticResource DangerBrush}"
                                           VerticalAlignment="Center" Margin="12,0,0,0"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <Grid Background="#F8FAFC" Height="40">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*"/>
                            <ColumnDefinition Width="1.1*"/>
                            <ColumnDefinition Width="1*"/>
                            <ColumnDefinition Width="1*"/>
                            <ColumnDefinition Width=".8*"/>
                            <ColumnDefinition Width=".8*"/>
                            <ColumnDefinition Width=".9*"/>
                            <ColumnDefinition Width=".8*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Exam Title" Margin="16,0,0,0" VerticalAlignment="Center" FontSize="12" FontWeight="Bold" Foreground="#111827"/>
                        <TextBlock Grid.Column="1" Text="Subject" VerticalAlignment="Center" FontSize="12" FontWeight="Bold" Foreground="#111827"/>
                        <TextBlock Grid.Column="2" Text="Total Students" VerticalAlignment="Center" FontSize="12" FontWeight="Bold" Foreground="#111827"/>
                        <TextBlock Grid.Column="3" Text="Submitted (%)" VerticalAlignment="Center" FontSize="12" FontWeight="Bold" Foreground="#111827"/>
                        <TextBlock Grid.Column="4" Text="Active" VerticalAlignment="Center" FontSize="12" FontWeight="Bold" Foreground="#111827"/>
                        <TextBlock Grid.Column="5" Text="Paused" VerticalAlignment="Center" FontSize="12" FontWeight="Bold" Foreground="#111827"/>
                        <TextBlock Grid.Column="6" Text="Status" VerticalAlignment="Center" FontSize="12" FontWeight="Bold" Foreground="#111827"/>
                        <TextBlock Grid.Column="7" Text="Actions" VerticalAlignment="Center" FontSize="12" FontWeight="Bold" Foreground="#111827"/>
                    </Grid>

                    <Border BorderBrush="#E5E7EB" BorderThickness="0,1,0,0"
                            Visibility="{Binding FilteredExams.Count, Mode=OneWay, Converter={StaticResource ZeroToVis}}">
                        <StackPanel HorizontalAlignment="Center" Margin="0,38">
                            <Border Width="58" Height="58" CornerRadius="29" Background="#ECFDF5" Margin="0,0,0,12">
                                <TextBlock Text="+" FontSize="30" Foreground="#047857" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="No exams match this view." FontSize="14" FontWeight="Bold" Foreground="#111827" HorizontalAlignment="Center"/>
                            <TextBlock Text="Create a new exam or clear the search and subject filter."
                                       FontSize="12" Foreground="#64748B" Margin="0,6,0,0"/>
                        </StackPanel>
                    </Border>

                    <ItemsControl ItemsSource="{Binding FilteredExams, Mode=OneWay}"
                                  Visibility="{Binding FilteredExams.Count, Mode=OneWay, Converter={StaticResource IntToVis}}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Height="44">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="2*"/>
                                        <ColumnDefinition Width="1.1*"/>
                                        <ColumnDefinition Width="1*"/>
                                        <ColumnDefinition Width="1*"/>
                                        <ColumnDefinition Width=".8*"/>
                                        <ColumnDefinition Width=".8*"/>
                                        <ColumnDefinition Width=".9*"/>
                                        <ColumnDefinition Width=".8*"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.ColumnSpan="8" BorderBrush="#E5E7EB" BorderThickness="0,0,0,1"/>
                                    <TextBlock Text="{Binding Title, Mode=OneWay}" Margin="16,0,0,0" VerticalAlignment="Center" FontSize="13" FontWeight="SemiBold" Foreground="#111827"/>
                                    <TextBlock Grid.Column="1" Text="{Binding Subject, Mode=OneWay}" VerticalAlignment="Center" FontSize="13" Foreground="#334155"/>
                                    <TextBlock Grid.Column="2" Text="0" VerticalAlignment="Center" FontSize="13" Foreground="#334155"/>
                                    <TextBlock Grid.Column="3" Text="0 (0%)" VerticalAlignment="Center" FontSize="13" Foreground="#334155"/>
                                    <TextBlock Grid.Column="4" Text="0" VerticalAlignment="Center" FontSize="13" Foreground="#334155"/>
                                    <TextBlock Grid.Column="5" Text="0" VerticalAlignment="Center" FontSize="13" Foreground="#334155"/>
                                    <Border Grid.Column="6" CornerRadius="6" Background="#ECFDF5" BorderBrush="#BBF7D0" BorderThickness="1"
                                            Padding="9,4" HorizontalAlignment="Left" VerticalAlignment="Center">
                                        <TextBlock Text="Ready" FontSize="12" FontWeight="Bold" Foreground="#047857"/>
                                    </Border>
                                    <StackPanel Grid.Column="7" Orientation="Horizontal" VerticalAlignment="Center">
                                        <Button Style="{StaticResource PrimaryBtn}" Background="#EFF6FF" Foreground="#0F6FEA"
                                                Padding="8,5" Margin="0,0,5,0" ToolTip="View">
                                            <TextBlock Text="&#xE8A5;" FontFamily="Segoe MDL2 Assets"/>
                                        </Button>
                                        <Button Style="{StaticResource PrimaryBtn}" Background="#EFF6FF" Foreground="#0F6FEA"
                                                Padding="8,5" Margin="0,0,5,0" ToolTip="Edit">
                                            <TextBlock Text="&#xE70F;" FontFamily="Segoe MDL2 Assets"/>
                                        </Button>
                                        <Button Style="{StaticResource PrimaryBtn}" Background="#FEF2F2" Foreground="#DC2626"
                                                Padding="8,5" ToolTip="Delete"
                                                Command="{Binding DataContext.DeleteExamCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                CommandParameter="{Binding}">
                                            <TextBlock Text="&#xE74D;" FontFamily="Segoe MDL2 Assets"/>
                                        </Button>
                                    </StackPanel>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
