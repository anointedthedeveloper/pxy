<UserControl x:Class="CbtExam.Desktop.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer VerticalScrollBarVisibility="Auto" Background="{DynamicResource BgBrush}">
        <StackPanel Margin="32,24,32,32">

            <!-- ── System Health Bar ── -->
            <Border Style="{StaticResource Card}" Padding="20,12" Margin="0,0,0,24">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <!-- Animated pulse dot -->
                        <Grid Width="20" Height="20" Margin="0,0,12,0">
                            <Ellipse x:Name="PulseDot" Width="20" Height="20" Fill="{DynamicResource AccentBrush}" Opacity="0.2"/>
                            <Ellipse Width="10" Height="10" Fill="{DynamicResource AccentBrush}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            <Grid.Triggers>
                                <EventTrigger RoutedEvent="Loaded">
                                    <BeginStoryboard>
                                        <Storyboard RepeatBehavior="Forever">
                                            <DoubleAnimation Storyboard.TargetName="PulseDot" Storyboard.TargetProperty="Opacity" From="0.4" To="0" Duration="0:0:1.5"/>
                                            <DoubleAnimation Storyboard.TargetName="PulseDot" Storyboard.TargetProperty="Width" From="10" To="28" Duration="0:0:1.5"/>
                                            <DoubleAnimation Storyboard.TargetName="PulseDot" Storyboard.TargetProperty="Height" From="10" To="28" Duration="0:0:1.5"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </EventTrigger>
                            </Grid.Triggers>
                        </Grid>
                        <TextBlock Text="System Health" FontSize="14" FontWeight="Bold" Foreground="{DynamicResource AccentBrush}"
                                   Margin="0,0,12,0" VerticalAlignment="Center"/>
                        <TextBlock Text="All systems operational and secure" FontSize="13" Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                        <Border Background="{DynamicResource NavActiveBrush}" CornerRadius="12" Padding="12,6" Margin="0,0,12,0">
                            <StackPanel Orientation="Horizontal">
                                <Ellipse Width="8" Height="8" VerticalAlignment="Center" Margin="0,0,8,0"
                                         Fill="{Binding DataContext.ServerRunning, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource BoolToColor}}"/>
                                <TextBlock Text="{Binding DataContext.ServerStatusText, RelativeSource={RelativeSource AncestorType=Window}, Mode=OneWay}"
                                           FontSize="12" FontWeight="Bold" VerticalAlignment="Center"
                                           Foreground="{DynamicResource AccentBrush}"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ── Page Header ── -->
            <Grid Margin="0,0,0,28">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="Admin Dashboard" FontSize="34" FontWeight="Black"
                               Foreground="{DynamicResource TextPrimaryBrush}"/>
                    <TextBlock Text="Monitor exam sessions, student progress, and system performance in real-time."
                               FontSize="14" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,6,0,0"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Command="{Binding RefreshCommand}" Style="{StaticResource PrimaryBtn}"
                            Background="{DynamicResource AccentBrush}" Padding="20,11">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="&#xE72C;" FontFamily="Segoe MDL2 Assets" FontSize="14" Margin="0,0,10,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Refresh Dashboard" FontSize="14" FontWeight="Bold" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>

            <!-- ── Main Row: Session Card + Stats ── -->
            <Grid Margin="0,0,0,24">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.5*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Gradient session card -->
                <Border Grid.Column="0" CornerRadius="20" Margin="0,0,20,0" Padding="32">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#064E3B" Offset="0"/>
                            <GradientStop Color="#059669" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="30" ShadowDepth="10" Opacity="0.2" Color="#064E3B"/>
                    </Border.Effect>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,32">
                                <Border Width="48" Height="48" CornerRadius="14" Background="#33FFFFFF" Margin="0,0,16,0">
                                    <TextBlock Text="&#xE916;" FontFamily="Segoe MDL2 Assets" Foreground="White"
                                               FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="{Binding ActiveSession.ExamTitle, Mode=OneWay, TargetNullValue='No active exam'}"
                                               FontSize="20" FontWeight="Bold" Foreground="White"/>
                                    <TextBlock Text="CURRENT ACTIVE SESSION" FontSize="11" FontWeight="Black" Foreground="#A7F3D0" Margin="0,2,0,0" Opacity="0.8"/>
                                </StackPanel>
                            </StackPanel>

                            <Grid HorizontalAlignment="Left" Margin="0,0,0,24">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="60"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="SESSION CODE" FontSize="11" FontWeight="Black" Foreground="#A7F3D0" Opacity="0.7"/>
                                    <TextBlock Text="{Binding ActiveSession.SessionCode, Mode=OneWay, TargetNullValue='------'}"
                                               FontSize="26" Foreground="White" FontWeight="Black" FontFamily="Consolas" Margin="0,4,0,0"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="STARTED AT" FontSize="11" FontWeight="Black" Foreground="#A7F3D0" Opacity="0.7"/>
                                    <TextBlock Text="{Binding ActiveSession.StartedAt, Mode=OneWay, StringFormat='HH:mm', TargetNullValue='--:--'}"
                                               FontSize="26" Foreground="White" FontWeight="Black" Margin="0,4,0,0"/>
                                </StackPanel>
                            </Grid>

                            <Border Height="1" Width="380" HorizontalAlignment="Left" Background="White" Opacity="0.1" Margin="0,0,0,20"/>

                            <StackPanel Width="380" HorizontalAlignment="Left">
                                <Grid Margin="0,0,0,10">
                                    <TextBlock Text="SUBMISSION PROGRESS" FontSize="11" FontWeight="Black" Foreground="#A7F3D0" Opacity="0.7"/>
                                    <TextBlock Text="{Binding SubmittedPercent, Mode=OneWay, StringFormat='{}{0}%'}"
                                               Foreground="White" FontSize="13" FontWeight="Bold" HorizontalAlignment="Right"/>
                                </Grid>
                                <Grid>
                                    <Border Height="10" CornerRadius="5" Background="#22FFFFFF"/>
                                    <Border Height="10" CornerRadius="5" Background="#D1FAE5" HorizontalAlignment="Left"
                                            Width="{Binding SubmittedPercent, Mode=OneWay, Converter={StaticResource PctToWidth}, ConverterParameter=380}">
                                        <Border.Effect>
                                            <DropShadowEffect BlurRadius="10" Color="White" Opacity="0.3" ShadowDepth="0"/>
                                        </Border.Effect>
                                    </Border>
                                </Grid>
                            </StackPanel>
                        </StackPanel>

                        <!-- Donut ring -->
                        <Grid Grid.Column="1" Width="160" Height="160" VerticalAlignment="Center" Margin="20,0,0,0">
                            <Ellipse Stroke="#22FFFFFF" StrokeThickness="16"/>
                            <Ellipse Stroke="#D1FAE5" StrokeThickness="16" StrokeDashArray="3,1"/>
                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                <TextBlock Text="{Binding ActiveCount, Mode=OneWay}" FontSize="48" FontWeight="Black"
                                           Foreground="White" HorizontalAlignment="Center"/>
                                <TextBlock Text="ACTIVE" FontSize="12" Foreground="#A7F3D0"
                                           FontWeight="Black" HorizontalAlignment="Center" Margin="0,-4,0,0"/>
                            </StackPanel>
                        </Grid>
                    </Grid>
                </Border>

                <!-- 4 stat cards with hover lift and entrance animation -->
                <UniformGrid Grid.Column="1" Columns="2" Rows="2">
                    <Border x:Name="Card1" Style="{StaticResource Card}" Padding="20" Margin="0,0,12,12" Opacity="0">
                        <Border.RenderTransform><TranslateTransform Y="20"/></Border.RenderTransform>
                        <StackPanel>
                            <Border Width="44" Height="44" CornerRadius="12" Background="#F1F5F9" HorizontalAlignment="Left">
                                <TextBlock Text="&#xE716;" FontFamily="Segoe MDL2 Assets" Foreground="#64748B"
                                           FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="Total Students" FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,12,0,4"/>
                            <TextBlock Text="{Binding TotalStudents, Mode=OneWay}" FontSize="36" FontWeight="Black"
                                       Foreground="{DynamicResource TextPrimaryBrush}"/>
                        </StackPanel>
                    </Border>
                    <Border x:Name="Card2" Style="{StaticResource Card}" Padding="20" Margin="0,0,0,12" Opacity="0">
                        <Border.RenderTransform><TranslateTransform Y="20"/></Border.RenderTransform>
                        <StackPanel>
                            <Border Width="44" Height="44" CornerRadius="12" Background="{DynamicResource NavActiveBrush}" HorizontalAlignment="Left">
                                <TextBlock Text="&#xE9D9;" FontFamily="Segoe MDL2 Assets" Foreground="{DynamicResource AccentBrush}"
                                           FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="Active Now" FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,12,0,4"/>
                            <TextBlock Text="{Binding ActiveCount, Mode=OneWay}" FontSize="36" FontWeight="Black"
                                       Foreground="{DynamicResource TextPrimaryBrush}"/>
                        </StackPanel>
                    </Border>
                    <Border x:Name="Card3" Style="{StaticResource Card}" Padding="20" Margin="0,0,12,0" Opacity="0">
                        <Border.RenderTransform><TranslateTransform Y="20"/></Border.RenderTransform>
                        <StackPanel>
                            <Border Width="44" Height="44" CornerRadius="12" Background="#EFF6FF" HorizontalAlignment="Left">
                                <TextBlock Text="&#xE724;" FontFamily="Segoe MDL2 Assets" Foreground="#2563EB"
                                           FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="Submitted" FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,12,0,4"/>
                            <TextBlock Text="{Binding SubmittedCount, Mode=OneWay}" FontSize="36" FontWeight="Black"
                                       Foreground="{DynamicResource TextPrimaryBrush}"/>
                        </StackPanel>
                    </Border>
                    <Border x:Name="Card4" Style="{StaticResource Card}" Padding="20" Margin="0,0,0,0" Opacity="0">
                        <Border.RenderTransform><TranslateTransform Y="20"/></Border.RenderTransform>
                        <StackPanel>
                            <Border Width="44" Height="44" CornerRadius="12" Background="#FFFBEB" HorizontalAlignment="Left">
                                <TextBlock Text="&#xE769;" FontFamily="Segoe MDL2 Assets" Foreground="#D97706"
                                           FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="Paused" FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,12,0,4"/>
                            <TextBlock Text="{Binding PausedCount, Mode=OneWay}" FontSize="36" FontWeight="Black"
                                       Foreground="{DynamicResource TextPrimaryBrush}"/>
                        </StackPanel>
                    </Border>
                    
                    <UniformGrid.Triggers>
                        <EventTrigger RoutedEvent="Loaded">
                            <BeginStoryboard>
                                <Storyboard>
                                    <DoubleAnimation Storyboard.TargetName="Card1" Storyboard.TargetProperty="Opacity" To="1" Duration="0:0:0.4"><DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction></DoubleAnimation>
                                    <DoubleAnimation Storyboard.TargetName="Card1" Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)" To="0" Duration="0:0:0.4"><DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction></DoubleAnimation>
                                    <DoubleAnimation Storyboard.TargetName="Card2" Storyboard.TargetProperty="Opacity" To="1" Duration="0:0:0.4" BeginTime="0:0:0.1"><DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction></DoubleAnimation>
                                    <DoubleAnimation Storyboard.TargetName="Card2" Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)" To="0" Duration="0:0:0.4" BeginTime="0:0:0.1"><DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction></DoubleAnimation>
                                    <DoubleAnimation Storyboard.TargetName="Card3" Storyboard.TargetProperty="Opacity" To="1" Duration="0:0:0.4" BeginTime="0:0:0.2"><DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction></DoubleAnimation>
                                    <DoubleAnimation Storyboard.TargetName="Card3" Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)" To="0" Duration="0:0:0.4" BeginTime="0:0:0.2"><DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction></DoubleAnimation>
                                    <DoubleAnimation Storyboard.TargetName="Card4" Storyboard.TargetProperty="Opacity" To="1" Duration="0:0:0.4" BeginTime="0:0:0.3"><DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction></DoubleAnimation>
                                    <DoubleAnimation Storyboard.TargetName="Card4" Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)" To="0" Duration="0:0:0.4" BeginTime="0:0:0.3"><DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction></DoubleAnimation>
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                    </UniformGrid.Triggers>
                </UniformGrid>
            </Grid>

            <!-- ── Empty state when no session ── -->
            <Border Style="{StaticResource Card}" Padding="64"
                    Visibility="{Binding NoActiveSession, Converter={StaticResource BoolToVis}}">
                <StackPanel HorizontalAlignment="Center">
                    <Grid Width="100" Height="100" Margin="0,0,0,32">
                        <Ellipse Fill="{DynamicResource NavActiveBrush}"/>
                        <TextBlock Text="&#xE8F9;" FontFamily="Segoe MDL2 Assets" FontSize="42"
                                   Foreground="{DynamicResource AccentBrush}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Grid>
                    <TextBlock Text="No Active Exam Session" FontSize="24" FontWeight="Black"
                               Foreground="{DynamicResource TextPrimaryBrush}" HorizontalAlignment="Center"/>
                    <TextBlock Text="Start an exam session to begin monitoring students and receiving submissions."
                               FontSize="15" Foreground="{DynamicResource TextSecondaryBrush}" HorizontalAlignment="Center" Margin="0,12,0,40"
                               TextAlignment="Center" MaxWidth="400"/>
                    <Button Content="Go to Sessions"
                            Style="{StaticResource PrimaryBtn}"
                            Padding="32,14" HorizontalAlignment="Center"
                            Command="{Binding DataContext.NavigateCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                            CommandParameter="Sessions"/>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>

</UserControl>
