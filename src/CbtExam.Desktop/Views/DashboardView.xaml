<UserControl x:Class="CbtExam.Desktop.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer VerticalScrollBarVisibility="Auto" Background="{DynamicResource BgBrush}">
        <StackPanel Margin="28,24,28,28">

            <!-- ── System Health Bar ── -->
            <Border CornerRadius="10" Padding="16,11" Margin="0,0,0,22"
                    Background="{DynamicResource CardBrush}" BorderBrush="#E5E7EB" BorderThickness="1">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="12" ShadowDepth="1" Opacity="0.05" Color="#111827"/>
                </Border.Effect>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <!-- Animated pulse dot -->
                        <Grid Width="18" Height="18" Margin="0,0,10,0">
                            <Ellipse x:Name="PulseDot" Width="18" Height="18" Fill="#DCFCE7" Opacity="0.6"/>
                            <Ellipse Width="10" Height="10" Fill="#16A34A" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            <Grid.Triggers>
                                <EventTrigger RoutedEvent="Loaded">
                                    <BeginStoryboard>
                                        <Storyboard RepeatBehavior="Forever">
                                            <DoubleAnimation Storyboard.TargetName="PulseDot" Storyboard.TargetProperty="Opacity" From="0.6" To="0" Duration="0:0:1.5" AutoReverse="False"/>
                                            <DoubleAnimation Storyboard.TargetName="PulseDot" Storyboard.TargetProperty="Width" From="10" To="24" Duration="0:0:1.5" AutoReverse="False"/>
                                            <DoubleAnimation Storyboard.TargetName="PulseDot" Storyboard.TargetProperty="Height" From="10" To="24" Duration="0:0:1.5" AutoReverse="False"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </EventTrigger>
                            </Grid.Triggers>
                        </Grid>
                        <TextBlock Text="System Health" FontSize="13" FontWeight="Bold" Foreground="#047857"
                                   Margin="0,0,10,0" VerticalAlignment="Center"/>
                        <TextBlock Text="All systems operational" FontSize="12" Foreground="#374151" VerticalAlignment="Center"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="&#xE7BA;" FontFamily="Segoe MDL2 Assets" Foreground="#F59E0B"
                                   FontSize="15" VerticalAlignment="Center" Margin="0,0,7,0"
                                   Visibility="{Binding DataContext.StartupStatus, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource NonEmptyToVis}}"/>
                        <TextBlock Text="{Binding DataContext.StartupStatus, RelativeSource={RelativeSource AncestorType=Window}, Mode=OneWay}"
                                   FontSize="12" Foreground="#92400E" FontWeight="SemiBold" Margin="0,0,18,0"
                                   VerticalAlignment="Center"
                                   Visibility="{Binding DataContext.StartupStatus, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource NonEmptyToVis}}"/>
                        <Ellipse Width="8" Height="8" VerticalAlignment="Center" Margin="0,0,7,0"
                                 Fill="{Binding DataContext.ServerRunning, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource BoolToColor}}"/>
                        <TextBlock Text="{Binding DataContext.ServerStatusText, RelativeSource={RelativeSource AncestorType=Window}, Mode=OneWay}"
                                   FontSize="12" FontWeight="Bold" VerticalAlignment="Center"
                                   Foreground="{Binding DataContext.ServerRunning, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource BoolToColor}}"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ── Page Header ── -->
            <Grid Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="Dashboard" FontSize="30" FontWeight="Bold"
                               Foreground="{DynamicResource TextPrimaryBrush}"/>
                    <TextBlock Text="Live exam control, session health, and real-time student monitoring."
                               FontSize="13" Foreground="#64748B" Margin="0,6,0,0"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Bottom" Margin="0,0,0,4">
                    <Border CornerRadius="8" Background="#ECFDF5" BorderBrush="#BBF7D0" BorderThickness="1"
                            Padding="12,8" Margin="0,0,8,0">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="&#xE9F5;" FontFamily="Segoe MDL2 Assets" FontSize="13" Foreground="#047857" Margin="0,0,6,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Offline Mode" FontSize="13" FontWeight="SemiBold" Foreground="#047857" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                    <Border CornerRadius="8" Background="#EFF6FF" BorderBrush="#BFDBFE" BorderThickness="1"
                            Padding="12,8" Margin="0,0,8,0">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="&#xE774;" FontFamily="Segoe MDL2 Assets" FontSize="13" Foreground="#2563EB" Margin="0,0,6,0" VerticalAlignment="Center"/>
                            <TextBlock Text="LAN Ready" FontSize="13" FontWeight="SemiBold" Foreground="#2563EB" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                    <Button Command="{Binding RefreshCommand}" Style="{StaticResource PrimaryBtn}"
                            Background="#0F6FEA" Padding="16,9">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="&#xE72C;" FontFamily="Segoe MDL2 Assets" FontSize="13" Margin="0,0,6,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Refresh" FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>

            <!-- ── Main Row: Session Card + Stats ── -->
            <Grid Margin="0,0,0,22">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.4*"/>
                    <ColumnDefinition Width="1*"/>
                </Grid.ColumnDefinitions>

                <!-- Gradient session card -->
                <Border Grid.Column="0" CornerRadius="16" Margin="0,0,18,0" Padding="24">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#065F46" Offset="0"/>
                            <GradientStop Color="#047857" Offset="0.5"/>
                            <GradientStop Color="#059669" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="24" ShadowDepth="4" Opacity="0.18" Color="#065F46"/>
                    </Border.Effect>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="150"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,28">
                                <Border Width="42" Height="42" CornerRadius="12" Background="#26FFFFFF" Margin="0,0,12,0">
                                    <TextBlock Text="&#xE916;" FontFamily="Segoe MDL2 Assets" Foreground="White"
                                               FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="{Binding ActiveSession.ExamTitle, Mode=OneWay, TargetNullValue='No active exam'}"
                                               FontSize="17" FontWeight="Bold" Foreground="White"/>
                                    <TextBlock Text="Active Session" FontSize="11" Foreground="#A7F3D0" Margin="0,2,0,0"/>
                                </StackPanel>
                            </StackPanel>

                            <Grid Width="340" HorizontalAlignment="Left" Margin="0,0,0,20">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="Session Code" FontSize="11" FontWeight="Bold" Foreground="#A7F3D0"/>
                                    <TextBlock Text="{Binding ActiveSession.SessionCode, Mode=OneWay, TargetNullValue='--'}"
                                               FontSize="22" Foreground="White" FontWeight="Bold" FontFamily="Consolas" Margin="0,4,0,0"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="Started At" FontSize="11" FontWeight="Bold" Foreground="#A7F3D0"/>
                                    <TextBlock Text="{Binding ActiveSession.StartedAt, Mode=OneWay, StringFormat='HH:mm', TargetNullValue='--'}"
                                               FontSize="22" Foreground="White" FontWeight="Bold" Margin="0,4,0,0"/>
                                </StackPanel>
                            </Grid>

                            <!-- Curved divider substitute: thin gradient line -->
                            <Border Height="1" Width="340" HorizontalAlignment="Left" Margin="0,0,0,14">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                        <GradientStop Color="#80FFFFFF" Offset="0"/>
                                        <GradientStop Color="#00FFFFFF" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                            </Border>

                            <TextBlock Text="{Binding SubmittedPercent, Mode=OneWay, StringFormat='{}{0}% submitted'}"
                                       Foreground="White" FontSize="12" FontWeight="Bold" Margin="0,0,0,7"/>
                            <Grid Width="340" HorizontalAlignment="Left">
                                <Border Height="8" CornerRadius="4" Background="#33FFFFFF"/>
                                <Border Height="8" CornerRadius="4" Background="#CFFAEA" HorizontalAlignment="Left"
                                        Width="{Binding SubmittedPercent, Mode=OneWay, Converter={StaticResource PctToWidth}, ConverterParameter=340}"/>
                            </Grid>
                        </StackPanel>

                        <!-- Donut ring -->
                        <Grid Grid.Column="1" Width="140" Height="140" VerticalAlignment="Center" HorizontalAlignment="Center">
                            <Ellipse Stroke="#33FFFFFF" StrokeThickness="14"/>
                            <Ellipse Stroke="#D1FAE5" StrokeThickness="14"/>
                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                <TextBlock Text="{Binding ActiveCount, Mode=OneWay}" FontSize="38" FontWeight="Bold"
                                           Foreground="White" HorizontalAlignment="Center"/>
                                <TextBlock Text="active" FontSize="12" Foreground="#A7F3D0"
                                           FontWeight="SemiBold" HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Grid>
                    </Grid>
                </Border>

                <!-- 4 stat cards with hover lift and entrance animation -->
                <UniformGrid Grid.Column="1" Columns="2" Rows="2">
                    <Border x:Name="Card1" CornerRadius="14" Padding="18" BorderBrush="#E5E7EB" BorderThickness="1" Margin="0,0,10,10"
                            Background="{DynamicResource CardBrush}" Opacity="0">
                        <Border.RenderTransform>
                            <TranslateTransform Y="20"/>
                        </Border.RenderTransform>
                        <Border.Style>
                            <Style TargetType="Border">
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Effect">
                                            <Setter.Value>
                                                <DropShadowEffect BlurRadius="18" ShadowDepth="3" Opacity="0.12" Color="#059669"/>
                                            </Setter.Value>
                                        </Setter>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <StackPanel>
                            <Border Width="40" Height="40" CornerRadius="10" Background="#F1F5F9" HorizontalAlignment="Left">
                                <TextBlock Text="&#xE716;" FontFamily="Segoe MDL2 Assets" Foreground="#64748B"
                                           FontSize="17" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="Total Students" FontSize="12" Foreground="#64748B" Margin="0,10,0,2"/>
                            <TextBlock Text="{Binding TotalStudents, Mode=OneWay}" FontSize="34" FontWeight="Bold"
                                       Foreground="{DynamicResource TextPrimaryBrush}"/>
                        </StackPanel>
                    </Border>
                    <Border x:Name="Card2" CornerRadius="14" Padding="18" BorderBrush="#E5E7EB" BorderThickness="1" Margin="0,0,0,10"
                            Background="{DynamicResource CardBrush}" Opacity="0">
                        <Border.RenderTransform>
                            <TranslateTransform Y="20"/>
                        </Border.RenderTransform>
                        <Border.Style>
                            <Style TargetType="Border">
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Effect">
                                            <Setter.Value>
                                                <DropShadowEffect BlurRadius="18" ShadowDepth="3" Opacity="0.12" Color="#059669"/>
                                            </Setter.Value>
                                        </Setter>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <StackPanel>
                            <Border Width="40" Height="40" CornerRadius="10" Background="#F0FDF4" HorizontalAlignment="Left">
                                <TextBlock Text="&#xE9D9;" FontFamily="Segoe MDL2 Assets" Foreground="#059669"
                                           FontSize="17" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="Active" FontSize="12" Foreground="#64748B" Margin="0,10,0,2"/>
                            <TextBlock Text="{Binding ActiveCount, Mode=OneWay}" FontSize="34" FontWeight="Bold"
                                       Foreground="{DynamicResource TextPrimaryBrush}"/>
                        </StackPanel>
                    </Border>
                    <Border x:Name="Card3" CornerRadius="14" Padding="18" BorderBrush="#E5E7EB" BorderThickness="1" Margin="0,0,10,0"
                            Background="{DynamicResource CardBrush}" Opacity="0">
                        <Border.RenderTransform>
                            <TranslateTransform Y="20"/>
                        </Border.RenderTransform>
                        <Border.Style>
                            <Style TargetType="Border">
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Effect">
                                            <Setter.Value>
                                                <DropShadowEffect BlurRadius="18" ShadowDepth="3" Opacity="0.12" Color="#2563EB"/>
                                            </Setter.Value>
                                        </Setter>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <StackPanel>
                            <Border Width="40" Height="40" CornerRadius="10" Background="#EFF6FF" HorizontalAlignment="Left">
                                <TextBlock Text="&#xE724;" FontFamily="Segoe MDL2 Assets" Foreground="#2563EB"
                                           FontSize="17" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="Submitted" FontSize="12" Foreground="#64748B" Margin="0,10,0,2"/>
                            <TextBlock Text="{Binding SubmittedCount, Mode=OneWay}" FontSize="34" FontWeight="Bold"
                                       Foreground="{DynamicResource TextPrimaryBrush}"/>
                        </StackPanel>
                    </Border>
                    <Border x:Name="Card4" CornerRadius="14" Padding="18" BorderBrush="#E5E7EB" BorderThickness="1"
                            Background="{DynamicResource CardBrush}" Opacity="0">
                        <Border.RenderTransform>
                            <TranslateTransform Y="20"/>
                        </Border.RenderTransform>
                        <Border.Style>
                            <Style TargetType="Border">
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Effect">
                                            <Setter.Value>
                                                <DropShadowEffect BlurRadius="18" ShadowDepth="3" Opacity="0.12" Color="#D97706"/>
                                            </Setter.Value>
                                        </Setter>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <StackPanel>
                            <Border Width="40" Height="40" CornerRadius="10" Background="#FFFBEB" HorizontalAlignment="Left">
                                <TextBlock Text="&#xE769;" FontFamily="Segoe MDL2 Assets" Foreground="#D97706"
                                           FontSize="17" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="Paused" FontSize="12" Foreground="#64748B" Margin="0,10,0,2"/>
                            <TextBlock Text="{Binding PausedCount, Mode=OneWay}" FontSize="34" FontWeight="Bold"
                                       Foreground="{DynamicResource TextPrimaryBrush}"/>
                        </StackPanel>
                    </Border>
                    
                    <UniformGrid.Triggers>
                        <EventTrigger RoutedEvent="Loaded">
                            <BeginStoryboard>
                                <Storyboard>
                                    <DoubleAnimation Storyboard.TargetName="Card1" Storyboard.TargetProperty="Opacity" To="1" Duration="0:0:0.4">
                                        <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                                    </DoubleAnimation>
                                    <DoubleAnimation Storyboard.TargetName="Card1" Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)" To="0" Duration="0:0:0.4">
                                        <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                                    </DoubleAnimation>

                                    <DoubleAnimation Storyboard.TargetName="Card2" Storyboard.TargetProperty="Opacity" To="1" Duration="0:0:0.4" BeginTime="0:0:0.1">
                                        <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                                    </DoubleAnimation>
                                    <DoubleAnimation Storyboard.TargetName="Card2" Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)" To="0" Duration="0:0:0.4" BeginTime="0:0:0.1">
                                        <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                                    </DoubleAnimation>

                                    <DoubleAnimation Storyboard.TargetName="Card3" Storyboard.TargetProperty="Opacity" To="1" Duration="0:0:0.4" BeginTime="0:0:0.2">
                                        <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                                    </DoubleAnimation>
                                    <DoubleAnimation Storyboard.TargetName="Card3" Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)" To="0" Duration="0:0:0.4" BeginTime="0:0:0.2">
                                        <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                                    </DoubleAnimation>

                                    <DoubleAnimation Storyboard.TargetName="Card4" Storyboard.TargetProperty="Opacity" To="1" Duration="0:0:0.4" BeginTime="0:0:0.3">
                                        <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                                    </DoubleAnimation>
                                    <DoubleAnimation Storyboard.TargetName="Card4" Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)" To="0" Duration="0:0:0.4" BeginTime="0:0:0.3">
                                        <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                                    </DoubleAnimation>
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                    </UniformGrid.Triggers>
                </UniformGrid>
            </Grid>

            <!-- ── Empty state when no session ── -->
            <Border CornerRadius="14" BorderBrush="#E5E7EB" BorderThickness="1" Padding="40"
                    Background="{DynamicResource CardBrush}"
                    Visibility="{Binding NoActiveSession, Converter={StaticResource BoolToVis}}">
                <StackPanel HorizontalAlignment="Center">
                    <Border Width="64" Height="64" CornerRadius="32" HorizontalAlignment="Center" Margin="0,0,0,14">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#DCFCE7" Offset="0"/>
                                <GradientStop Color="#A7F3D0" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <TextBlock Text="&#xE787;" FontFamily="Segoe MDL2 Assets" FontSize="26"
                                   Foreground="#047857" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Text="No Active Session" FontSize="18" FontWeight="Bold"
                               Foreground="{DynamicResource TextPrimaryBrush}" HorizontalAlignment="Center"/>
                    <TextBlock Text="Go to Sessions to start an exam room, then students can join via the URL."
                               FontSize="13" Foreground="#64748B" HorizontalAlignment="Center" Margin="0,8,0,20"
                               TextAlignment="Center"/>
                    <Button Content="&#xE787;  Go to Sessions"
                            Style="{StaticResource PrimaryBtn}" Background="#047857"
                            Padding="20,10" HorizontalAlignment="Center"
                            Command="{Binding DataContext.NavigateCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                            CommandParameter="Sessions"/>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>
