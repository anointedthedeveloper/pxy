<UserControl x:Class="CbtExam.Desktop.Views.ReportsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer Background="{StaticResource BgBrush}">
        <StackPanel Margin="26">
            <Grid Margin="0,0,0,22">
                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="Reports" FontSize="28" FontWeight="Bold" Foreground="#111827"/>
                    <TextBlock Text="Generate and review system-wide exam reports." FontSize="14" Foreground="#64748B" Margin="0,8,0,0"/>
                </StackPanel>
                <Button Grid.Column="1" Command="{Binding RefreshCommand}" Style="{StaticResource PrimaryBtn}" Background="#059669" Padding="18,11">
                    <StackPanel Orientation="Horizontal"><TextBlock Text="&#xE72C;" FontFamily="Segoe MDL2 Assets" Margin="0,0,8,0"/><TextBlock Text="Refresh"/></StackPanel>
                </Button>
            </Grid>

            <UniformGrid Columns="3" Margin="0,0,0,20">
                <Border Background="White" CornerRadius="14" BorderBrush="#E5E7EB" BorderThickness="1" Padding="18" Margin="0,0,12,0">
                    <StackPanel><TextBlock Text="Total Exams" Foreground="#64748B"/><TextBlock Text="{Binding TotalExams, Mode=OneWay}" FontSize="32" FontWeight="Bold" Foreground="#111827"/></StackPanel>
                </Border>
                <Border Background="White" CornerRadius="14" BorderBrush="#E5E7EB" BorderThickness="1" Padding="18" Margin="0,0,12,0">
                    <StackPanel><TextBlock Text="Total Sessions" Foreground="#64748B"/><TextBlock Text="{Binding TotalSessions, Mode=OneWay}" FontSize="32" FontWeight="Bold" Foreground="#059669"/></StackPanel>
                </Border>
                <Border Background="White" CornerRadius="14" BorderBrush="#E5E7EB" BorderThickness="1" Padding="18">
                    <StackPanel><TextBlock Text="Students Tested" Foreground="#64748B"/><TextBlock Text="{Binding TotalStudents, Mode=OneWay}" FontSize="32" FontWeight="Bold" Foreground="#2563EB"/></StackPanel>
                </Border>
            </UniformGrid>

            <UniformGrid Columns="3" Margin="0,0,0,20">
                <Border Background="White" CornerRadius="14" BorderBrush="#E5E7EB" BorderThickness="1" Padding="18" Margin="0,0,12,12">
                    <StackPanel><TextBlock Text="&#xE9D9;" FontFamily="Segoe MDL2 Assets" Foreground="#059669" FontSize="22"/><TextBlock Text="Exam Summary" FontWeight="Bold" Margin="0,12,0,4"/><TextBlock Text="Overview of all exams" Foreground="#64748B" FontSize="12"/><Button Content="Generate" Style="{StaticResource PrimaryBtn}" Background="#ECFDF5" Foreground="#047857" Padding="12,7" HorizontalAlignment="Left" Margin="0,14,0,0"/></StackPanel>
                </Border>
                <Border Background="White" CornerRadius="14" BorderBrush="#E5E7EB" BorderThickness="1" Padding="18" Margin="0,0,12,12">
                    <StackPanel><TextBlock Text="&#xE9D2;" FontFamily="Segoe MDL2 Assets" Foreground="#2563EB" FontSize="22"/><TextBlock Text="Student Performance" FontWeight="Bold" Margin="0,12,0,4"/><TextBlock Text="Analyze student results" Foreground="#64748B" FontSize="12"/><Button Content="Generate" Style="{StaticResource PrimaryBtn}" Background="#EFF6FF" Foreground="#2563EB" Padding="12,7" HorizontalAlignment="Left" Margin="0,14,0,0"/></StackPanel>
                </Border>
                <Border Background="White" CornerRadius="14" BorderBrush="#E5E7EB" BorderThickness="1" Padding="18" Margin="0,0,0,12">
                    <StackPanel><TextBlock Text="&#xE787;" FontFamily="Segoe MDL2 Assets" Foreground="#D97706" FontSize="22"/><TextBlock Text="Session Activity" FontWeight="Bold" Margin="0,12,0,4"/><TextBlock Text="Session activity report" Foreground="#64748B" FontSize="12"/><Button Content="Generate" Style="{StaticResource PrimaryBtn}" Background="#FFFBEB" Foreground="#B45309" Padding="12,7" HorizontalAlignment="Left" Margin="0,14,0,0"/></StackPanel>
                </Border>
            </UniformGrid>

            <Border Background="White" CornerRadius="14" BorderBrush="#E5E7EB" BorderThickness="1" Padding="18">
                <StackPanel>
                    <TextBlock Text="Session Breakdown" FontSize="18" FontWeight="Bold" Foreground="#111827" Margin="0,0,0,14"/>
                    <Border Background="#F8FAFC" CornerRadius="10" BorderBrush="#E5E7EB" BorderThickness="1" Padding="28"
                            Visibility="{Binding Rows.Count, Mode=OneWay, Converter={StaticResource ZeroToVis}}">
                        <TextBlock Text="No completed sessions with results yet." Foreground="#64748B" HorizontalAlignment="Center"/>
                    </Border>
                    <DataGrid ItemsSource="{Binding Rows, Mode=OneWay}" Visibility="{Binding Rows.Count, Mode=OneWay, Converter={StaticResource IntToVis}}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Exam" Binding="{Binding ExamTitle, Mode=OneWay}" Width="*"/>
                            <DataGridTextColumn Header="Session" Binding="{Binding SessionCode, Mode=OneWay}" Width="120"/>
                            <DataGridTextColumn Header="Date" Binding="{Binding Date, Mode=OneWay}" Width="160"/>
                            <DataGridTextColumn Header="Students" Binding="{Binding Students, Mode=OneWay}" Width="100"/>
                            <DataGridTextColumn Header="Average" Binding="{Binding AvgPct, Mode=OneWay, StringFormat='{}{0:F1}%'}" Width="100"/>
                            <DataGridTextColumn Header="Passed" Binding="{Binding Passed, Mode=OneWay}" Width="90"/>
                            <DataGridTextColumn Header="Failed" Binding="{Binding Failed, Mode=OneWay}" Width="90"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
