<UserControl x:Class="CbtExam.Desktop.Views.ReportsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Background="{DynamicResource BgBrush}" Margin="32">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Top Panel: Headers, selectors, reports grid -->
        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <!-- Header -->
            <Grid Margin="0,0,0,24">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="Analytics &amp; Reports" FontSize="28" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                    <TextBlock Text="Review system-wide performance metrics and generate detailed exam audits." FontSize="14" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,6,0,0"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Command="{Binding RefreshCommand}" Style="{StaticResource PrimaryBtn}" 
                            Background="{DynamicResource CardBrush}" Foreground="{DynamicResource TextPrimaryBrush}" Padding="16,10" Margin="0,0,12,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE72C;" FontFamily="Segoe MDL2 Assets" Margin="0,0,10,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Refresh" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button Command="{Binding PrintCommand}" Style="{StaticResource PrimaryBtn}" 
                            Background="{DynamicResource PremiumGradient}" Padding="20,10">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE749;" FontFamily="Segoe MDL2 Assets" Margin="0,0,10,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Export Data" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>

            <!-- Stat Row -->
            <UniformGrid Columns="3" Margin="0,0,0,24">
                <Border Style="{StaticResource Card}" Padding="24" Margin="0,0,16,0">
                    <StackPanel>
                        <TextBlock Text="TOTAL EXAMS" FontSize="10" FontWeight="Bold" Foreground="{DynamicResource TextSecondaryBrush}"/>
                        <TextBlock Text="{Binding TotalExams, Mode=OneWay}" FontSize="36" FontWeight="Black" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,8,0,0"/>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource Card}" Padding="24" Margin="0,0,16,0">
                    <StackPanel>
                        <TextBlock Text="TOTAL SESSIONS" FontSize="10" FontWeight="Bold" Foreground="{DynamicResource TextSecondaryBrush}"/>
                        <TextBlock Text="{Binding TotalSessions, Mode=OneWay}" FontSize="36" FontWeight="Black" Foreground="#16A34A" Margin="0,8,0,0"/>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource Card}" Padding="24">
                    <StackPanel>
                        <TextBlock Text="CANDIDATES TESTED" FontSize="10" FontWeight="Bold" Foreground="{DynamicResource TextSecondaryBrush}"/>
                        <TextBlock Text="{Binding TotalStudents, Mode=OneWay}" FontSize="36" FontWeight="Black" Foreground="{DynamicResource AccentBrush}" Margin="0,8,0,0"/>
                    </StackPanel>
                </Border>
            </UniformGrid>

            <!-- Report Types -->
            <UniformGrid Columns="3">
                <Border Style="{StaticResource Card}" Padding="24" Margin="0,0,16,0">
                    <StackPanel>
                        <Border Width="48" Height="48" CornerRadius="12" Background="#1016A34A" HorizontalAlignment="Left">
                            <TextBlock Text="&#xE9D9;" FontFamily="Segoe MDL2 Assets" Foreground="#16A34A" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="Exam Summary" FontSize="16" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,16,0,6"/>
                        <TextBlock Text="Complete overview of all exam templates and configurations." Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12" TextWrapping="Wrap"/>
                        <Button Content="Generate Report" Command="{Binding PrintExamSummaryCommand}" Style="{StaticResource PrimaryBtn}" Background="{DynamicResource CardBrush}" Foreground="{DynamicResource TextPrimaryBrush}" Padding="16,8" HorizontalAlignment="Left" Margin="0,20,0,0"/>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource Card}" Padding="24" Margin="0,0,16,0">
                    <StackPanel>
                        <Border Width="48" Height="48" CornerRadius="12" Background="#103B82F6" HorizontalAlignment="Left">
                            <TextBlock Text="&#xE9D2;" FontFamily="Segoe MDL2 Assets" Foreground="#3B82F6" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="Student Analysis" FontSize="16" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,16,0,6"/>
                        <TextBlock Text="Detailed performance metrics and competency analysis per student." Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12" TextWrapping="Wrap"/>
                        <Button Content="Generate Report" Command="{Binding PrintStudentAnalysisCommand}" Style="{StaticResource PrimaryBtn}" Background="{DynamicResource CardBrush}" Foreground="{DynamicResource TextPrimaryBrush}" Padding="16,8" HorizontalAlignment="Left" Margin="0,20,0,0"/>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource Card}" Padding="24">
                    <StackPanel>
                        <Border Width="48" Height="48" CornerRadius="12" Background="#10F59E0B" HorizontalAlignment="Left">
                            <TextBlock Text="&#xE787;" FontFamily="Segoe MDL2 Assets" Foreground="#F59E0B" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="Session Activity" FontSize="16" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,16,0,6"/>
                        <TextBlock Text="Audit log of session times, proctor actions, and connectivity events." Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12" TextWrapping="Wrap"/>
                        <Button Content="Generate Report" Command="{Binding PrintSessionActivityCommand}" Style="{StaticResource PrimaryBtn}" Background="{DynamicResource CardBrush}" Foreground="{DynamicResource TextPrimaryBrush}" Padding="16,8" HorizontalAlignment="Left" Margin="0,20,0,0"/>
                    </StackPanel>
                </Border>
            </UniformGrid>
        </StackPanel>

        <!-- Bottom Panel: Scrollable Completed Session Audit -->
        <Border Grid.Row="1" Style="{StaticResource Card}" Padding="0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Background="{DynamicResource HeaderBgBrush}" CornerRadius="16,16,0,0" Padding="24,14">
                    <TextBlock Text="Completed Session Audit" FontSize="14" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                </Border>
                
                <Border Grid.Row="1" Padding="12">
                    <Grid>
                        <Border Background="{DynamicResource BgBrush}" CornerRadius="12" Padding="48"
                                Visibility="{Binding Rows.Count, Mode=OneWay, Converter={StaticResource ZeroToVis}}">
                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                <TextBlock Text="&#xE8F9;" FontFamily="Segoe MDL2 Assets" FontSize="32" Foreground="{DynamicResource TextSecondaryBrush}" HorizontalAlignment="Center" Margin="0,0,0,16"/>
                                <TextBlock Text="No analytical data available yet" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="14" FontWeight="SemiBold"/>
                            </StackPanel>
                        </Border>
                        
                        <DataGrid ItemsSource="{Binding Rows, Mode=OneWay}" 
                                  Visibility="{Binding Rows.Count, Mode=OneWay, Converter={StaticResource IntToVis}}"
                                  Background="Transparent" BorderThickness="0" RowHeight="50" GridLinesVisibility="None"
                                  HeadersVisibility="Column" VerticalScrollBarVisibility="Auto">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="EXAM TITLE" Binding="{Binding ExamTitle, Mode=OneWay}" Width="*">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="FontWeight" Value="SemiBold"/>
                                            <Setter Property="VerticalAlignment" Value="Center"/>
                                            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
                                            <Setter Property="Padding" Value="12,0"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                <DataGridTextColumn Header="SESSION" Binding="{Binding SessionCode, Mode=OneWay}" Width="120">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="FontFamily" Value="Consolas"/>
                                            <Setter Property="VerticalAlignment" Value="Center"/>
                                            <Setter Property="Foreground" Value="{DynamicResource AccentBrush}"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                <DataGridTextColumn Header="DATE" Binding="{Binding Date, Mode=OneWay}" Width="160">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="VerticalAlignment" Value="Center"/>
                                            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                <DataGridTextColumn Header="STUDENTS" Binding="{Binding Students, Mode=OneWay}" Width="100">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="FontWeight" Value="Bold"/>
                                            <Setter Property="VerticalAlignment" Value="Center"/>
                                            <Setter Property="HorizontalAlignment" Value="Center"/>
                                            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                <DataGridTextColumn Header="AVG %" Binding="{Binding AvgPct, Mode=OneWay, StringFormat='{}{0:F1}%'}" Width="100">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="FontWeight" Value="Bold"/>
                                            <Setter Property="VerticalAlignment" Value="Center"/>
                                            <Setter Property="Foreground" Value="#16A34A"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </Border>
            </Grid>
        </Border>
    </Grid>
</UserControl>
