<UserControl x:Class="CbtExam.Desktop.Views.ResultsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer Background="{StaticResource BgBrush}">
        <StackPanel Margin="26">
            <Grid Margin="0,0,0,22">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="Results" FontSize="28" FontWeight="Bold" Foreground="#111827"/>
                    <TextBlock Text="Review student scores and session performance." FontSize="14" Foreground="#64748B" Margin="0,8,0,0"/>
                </StackPanel>
                <Button Grid.Column="1" Command="{Binding RefreshCommand}" Style="{StaticResource PrimaryBtn}" Background="#059669" Padding="18,11">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE72C;" FontFamily="Segoe MDL2 Assets" Margin="0,0,8,0"/>
                        <TextBlock Text="Refresh"/>
                    </StackPanel>
                </Button>
            </Grid>

            <Border Background="White" CornerRadius="14" BorderBrush="#E5E7EB" BorderThickness="1" Padding="18" Margin="0,0,0,20">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Session" FontSize="13" FontWeight="SemiBold" Foreground="#334155" VerticalAlignment="Center" Margin="0,0,12,0"/>
                    <ComboBox ItemsSource="{Binding Sessions, Mode=OneWay}" SelectedItem="{Binding SelectedSession}" DisplayMemberPath="SessionCode" Width="190" Margin="0,0,16,0"/>
                    <TextBlock Text="{Binding SelectedSession.ExamTitle, Mode=OneWay}" FontSize="13" Foreground="#64748B" VerticalAlignment="Center"/>
                </StackPanel>
            </Border>

            <UniformGrid Columns="3" Margin="0,0,0,20" Visibility="{Binding Results.Count, Mode=OneWay, Converter={StaticResource IntToVis}}">
                <Border Background="White" CornerRadius="14" BorderBrush="#E5E7EB" BorderThickness="1" Padding="18" Margin="0,0,12,0">
                    <StackPanel><TextBlock Text="Average Score" Foreground="#64748B"/><TextBlock FontSize="30" FontWeight="Bold" Foreground="#2563EB"><Run Text="{Binding AvgScore, Mode=OneWay}"/><Run Text="%"/></TextBlock></StackPanel>
                </Border>
                <Border Background="White" CornerRadius="14" BorderBrush="#E5E7EB" BorderThickness="1" Padding="18" Margin="0,0,12,0">
                    <StackPanel><TextBlock Text="Passed" Foreground="#64748B"/><TextBlock Text="{Binding PassCount, Mode=OneWay}" FontSize="30" FontWeight="Bold" Foreground="#059669"/></StackPanel>
                </Border>
                <Border Background="White" CornerRadius="14" BorderBrush="#E5E7EB" BorderThickness="1" Padding="18">
                    <StackPanel><TextBlock Text="Failed" Foreground="#64748B"/><TextBlock Text="{Binding FailCount, Mode=OneWay}" FontSize="30" FontWeight="Bold" Foreground="#DC2626"/></StackPanel>
                </Border>
            </UniformGrid>

            <Border Background="White" CornerRadius="14" BorderBrush="#E5E7EB" BorderThickness="1" Padding="18">
                <StackPanel>
                    <Grid Margin="0,0,0,18">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                        <Grid Width="360" Height="44">
                            <TextBox Padding="40,8,12,8"/>
                            <TextBlock Text="&#xE721;" FontFamily="Segoe MDL2 Assets" Foreground="#64748B" VerticalAlignment="Center" Margin="14,0,0,0"/>
                            <TextBlock Text="Search results..." Foreground="#64748B" VerticalAlignment="Center" Margin="40,0,0,0" IsHitTestVisible="False"/>
                        </Grid>
                        <Button Grid.Column="1" Style="{StaticResource PrimaryBtn}" Background="#F8FAFC" Foreground="#111827" Padding="15,10">
                            <StackPanel Orientation="Horizontal"><TextBlock Text="&#xE74E;" FontFamily="Segoe MDL2 Assets" Margin="0,0,8,0"/><TextBlock Text="Export"/></StackPanel>
                        </Button>
                    </Grid>
                    <DataGrid ItemsSource="{Binding Results, Mode=OneWay}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Student" Binding="{Binding FullName, Mode=OneWay}" Width="*"/>
                            <DataGridTextColumn Header="Student ID" Binding="{Binding StudentId, Mode=OneWay}" Width="130"/>
                            <DataGridTextColumn Header="Score" Binding="{Binding Score, Mode=OneWay}" Width="80"/>
                            <DataGridTextColumn Header="Total" Binding="{Binding Total, Mode=OneWay}" Width="80"/>
                            <DataGridTextColumn Header="Percentage" Binding="{Binding Percentage, Mode=OneWay, StringFormat='{}{0:F0}%'}" Width="110"/>
                            <DataGridTemplateColumn Header="Result" Width="110">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Border CornerRadius="6" Background="#ECFDF5" BorderBrush="#BBF7D0" BorderThickness="1" Padding="9,4" HorizontalAlignment="Left">
                                            <TextBlock Text="Recorded" FontSize="12" FontWeight="Bold" Foreground="#047857"/>
                                        </Border>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Header="Submitted" Binding="{Binding SubmittedAt, Mode=OneWay, StringFormat='HH:mm:ss'}" Width="110"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
