<UserControl x:Class="CbtExam.Desktop.Views.ResultsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer Background="{DynamicResource BgBrush}">
        <StackPanel Margin="32">
            <!-- Header -->
            <Grid Margin="0,0,0,32">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="Performance Results" FontSize="28" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                    <TextBlock Text="Analyze individual candidate performance and session-level statistics." FontSize="14"
                               Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,6,0,0"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Command="{Binding RefreshCommand}" Style="{StaticResource PrimaryBtn}"
                            Background="{DynamicResource CardBrush}" Foreground="{DynamicResource TextPrimaryBrush}"
                            Padding="16,10" Margin="0,0,12,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE72C;" FontFamily="Segoe MDL2 Assets" Margin="0,0,10,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Refresh" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button Command="{Binding PrintCommand}" Style="{StaticResource PrimaryBtn}"
                            Background="{DynamicResource PremiumGradient}" Padding="20,10">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE749;" FontFamily="Segoe MDL2 Assets" Margin="0,0,10,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Export Results" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>

            <!-- Session selector -->
            <Border Style="{StaticResource Card}" Padding="24,16" Margin="0,0,0,24">
                <StackPanel Orientation="Horizontal">
                    <Border Background="{DynamicResource NavActiveBrush}" CornerRadius="10" Padding="12,6" Margin="0,0,16,0">
                         <TextBlock Text="ACTIVE FILTER" FontSize="10" FontWeight="Bold" Foreground="{DynamicResource AccentBrush}" LetterSpacing="1" VerticalAlignment="Center"/>
                    </Border>
                    
                    <TextBlock Text="Session:" FontSize="13" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center" Margin="0,0,12,0"/>
                    <ComboBox ItemsSource="{Binding Sessions}" SelectedItem="{Binding SelectedSession}"
                               DisplayMemberPath="SessionCode" Width="220" Margin="0,0,20,0" Height="40"/>
                               
                    <Border Background="{DynamicResource BgBrush}" CornerRadius="8" Padding="12,6" VerticalAlignment="Center">
                        <TextBlock Text="{Binding SelectedSession.ExamTitle}" FontSize="13" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextPrimaryBrush}"/>
                    </Border>
                </StackPanel>
            </Border>

            <!-- Stats row -->
            <UniformGrid Columns="3" Margin="0,0,0,24"
                         Visibility="{Binding Results.Count, Converter={StaticResource IntToVis}}">
                <Border Style="{StaticResource Card}" Padding="24" Margin="0,0,16,0">
                    <StackPanel>
                        <TextBlock Text="AVERAGE PERFORMANCE" FontSize="10" FontWeight="Bold" Foreground="{DynamicResource TextSecondaryBrush}" LetterSpacing="1"/>
                        <TextBlock FontSize="36" FontWeight="Black" Foreground="{DynamicResource AccentBrush}" Margin="0,8,0,0">
                            <Run Text="{Binding AvgScore}"/><Run Text="%" FontSize="20"/>
                        </TextBlock>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource Card}" Padding="24" Margin="0,0,16,0">
                    <StackPanel>
                        <TextBlock Text="TOTAL PASSED" FontSize="10" FontWeight="Bold" Foreground="{DynamicResource TextSecondaryBrush}" LetterSpacing="1"/>
                        <TextBlock Text="{Binding PassCount}" FontSize="36" FontWeight="Black" Foreground="#16A34A" Margin="0,8,0,0"/>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource Card}" Padding="24">
                    <StackPanel>
                        <TextBlock Text="TOTAL FAILED" FontSize="10" FontWeight="Bold" Foreground="{DynamicResource TextSecondaryBrush}" LetterSpacing="1"/>
                        <TextBlock Text="{Binding FailCount}" FontSize="36" FontWeight="Black" Foreground="#DC2626" Margin="0,8,0,0"/>
                    </StackPanel>
                </Border>
            </UniformGrid>

            <!-- Results table -->
            <Border Style="{StaticResource Card}" Padding="0">
                <StackPanel>
                    <Border Background="{DynamicResource HeaderBgBrush}" CornerRadius="16,16,0,0" Padding="24,14">
                        <TextBlock Text="Candidate Merit List" FontSize="14" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                    </Border>
                    
                    <Border Padding="12">
                         <DataGrid ItemsSource="{Binding Results}" AutoGenerateColumns="False" CanUserAddRows="False"
                                  Background="Transparent" BorderThickness="0" RowHeight="50" GridLinesVisibility="None"
                                  HeadersVisibility="Column">
                            <DataGrid.Columns>
                                <DataGridTemplateColumn Header="CANDIDATE" Width="*">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="12,0">
                                                <Border Width="32" Height="32" CornerRadius="16" Background="{DynamicResource NavActiveBrush}" Margin="0,0,12,0">
                                                    <TextBlock Text="&#xE77B;" FontFamily="Segoe MDL2 Assets" Foreground="{DynamicResource AccentBrush}" FontSize="14" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                                <StackPanel VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding FullName}" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                                    <TextBlock Text="{Binding StudentId}" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                                </StackPanel>
                                            </StackPanel>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                
                                <DataGridTextColumn Header="SCORE" Binding="{Binding Score}" Width="80">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="FontWeight" Value="Bold"/>
                                            <Setter Property="VerticalAlignment" Value="Center"/>
                                            <Setter Property="HorizontalAlignment" Value="Center"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                
                                <DataGridTextColumn Header="TOTAL" Binding="{Binding Total}" Width="80">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="VerticalAlignment" Value="Center"/>
                                            <Setter Property="HorizontalAlignment" Value="Center"/>
                                            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                
                                <DataGridTextColumn Header="PERCENT" Binding="{Binding Percentage, StringFormat='{}{0:F1}%'}" Width="100">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="FontWeight" Value="Black"/>
                                            <Setter Property="VerticalAlignment" Value="Center"/>
                                            <Setter Property="Foreground" Value="{DynamicResource AccentBrush}"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                
                                <DataGridTemplateColumn Header="OUTCOME" Width="120">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Border CornerRadius="8" Padding="12,6" HorizontalAlignment="Left" VerticalAlignment="Center">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Background" Value="#10DC2626"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Passed}" Value="True">
                                                                <Setter Property="Background" Value="#1016A34A"/>
                                                                <Setter Property="BorderBrush" Value="#3016A34A"/>
                                                                <Setter Property="BorderThickness" Value="1"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <TextBlock FontSize="11" FontWeight="Bold">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Text" Value="REJECTED"/>
                                                            <Setter Property="Foreground" Value="#DC2626"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding Passed}" Value="True">
                                                                    <Setter Property="Text" Value="PASSED"/>
                                                                    <Setter Property="Foreground" Value="#16A34A"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </Border>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                
                                <DataGridTextColumn Header="SUBMITTED" Binding="{Binding SubmittedAt, StringFormat='HH:mm:ss'}" Width="120">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="VerticalAlignment" Value="Center"/>
                                            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Border>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
