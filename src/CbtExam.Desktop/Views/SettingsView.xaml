<UserControl x:Class="CbtExam.Desktop.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <ScrollViewer Background="{DynamicResource BgBrush}">
        <StackPanel Margin="32">
            <TextBlock Text="System Configuration" FontSize="28" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}"/>
            <TextBlock Text="Manage global application preferences, server settings, and visual themes." FontSize="14" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,8,0,32"/>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="240"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="340"/>
                </Grid.ColumnDefinitions>

                <!-- Sidebar Settings Navigation -->
                <Border Style="{StaticResource Card}" Padding="12" Margin="0,0,24,0" VerticalAlignment="Top">
                    <StackPanel>
                        <Border CornerRadius="12" Background="{DynamicResource NavActiveBrush}" Padding="16,12" Margin="0,0,0,8">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE713;" FontFamily="Segoe MDL2 Assets" Foreground="{DynamicResource AccentBrush}" FontSize="18" Margin="0,0,14,0" VerticalAlignment="Center"/>
                                <TextBlock Text="General" FontWeight="Bold" Foreground="{DynamicResource AccentBrush}" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        <Border CornerRadius="12" Background="Transparent" Padding="16,12" Margin="0,0,0,8" Cursor="Hand">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE77B;" FontFamily="Segoe MDL2 Assets" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="18" Margin="0,0,14,0" VerticalAlignment="Center"/>
                                <TextBlock Text="Account" FontWeight="SemiBold" Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        <Border CornerRadius="12" Background="Transparent" Padding="16,12" Cursor="Hand">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xEA1F;" FontFamily="Segoe MDL2 Assets" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="18" Margin="0,0,14,0" VerticalAlignment="Center"/>
                                <TextBlock Text="Security" FontWeight="SemiBold" Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>

                <!-- Middle Column: Identity & Appearance -->
                <StackPanel Grid.Column="1" Margin="0,0,24,0">
                    <Border Style="{StaticResource Card}" Padding="24" Margin="0,0,0,24">
                        <StackPanel>
                            <TextBlock Text="Institution Identity" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,20"/>
                            
                            <!-- School Logo Upload -->
                            <TextBlock Text="INSTITUTION LOGO" FontSize="10" FontWeight="Bold" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,12" LetterSpacing="1"/>
                            <Grid Margin="0,0,0,24">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                
                                <Border Grid.Column="0" Width="80" Height="80" CornerRadius="12" Background="{DynamicResource BgBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                                    <Image Source="{Binding SchoolLogoImage}" Stretch="Uniform" Margin="8">
                                        <Image.Style>
                                            <Style TargetType="Image">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding SchoolLogoImage}" Value="{x:Null}">
                                                        <Setter Property="Source" Value="pack://application:,,,/Resources/jamb.png"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Image.Style>
                                    </Image>
                                </Border>
                                
                                <StackPanel Grid.Column="1" Margin="20,0,0,0" VerticalAlignment="Center">
                                    <TextBlock Text="Visual Branding" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                    <TextBlock Text="PNG or JPG. Maximum size 2MB." FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,4,0,0"/>
                                </StackPanel>
                                
                                <Button Grid.Column="2" Content="Replace Logo" Command="{Binding UploadLogoCommand}" 
                                        Style="{StaticResource PrimaryBtn}" Background="{DynamicResource CardBrush}" Foreground="{DynamicResource TextPrimaryBrush}" Padding="16,8" VerticalAlignment="Center"/>
                            </Grid>
                            
                            <TextBlock Text="SYSTEM DISPLAY NAME" FontSize="10" FontWeight="Bold" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,8" LetterSpacing="1"/>
                            <TextBox Text="{Binding SystemName}" Margin="0,0,0,16" Height="42"/>
                            
                            <TextBlock Text="ADMINISTRATIVE CONTACT" FontSize="10" FontWeight="Bold" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,8" LetterSpacing="1"/>
                            <TextBox Text="{Binding AdminEmail}" Margin="0,0,0,16" Height="42"/>
                            
                            <TextBlock Text="SERVER BINDING PORT" FontSize="10" FontWeight="Bold" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,8" LetterSpacing="1"/>
                            <StackPanel Orientation="Horizontal">
                                <TextBox Text="{Binding Port}" Width="120" Margin="0,0,12,0" Height="42" FontWeight="Bold"/>
                                <Border Background="#10F59E0B" CornerRadius="8" Padding="12,4" VerticalAlignment="Center">
                                    <TextBlock Text="Requires server restart" Foreground="#D97706" FontSize="11" FontWeight="Bold"/>
                                </Border>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource Card}" Padding="24">
                        <StackPanel>
                            <TextBlock Text="Visual Interface" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,20"/>
                            
                            <Grid Margin="0,0,0,20">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Margin="0,0,12,0">
                                    <TextBlock Text="THEME MODE" FontSize="10" FontWeight="Bold" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,8,8" LetterSpacing="1"/>
                                    <ComboBox ItemsSource="{Binding ThemeOptions}" SelectedItem="{Binding SelectedTheme}" Height="42"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Margin="12,0,0,0">
                                    <TextBlock Text="ACCENT COLOR" FontSize="10" FontWeight="Bold" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,8,8" LetterSpacing="1"/>
                                    <ComboBox ItemsSource="{Binding AccentOptions}" SelectedItem="{Binding SelectedAccent}" Height="42"/>
                                </StackPanel>
                            </Grid>
                            
                            <Button Content="Apply Interface Changes" Command="{Binding ApplyThemeCommand}" 
                                    Style="{StaticResource PrimaryBtn}" Background="{DynamicResource PremiumGradient}" Padding="24,12" HorizontalAlignment="Stretch"/>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- Right Column: Notifications & System Info -->
                <StackPanel Grid.Column="2">
                    <Border Style="{StaticResource Card}" Padding="24" Margin="0,0,0,24">
                        <StackPanel>
                            <TextBlock Text="Notifications" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,16"/>
                            <CheckBox Content="Email reporting" IsChecked="True" Margin="0,0,0,14"/>
                            <CheckBox Content="Live session alerts" IsChecked="True" Margin="0,0,0,14"/>
                            <CheckBox Content="Real-time exam monitor" IsChecked="True" Margin="0,0,0,14"/>
                            <CheckBox Content="System health updates" IsChecked="True"/>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource Card}" Padding="24" Margin="0,0,0,24">
                        <StackPanel>
                            <TextBlock Text="Global Repository" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,8"/>
                            <TextBlock Text="Sync question banks from a remote master server." FontSize="13" Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap" Margin="0,0,0,20" LineHeight="1.5"/>
                            
                            <TextBlock Text="REPOSITORY ENDPOINT URL" FontSize="10" FontWeight="Bold" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,8" LetterSpacing="1"/>
                            <TextBox Text="{Binding RepoUrl, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,16" Height="42" Tag="https://api.example.com/repo.json"/>
                            
                            <Button Command="{Binding DownloadRepoCommand}" Style="{StaticResource PrimaryBtn}" 
                                    Background="{DynamicResource AccentBrush}" Padding="20,12" HorizontalAlignment="Stretch">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE896;" FontFamily="Segoe MDL2 Assets" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="Sync &amp; Update" FontWeight="Bold" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            
                            <TextBlock Text="{Binding CopyStatus}" Foreground="{DynamicResource AccentBrush}" FontSize="12" Margin="0,12,0,0" TextWrapping="Wrap" HorizontalAlignment="Center" FontWeight="SemiBold"/>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource Card}" Padding="24">
                        <StackPanel>
                            <TextBlock Text="System Audit" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,20"/>
                            <Grid>
                                <Grid.ColumnDefinitions><ColumnDefinition Width="110"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <TextBlock Text="Version" FontWeight="SemiBold" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,12"/><TextBlock Grid.Column="1" Text="1.2.4 Premium" Foreground="{DynamicResource TextPrimaryBrush}" FontWeight="Bold"/>
                                <TextBlock Grid.Row="1" Text="Build Target" FontWeight="SemiBold" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,12"/><TextBlock Grid.Row="1" Grid.Column="1" Text="Windows Desktop" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                <TextBlock Grid.Row="2" Text="Architecture" FontWeight="SemiBold" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,12"/><TextBlock Grid.Row="2" Grid.Column="1" Text="x64 (Managed)" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                <TextBlock Grid.Row="3" Text="Machine IP" FontWeight="SemiBold" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,12"/><TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding LocalIp}" Foreground="{DynamicResource AccentBrush}" FontWeight="Bold"/>
                                <TextBlock Grid.Row="4" Text="Public URL" FontWeight="SemiBold" Foreground="{DynamicResource TextSecondaryBrush}"/><TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding ServerUrl}" TextWrapping="Wrap" Foreground="{DynamicResource AccentBrush}" FontFamily="Consolas"/>
                            </Grid>
                            
                            <Grid Margin="0,24,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Button Content="Copy URL" Command="{Binding CopyUrlCommand}" Style="{StaticResource PrimaryBtn}" Background="{DynamicResource NavActiveBrush}" Foreground="{DynamicResource AccentBrush}" Padding="12,10" Margin="0,0,6,0"/>
                                <Button Content="Firewall" Command="{Binding OpenFirewallCommand}" Style="{StaticResource PrimaryBtn}" Background="{DynamicResource CardBrush}" Foreground="{DynamicResource TextPrimaryBrush}" Padding="12,10" Margin="6,0,0,0"/>
                            </Grid>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>
        </StackPanel>
    </ScrollViewer>
    
        <!-- Loading Overlay -->
        <Border Background="#A0000000" Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}" CornerRadius="0">
            <Border Background="{DynamicResource CardBrush}" CornerRadius="16" Padding="32" HorizontalAlignment="Center" VerticalAlignment="Center" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                <StackPanel>
                    <ProgressBar IsIndeterminate="True" Width="200" Height="4" Background="{DynamicResource BgBrush}" BorderThickness="0" Foreground="{DynamicResource AccentBrush}"/>
                    <TextBlock Text="{Binding BusyMessage}" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="14" FontWeight="Bold" Margin="0,16,0,0" HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>
        </Border>
    </Grid>
</UserControl>
