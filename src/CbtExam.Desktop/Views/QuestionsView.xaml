<UserControl x:Class="CbtExam.Desktop.Views.QuestionsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Background="{DynamicResource BgBrush}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="400"/>
        </Grid.ColumnDefinitions>

        <!-- Left: Questions List -->
        <Grid Margin="24,24,12,24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Grid Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="Questions Bank" FontSize="28" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                    <TextBlock Text="Manage your question repository by subject and year" FontSize="13"
                               Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,4,0,0"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Command="{Binding RefreshCommand}" Style="{StaticResource PrimaryBtn}"
                            Background="{DynamicResource CardBrush}" Foreground="{DynamicResource TextPrimaryBrush}"
                            Padding="12,9" Margin="0,0,8,0" ToolTip="Refresh">
                        <TextBlock Text="&#xE72C;" FontFamily="Segoe MDL2 Assets"/>
                    </Button>
                    <Button Command="{Binding AddSubjectCommand}" Style="{StaticResource PrimaryBtn}"
                            Background="{DynamicResource CardBrush}" Foreground="{DynamicResource TextPrimaryBrush}"
                            Padding="14,9" Margin="0,0,8,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE710;" FontFamily="Segoe MDL2 Assets" Margin="0,0,7,0"/>
                            <TextBlock Text="New Subject"/>
                        </StackPanel>
                    </Button>
                    <Button Command="{Binding BulkUploadCommand}" Style="{StaticResource PrimaryBtn}"
                            Background="#059669" Padding="14,9">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE8A3;" FontFamily="Segoe MDL2 Assets" Margin="0,0,7,0"/>
                            <TextBlock Text="Bulk Upload"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>

            <!-- Search + Filter toolbar -->
            <Grid Grid.Row="1" Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="1.5*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Grid Height="42">
                    <TextBox Text="{Binding Search, UpdateSourceTrigger=PropertyChanged}" Padding="38,8,12,8" VerticalContentAlignment="Center"/>
                    <TextBlock Text="&#xE721;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               VerticalAlignment="Center" HorizontalAlignment="Left" Margin="12,0,0,0" IsHitTestVisible="False"/>
                    <TextBlock Text="Search questions..." FontSize="13" Foreground="{DynamicResource TextSecondaryBrush}"
                               VerticalAlignment="Center" HorizontalAlignment="Left" Margin="38,0,0,0"
                               IsHitTestVisible="False"
                               Visibility="{Binding Search, Converter={StaticResource EmptyStringToVis}}"/>
                </Grid>
                <ComboBox Grid.Column="1" ItemsSource="{Binding SubjectFilters}" SelectedItem="{Binding SelectedSubject}"
                          MinWidth="100" Margin="8,0,0,0"/>
                <ComboBox Grid.Column="2" ItemsSource="{Binding YearFilters}" SelectedItem="{Binding SelectedYear}"
                          MinWidth="80" Margin="8,0,0,0"/>
                <Border Grid.Column="3" Background="{DynamicResource CardBrush}" CornerRadius="8"
                        BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Margin="8,0,0,0" Padding="10,0">
                    <TextBlock VerticalAlignment="Center" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}">
                        <Run Text="{Binding Questions.Count, Mode=OneWay}"/><Run Text=" questions"/>
                    </TextBlock>
                </Border>
            </Grid>

            <!-- Questions table -->
            <Border Grid.Row="2" Style="{StaticResource Card}" Padding="0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    
                    <!-- Table header -->
                    <Border Background="{DynamicResource HeaderBgBrush}" CornerRadius="14,14,0,0" Padding="0,0,0,0"
                            Visibility="{Binding Questions.Count, Converter={StaticResource IntToVis}}">
                        <Grid Height="40">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="50"/>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="60"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="60"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="#" Margin="16,0,0,0" VerticalAlignment="Center" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource TextSecondaryBrush}"/>
                            <TextBlock Grid.Column="1" Text="Subject" Margin="12,0,0,0" VerticalAlignment="Center" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource TextSecondaryBrush}"/>
                            <TextBlock Grid.Column="2" Text="Year" VerticalAlignment="Center" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource TextSecondaryBrush}"/>
                            <TextBlock Grid.Column="3" Text="#" VerticalAlignment="Center" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource TextSecondaryBrush}"/>
                            <TextBlock Grid.Column="4" Text="Preview" Margin="12,0,0,0" VerticalAlignment="Center" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource TextSecondaryBrush}"/>
                            <TextBlock Grid.Column="5" Text="Edit" VerticalAlignment="Center" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource TextSecondaryBrush}"/>
                        </Grid>
                    </Border>
                    
                    <!-- ScrollViewer for list -->
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto"
                                  Visibility="{Binding Questions.Count, Converter={StaticResource IntToVis}}">
                        <ItemsControl ItemsSource="{Binding Questions}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1"
                                            Background="Transparent">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Style.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="{DynamicResource RowHoverBrush}"/>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <Grid Height="46">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="50"/>
                                                <ColumnDefinition Width="120"/>
                                                <ColumnDefinition Width="80"/>
                                                <ColumnDefinition Width="60"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="60"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="{Binding Serial}" Margin="16,0,0,0" VerticalAlignment="Center"
                                                       FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                            <TextBlock Grid.Column="1" Text="{Binding Subject}" Margin="12,0,0,0"
                                                       VerticalAlignment="Center" FontSize="13" FontWeight="SemiBold"
                                                       Foreground="{DynamicResource TextPrimaryBrush}"/>
                                            <TextBlock Grid.Column="2" Text="{Binding Year}" VerticalAlignment="Center"
                                                       FontSize="12" Foreground="{DynamicResource AccentBrush}"/>
                                            <TextBlock Grid.Column="3" Text="{Binding QuestionNumber}" VerticalAlignment="Center"
                                                       FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                            <TextBlock Grid.Column="4" Text="{Binding Preview}" Margin="12,0,0,0"
                                                       VerticalAlignment="Center" FontSize="12" 
                                                       TextTrimming="CharacterEllipsis"
                                                       Foreground="{DynamicResource TextSecondaryBrush}"/>
                                            <Button Grid.Column="5" Style="{StaticResource PrimaryBtn}"
                                                    Background="Transparent" Foreground="{DynamicResource AccentBrush}"
                                                    Padding="6,4" ToolTip="Edit"
                                                    Command="{Binding DataContext.PickCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                    CommandParameter="{Binding}">
                                                <TextBlock Text="&#xE70F;" FontFamily="Segoe MDL2 Assets" FontSize="13"/>
                                            </Button>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>

                    <!-- Empty State Panel -->
                    <StackPanel Grid.RowSpan="2" VerticalAlignment="Center" HorizontalAlignment="Center" Margin="24"
                                Visibility="{Binding Questions.Count, Converter={StaticResource ZeroToVis}}">
                        <TextBlock Text="&#xE90A;" FontFamily="Segoe MDL2 Assets" FontSize="64" Foreground="#D1D5DB" HorizontalAlignment="Center" Margin="0,0,0,16"/>
                        <TextBlock Text="No questions in your bank yet" FontSize="18" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" HorizontalAlignment="Center"/>
                        <TextBlock Text="Get started by adding questions manually or uploading a bulk sheet on the right panel." FontSize="13" Foreground="{DynamicResource TextSecondaryBrush}" HorizontalAlignment="Center" Margin="0,6,0,0" TextAlignment="Center" MaxWidth="360" TextWrapping="Wrap"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <!-- Right panel: Add/Edit Question -->
        <Border Grid.Column="1" Background="{DynamicResource CardBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1,0,0,0" Margin="0,24,24,24" CornerRadius="0,16,16,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Tab Header -->
                <Border Background="{DynamicResource HeaderBgBrush}" Padding="12,12,12,0" CornerRadius="0,16,0,0">
                    <StackPanel Orientation="Horizontal">
                        <RadioButton x:Name="ManualTab" Content="Manual Entry" IsChecked="True" Style="{StaticResource TabRadioStyle}" Margin="0,0,12,0"/>
                        <RadioButton x:Name="BulkTab" Content="Bulk Upload" Style="{StaticResource TabRadioStyle}"/>
                    </StackPanel>
                </Border>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="24">
                    <Grid>
                        <!-- Manual Entry Form -->
                        <StackPanel Visibility="{Binding IsChecked, ElementName=ManualTab, Converter={StaticResource BoolToVis}}">
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                                <Border Width="36" Height="36" CornerRadius="10" Background="{DynamicResource NavActiveBrush}" Margin="0,0,12,0">
                                    <TextBlock Text="&#xE8F1;" FontFamily="Segoe MDL2 Assets" FontSize="16"
                                               Foreground="{DynamicResource NavActiveFgBrush}"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock VerticalAlignment="Center" FontSize="18" FontWeight="Bold"
                                           Foreground="{DynamicResource TextPrimaryBrush}">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Text" Value="Add Question"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                                    <Setter Property="Text" Value="Edit Question"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </StackPanel>

                            <TextBlock Text="Question Text *" FontSize="12" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,6"/>
                            <TextBox Text="{Binding QuestionText, UpdateSourceTrigger=PropertyChanged}" 
                                     Height="100" TextWrapping="Wrap" AcceptsReturn="True" 
                                     VerticalScrollBarVisibility="Auto" Margin="0,0,0,16"
                                     VerticalContentAlignment="Top"/>

                            <Grid Margin="0,0,0,16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="3*"/>
                                    <ColumnDefinition Width="16"/>
                                    <ColumnDefinition Width="2*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <Grid Margin="0,0,0,6">
                                        <TextBlock Text="Subject *" FontSize="12" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                                        <Button Content="+ New" HorizontalAlignment="Right" Style="{StaticResource PrimaryBtn}" 
                                                Background="Transparent" Foreground="{DynamicResource AccentBrush}"
                                                BorderThickness="0" Padding="0" Margin="0" FontSize="11" FontWeight="SemiBold"
                                                Command="{Binding AddSubjectCommand}" Cursor="Hand"/>
                                    </Grid>
                                    <ComboBox Text="{Binding Subject, UpdateSourceTrigger=PropertyChanged}" 
                                              SelectedValue="{Binding Subject, UpdateSourceTrigger=PropertyChanged}"
                                              IsEditable="True" ItemsSource="{Binding Subjects}" Height="42" VerticalContentAlignment="Center"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="Year *" FontSize="12" FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,6"/>
                                    <TextBox Text="{Binding Year, UpdateSourceTrigger=PropertyChanged}" Height="42" VerticalContentAlignment="Center"/>
                                </StackPanel>
                            </Grid>

                            <TextBlock Text="Options *" FontSize="12" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,16,0,10"/>
                            
                            <Grid Margin="0,0,0,16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="12"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                
                                <StackPanel Grid.Row="0" Grid.Column="0">
                                    <TextBlock Text="Option A" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,6"/>
                                    <TextBox Text="{Binding OptionA, UpdateSourceTrigger=PropertyChanged}" Height="42" VerticalContentAlignment="Center"/>
                                </StackPanel>
                                <StackPanel Grid.Row="0" Grid.Column="1" Margin="16,0,0,0">
                                    <TextBlock Text="Option B" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,6"/>
                                    <TextBox Text="{Binding OptionB, UpdateSourceTrigger=PropertyChanged}" Height="42" VerticalContentAlignment="Center"/>
                                </StackPanel>
                                
                                <StackPanel Grid.Row="2" Grid.Column="0">
                                    <TextBlock Text="Option C" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,6"/>
                                    <TextBox Text="{Binding OptionC, UpdateSourceTrigger=PropertyChanged}" Height="42" VerticalContentAlignment="Center"/>
                                </StackPanel>
                                <StackPanel Grid.Row="2" Grid.Column="1" Margin="16,0,0,0">
                                    <TextBlock Text="Option D" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,6"/>
                                    <TextBox Text="{Binding OptionD, UpdateSourceTrigger=PropertyChanged}" Height="42" VerticalContentAlignment="Center"/>
                                </StackPanel>
                            </Grid>

                            <TextBlock Text="Correct Answer *" FontSize="12" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,16,0,6"/>
                            <ComboBox SelectedValue="{Binding CorrectAnswer}" SelectedValuePath="Content" Height="42" VerticalContentAlignment="Center" Margin="0,0,0,24">
                                <ComboBoxItem Content="A"/>
                                <ComboBoxItem Content="B"/>
                                <ComboBoxItem Content="C"/>
                                <ComboBoxItem Content="D"/>
                            </ComboBox>

                            <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                <Button Command="{Binding SaveCommand}" Style="{StaticResource PrimaryBtn}"
                                        Background="{DynamicResource AccentBrush}" Padding="24,11" Margin="0,0,10,0">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="&#xE74E;" FontFamily="Segoe MDL2 Assets" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                        <TextBlock Text="Save Question" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                                <Button Command="{Binding DeleteCommand}" Style="{StaticResource DangerBtn}"
                                        Padding="16,11" Margin="0,0,10,0"
                                        Visibility="{Binding IsEditing, Converter={StaticResource BoolToVis}}">
                                    <TextBlock Text="&#xE74D;" FontFamily="Segoe MDL2 Assets"/>
                                </Button>
                                <Button Command="{Binding ClearCommand}" Style="{StaticResource PrimaryBtn}"
                                        Background="{DynamicResource HeaderBgBrush}" Foreground="{DynamicResource TextPrimaryBrush}"
                                        Padding="18,11" Visibility="{Binding IsEditing, Converter={StaticResource BoolToVis}}">
                                    <TextBlock Text="Cancel"/>
                                </Button>
                            </StackPanel>
                            <TextBlock Text="{Binding Status}" FontSize="13" TextWrapping="Wrap"
                                       Foreground="{Binding StatusOk, Converter={StaticResource BoolToColor}}"/>
                        </StackPanel>

                        <!-- Bulk Upload Form -->
                        <StackPanel Visibility="{Binding IsChecked, ElementName=BulkTab, Converter={StaticResource BoolToVis}}">
                            <TextBlock Text="Bulk Questions Ingestion" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,6"/>
                            <TextBlock Text="Upload files to seamlessly import hundreds of questions instantly." FontSize="13" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,20" TextWrapping="Wrap"/>

                            <!-- Dashed Ingestion Zone -->
                            <Border x:Name="UploadZoneBorder" AllowDrop="True" Background="{DynamicResource FieldBg}" CornerRadius="12" BorderThickness="0" Margin="0,0,0,16" Height="180">
                                <Grid>
                                    <Rectangle Stroke="{DynamicResource BorderBrush}" StrokeDashArray="4 3" StrokeThickness="1.5" RadiusX="12" RadiusY="12"/>
                                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Margin="20">
                                        <TextBlock Text="&#xE8E5;" FontFamily="Segoe MDL2 Assets" FontSize="40" Foreground="{DynamicResource AccentBrush}" HorizontalAlignment="Center" Margin="0,0,0,12"/>
                                        <TextBlock Text="Drag &amp; drop your question file here" FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" HorizontalAlignment="Center"/>
                                        <TextBlock Text="or browse local files" FontSize="12" Foreground="{DynamicResource AccentBrush}" FontWeight="SemiBold" HorizontalAlignment="Center" Margin="0,4,0,0" Cursor="Hand">
                                            <TextBlock.InputBindings>
                                                <MouseBinding MouseAction="LeftClick" Command="{Binding BrowseFileCommand}"/>
                                            </TextBlock.InputBindings>
                                        </TextBlock>
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <TextBlock Text="Supports .csv or .json formatted templates" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}" HorizontalAlignment="Center" Margin="0,0,0,24"/>

                            <!-- Action Buttons -->
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,24">
                                <Button Command="{Binding DownloadTemplateCommand}" Style="{StaticResource PrimaryBtn}"
                                        Background="{DynamicResource FieldBg}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                                        Foreground="{DynamicResource TextPrimaryBrush}" Padding="16,10" Margin="0,0,12,0" Cursor="Hand">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="&#xE896;" FontFamily="Segoe MDL2 Assets" FontSize="12" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                        <TextBlock Text="Download CSV Template" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                                <Button Command="{Binding BrowseFileCommand}" Style="{StaticResource PrimaryBtn}"
                                        Background="{DynamicResource AccentBrush}" Foreground="White" Padding="16,10" Cursor="Hand">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="&#xE8E5;" FontFamily="Segoe MDL2 Assets" FontSize="12" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                        <TextBlock Text="Browse File" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                            </StackPanel>

                            <!-- JSON Paste alternative -->
                            <Expander Header="Alternative: Paste Raw JSON" Background="Transparent" BorderThickness="0" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12" HorizontalAlignment="Stretch">
                                <StackPanel Margin="0,10,0,0">
                                    <TextBlock Text="Paste JSON content directly below:" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,6"/>
                                    <TextBox Text="{Binding JsonImport, UpdateSourceTrigger=PropertyChanged}" Height="120" TextWrapping="Wrap" AcceptsReturn="True" FontFamily="Consolas" FontSize="12" VerticalScrollBarVisibility="Auto" Margin="0,0,0,12"/>
                                    <Button Command="{Binding ImportJsonCommand}" Style="{StaticResource PrimaryBtn}" Background="#059669" Padding="16,8" HorizontalAlignment="Left">
                                        <TextBlock Text="Parse &amp; Import JSON" FontSize="12" FontWeight="Bold"/>
                                    </Button>
                                </StackPanel>
                            </Expander>

                            <TextBlock Text="{Binding Status}" FontSize="13" TextWrapping="Wrap" Margin="0,16,0,0" HorizontalAlignment="Center"
                                       Foreground="{Binding StatusOk, Converter={StaticResource BoolToColor}}"/>
                        </StackPanel>
                    </Grid>
                </ScrollViewer>
            </Grid>
        </Border>

        <!-- Add Subject Overlay -->
        <Border Grid.ColumnSpan="2" Background="#80000000" Visibility="{Binding IsAddingSubject, Converter={StaticResource BoolToVis}}">
            <Border Background="{DynamicResource CardBrush}" CornerRadius="16" Width="320" VerticalAlignment="Center" HorizontalAlignment="Center" Padding="24">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="30" ShadowDepth="5" Opacity="0.2" Color="#000000"/>
                </Border.Effect>
                <StackPanel>
                    <TextBlock Text="Create New Subject" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,16"/>
                    <TextBlock Text="Enter the name of the subject you want to add to the bank." FontSize="13" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,20" TextWrapping="Wrap"/>
                    
                    <TextBlock Text="Subject Name" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,6"/>
                    <TextBox Text="{Binding NewSubjectName, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,24">
                        <TextBox.InputBindings>
                            <KeyBinding Key="Enter" Command="{Binding ConfirmAddSubjectCommand}"/>
                            <KeyBinding Key="Escape" Command="{Binding CancelAddSubjectCommand}"/>
                        </TextBox.InputBindings>
                    </TextBox>
                    
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="Cancel" Command="{Binding CancelAddSubjectCommand}" Style="{StaticResource PrimaryBtn}" Background="#F1F5F9" Foreground="#111827" Margin="0,0,12,0" Padding="16,8"/>
                        <Button Content="Create Subject" Command="{Binding ConfirmAddSubjectCommand}" Style="{StaticResource PrimaryBtn}" Background="{DynamicResource AccentBrush}" Padding="16,8"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Border>

        <!-- Loading Overlay -->
        <Border Grid.ColumnSpan="2" Background="#40FFFFFF" Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <ProgressBar IsIndeterminate="True" Width="120" Height="3" Background="Transparent" BorderThickness="0" Foreground="{DynamicResource AccentBrush}"/>
                <TextBlock Text="{Binding BusyMessage}" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12" Margin="0,10,0,0" HorizontalAlignment="Center"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
