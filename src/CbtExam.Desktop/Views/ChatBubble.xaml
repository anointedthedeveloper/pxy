<UserControl x:Class="CbtExam.Desktop.Views.ChatBubble"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:CbtExam.Desktop.ViewModels">

    <UserControl.Resources>

        <!-- User message bubble -->
        <Style x:Key="UserBubble" TargetType="Border">
            <Setter Property="Background"    Value="{DynamicResource AccentBrush}"/>
            <Setter Property="CornerRadius"  Value="14,14,2,14"/>
            <Setter Property="Padding"       Value="12,8"/>
            <Setter Property="Margin"        Value="48,3,0,3"/>
            <Setter Property="HorizontalAlignment" Value="Right"/>
            <Setter Property="MaxWidth"      Value="260"/>
        </Style>

        <!-- Bot message bubble -->
        <Style x:Key="BotBubble" TargetType="Border">
            <Setter Property="Background"    Value="{DynamicResource FieldBg}"/>
            <Setter Property="CornerRadius"  Value="14,14,14,2"/>
            <Setter Property="Padding"       Value="12,8"/>
            <Setter Property="Margin"        Value="0,3,48,3"/>
            <Setter Property="HorizontalAlignment" Value="Left"/>
            <Setter Property="MaxWidth"      Value="260"/>
            <Setter Property="BorderBrush"   Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <!-- Send button -->
        <Style x:Key="SendBtn" TargetType="Button">
            <Setter Property="Background"       Value="{DynamicResource AccentBrush}"/>
            <Setter Property="Foreground"       Value="White"/>
            <Setter Property="BorderThickness"  Value="0"/>
            <Setter Property="Width"            Value="36"/>
            <Setter Property="Height"           Value="36"/>
            <Setter Property="Cursor"           Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                CornerRadius="18" Width="36" Height="36">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{DynamicResource AccentDarkBrush}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="bd" Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- FAB (floating action button) style -->
        <Style x:Key="FabStyle" TargetType="Button">
            <Setter Property="Width"           Value="52"/>
            <Setter Property="Height"          Value="52"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Background"      Value="{DynamicResource AccentBrush}"/>
            <Setter Property="Foreground"       Value="White"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid>
                            <!-- drop shadow -->
                            <Ellipse Fill="Black" Opacity="0.18" Margin="2,4,0,0"/>
                            <Border x:Name="bd" Background="{TemplateBinding Background}"
                                    CornerRadius="26" Width="52" Height="52">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{DynamicResource AccentDarkBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="Opacity" Value="0.85"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </UserControl.Resources>

    <!--
        The entire overlay is a Canvas that fills the window.
        The bubble + popup are positioned via right/bottom margin on an inner container.
        Code-behind handles drag to update BubbleRight / BubbleBottom.
    -->
    <Canvas x:Name="RootCanvas" IsHitTestVisible="True"
            HorizontalAlignment="Stretch" VerticalAlignment="Stretch">

        <!-- Anchor panel: sits at bottom-right, position driven by BubbleRight/BubbleBottom -->
        <Grid x:Name="AnchorPanel">
            <StackPanel HorizontalAlignment="Right" VerticalAlignment="Bottom">

                <!-- ── Chat popup panel ───────────────────────────────────────── -->
                <Border x:Name="ChatPanel"
                        Width="320" Height="440"
                        Background="{DynamicResource CardBrush}"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="1"
                        CornerRadius="16"
                        Margin="0,0,0,10"
                        Visibility="{Binding IsOpen, Converter={StaticResource BoolToVis}}">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="24" ShadowDepth="4" Opacity="0.15" Direction="270"/>
                    </Border.Effect>

                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="52"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Header -->
                        <Border Grid.Row="0" Background="{DynamicResource AccentBrush}"
                                CornerRadius="16,16,0,0" Cursor="SizeAll"
                                MouseLeftButtonDown="Header_MouseLeftButtonDown">
                            <Grid Margin="14,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <!-- Bot avatar -->
                                <Border Width="30" Height="30" CornerRadius="15"
                                        Background="White" Opacity="0.25"/>
                                <Border Width="30" Height="30" CornerRadius="15" Margin="0">
                                    <TextBlock Text="🤖" FontSize="16"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel Grid.Column="1" Margin="10,0,0,0" VerticalAlignment="Center">
                                    <TextBlock Text="CBT Assistant" Foreground="White"
                                               FontWeight="Bold" FontSize="13"/>
                                    <TextBlock Text="Online · Always ready" Foreground="White"
                                               FontSize="10" Opacity="0.85"/>
                                </StackPanel>
                                <!-- Clear button -->
                                <Button Grid.Column="2" Command="{Binding ClearCommand}"
                                        Background="Transparent" BorderThickness="0"
                                        Cursor="Hand" ToolTip="Clear chat" Padding="4" Margin="0,0,4,0">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="bd" Background="Transparent" CornerRadius="4" Padding="4">
                                                <TextBlock Text="&#xE894;" FontFamily="Segoe MDL2 Assets"
                                                           FontSize="13" Foreground="White" Opacity="0.8"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="bd" Property="Background" Value="#22FFFFFF"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                                <!-- Close button -->
                                <Button Grid.Column="3" Command="{Binding ToggleCommand}"
                                        Background="Transparent" BorderThickness="0"
                                        Cursor="Hand" ToolTip="Close" Padding="4">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="bd" Background="Transparent" CornerRadius="4" Padding="4">
                                                <TextBlock Text="&#xE8BB;" FontFamily="Segoe MDL2 Assets"
                                                           FontSize="13" Foreground="White" Opacity="0.8"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="bd" Property="Background" Value="#22FFFFFF"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                            </Grid>
                        </Border>

                        <!-- Message list -->
                        <ScrollViewer Grid.Row="1" x:Name="MessageScroll"
                                      VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled"
                                      Padding="10,8"
                                      Background="{DynamicResource BgBrush}">
                            <ItemsControl ItemsSource="{Binding Messages}" x:Name="MessageList">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,2">
                                            <!-- User message (right) -->
                                            <StackPanel HorizontalAlignment="Right"
                                                        Visibility="{Binding IsUser, Converter={StaticResource BoolToVis}}">
                                                <Border Style="{StaticResource UserBubble}">
                                                    <TextBlock Text="{Binding Text}"
                                                               Foreground="White" FontSize="13"
                                                               TextWrapping="Wrap"/>
                                                </Border>
                                                <TextBlock Text="{Binding Time}" FontSize="9"
                                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                                           HorizontalAlignment="Right" Margin="0,1,4,0"/>
                                            </StackPanel>

                                            <!-- Bot message (left) -->
                                            <StackPanel HorizontalAlignment="Left"
                                                        Visibility="{Binding IsUser, Converter={StaticResource BoolToVisInverse}}">
                                                <Border Style="{StaticResource BotBubble}">
                                                    <TextBlock Text="{Binding Text}"
                                                               Foreground="{DynamicResource TextPrimaryBrush}"
                                                               FontSize="13" TextWrapping="Wrap"/>
                                                </Border>
                                                <TextBlock Text="{Binding Time}" FontSize="9"
                                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                                           HorizontalAlignment="Left" Margin="4,1,0,0"/>
                                            </StackPanel>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>

                        <!-- Input area -->
                        <Border Grid.Row="2"
                                BorderBrush="{DynamicResource BorderBrush}"
                                BorderThickness="0,1,0,0"
                                Background="{DynamicResource CardBrush}"
                                CornerRadius="0,0,16,16"
                                Padding="10,8">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0" Background="{DynamicResource FieldBg}"
                                        BorderBrush="{DynamicResource BorderBrush}"
                                        BorderThickness="1" CornerRadius="18" Padding="12,6"
                                        Margin="0,0,8,0">
                                    <TextBox x:Name="InputBox"
                                             Text="{Binding InputText, UpdateSourceTrigger=PropertyChanged}"
                                             Background="Transparent"
                                             BorderThickness="0"
                                             Foreground="{DynamicResource TextPrimaryBrush}"
                                             CaretBrush="{DynamicResource TextPrimaryBrush}"
                                             FontSize="13"
                                             VerticalAlignment="Center"
                                             AcceptsReturn="False"
                                             KeyDown="InputBox_KeyDown">
                                        <TextBox.Style>
                                            <Style TargetType="TextBox">
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate TargetType="TextBox">
                                                            <Grid>
                                                                <TextBlock x:Name="placeholder"
                                                                           Text="Ask me anything..."
                                                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                                                           FontSize="13" VerticalAlignment="Center"
                                                                           IsHitTestVisible="False"
                                                                           Visibility="Collapsed"/>
                                                                <ScrollViewer x:Name="PART_ContentHost" VerticalAlignment="Center"/>
                                                            </Grid>
                                                            <ControlTemplate.Triggers>
                                                                <Trigger Property="Text" Value="">
                                                                    <Setter TargetName="placeholder" Property="Visibility" Value="Visible"/>
                                                                </Trigger>
                                                            </ControlTemplate.Triggers>
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                            </Style>
                                        </TextBox.Style>
                                    </TextBox>
                                </Border>
                                <Button Grid.Column="1" Style="{StaticResource SendBtn}"
                                        Command="{Binding SendCommand}">
                                    <TextBlock Text="&#xE724;" FontFamily="Segoe MDL2 Assets" FontSize="14"/>
                                </Button>
                            </Grid>
                        </Border>

                    </Grid>
                </Border>

                <!-- ── FAB chat button ───────────────────────────────────────── -->
                <Button Style="{StaticResource FabStyle}"
                        Command="{Binding ToggleCommand}"
                        HorizontalAlignment="Right"
                        ToolTip="CBT Assistant"
                        x:Name="FabButton"
                        MouseLeftButtonDown="Fab_MouseLeftButtonDown">
                    <!-- Show chat icon when closed, X when open -->
                    <Grid Width="52" Height="52">
                        <TextBlock Text="&#xE8BD;" FontFamily="Segoe MDL2 Assets" FontSize="22"
                                   Foreground="White"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                   Visibility="{Binding IsClose, Converter={StaticResource BoolToVis}}"/>
                        <TextBlock Text="&#xE8BB;" FontFamily="Segoe MDL2 Assets" FontSize="20"
                                   Foreground="White"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                   Visibility="{Binding IsOpen, Converter={StaticResource BoolToVis}}"/>
                    </Grid>
                </Button>

            </StackPanel>
        </Grid>

    </Canvas>
</UserControl>
