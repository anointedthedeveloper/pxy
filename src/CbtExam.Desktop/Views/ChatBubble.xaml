<UserControl x:Class="CbtExam.Desktop.Views.ChatBubble"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <UserControl.Resources>

        <!-- ── Easing ─────────────────────────────────────────────── -->
        <CubicEase x:Key="SmoothOut" EasingMode="EaseOut"/>
        <BackEase  x:Key="BounceIn"  EasingMode="EaseOut" Amplitude="0.3"/>

        <!-- ── User bubble ───────────────────────────────────────── -->
        <Style x:Key="UserBubble" TargetType="Border">
            <Setter Property="Background"          Value="{DynamicResource AccentBrush}"/>
            <Setter Property="CornerRadius"        Value="16,16,2,16"/>
            <Setter Property="Padding"             Value="12,9"/>
            <Setter Property="Margin"              Value="40,3,0,3"/>
            <Setter Property="HorizontalAlignment" Value="Right"/>
            <Setter Property="MaxWidth"            Value="240"/>
        </Style>

        <!-- ── Bot bubble ────────────────────────────────────────── -->
        <Style x:Key="BotBubble" TargetType="Border">
            <Setter Property="Background"          Value="{DynamicResource FieldBg}"/>
            <Setter Property="CornerRadius"        Value="16,16,16,2"/>
            <Setter Property="Padding"             Value="12,9"/>
            <Setter Property="Margin"              Value="0,3,40,3"/>
            <Setter Property="HorizontalAlignment" Value="Left"/>
            <Setter Property="MaxWidth"            Value="240"/>
            <Setter Property="BorderBrush"         Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness"     Value="1"/>
        </Style>

        <!-- ── Header icon button ────────────────────────────────── -->
        <Style x:Key="HeaderIconBtn" TargetType="Button">
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Padding"         Value="5"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="Transparent" CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#30FFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#50FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── Send button ───────────────────────────────────────── -->
        <Style x:Key="SendBtn" TargetType="Button">
            <Setter Property="Width"           Value="38"/>
            <Setter Property="Height"          Value="38"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Background"      Value="{DynamicResource AccentBrush}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                CornerRadius="19" Width="38" Height="38">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{DynamicResource AccentDarkBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="Opacity" Value="0.75"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="bd" Property="Opacity" Value="0.35"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── FAB ───────────────────────────────────────────────── -->
        <Style x:Key="FabStyle" TargetType="Button">
            <Setter Property="Width"           Value="54"/>
            <Setter Property="Height"          Value="54"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Background"      Value="{DynamicResource AccentBrush}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid>
                            <Ellipse Fill="Black" Opacity="0.20" Margin="3,5,0,0"/>
                            <Border x:Name="bd" Background="{TemplateBinding Background}"
                                    CornerRadius="27" Width="54" Height="54">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{DynamicResource AccentDarkBrush}"/>
                                <Setter TargetName="bd" Property="Opacity" Value="0.92"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="Opacity" Value="0.70"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── Dismiss (X) button on FAB ─────────────────────────── -->
        <Style x:Key="DismissBtn" TargetType="Button">
            <Setter Property="Width"           Value="18"/>
            <Setter Property="Height"          Value="18"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Background"      Value="#CC555555"/>
            <Setter Property="ToolTip"         Value="Hide chat (T+C to reopen)"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                CornerRadius="9" Width="18" Height="18">
                            <TextBlock Text="✕" FontSize="8" Foreground="White"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                       FontWeight="Bold"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#EF4444"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </UserControl.Resources>

    <!-- Full-window transparent overlay canvas -->
    <Canvas x:Name="RootCanvas" IsHitTestVisible="True">

        <!-- Anchor panel — positioned by code-behind -->
        <Grid x:Name="AnchorPanel">

            <!-- FAB visible guard -->
            <StackPanel Visibility="{Binding IsFabVisible, Converter={StaticResource BoolToVis}}">

                <!-- ── Chat popup — ABOVE the FAB ──────────────────────── -->
                <Border x:Name="ChatPanel"
                        Width="330"
                        MinHeight="420" MaxHeight="480"
                        Background="{DynamicResource CardBrush}"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="1"
                        CornerRadius="18"
                        Margin="0,0,0,12"
                        HorizontalAlignment="Right"
                        Visibility="{Binding IsOpen, Converter={StaticResource BoolToVis}}">

                    <Border.Effect>
                        <DropShadowEffect BlurRadius="32" ShadowDepth="6" Opacity="0.18" Direction="270"/>
                    </Border.Effect>

                    <!-- Slide+fade in animation -->
                    <Border.Style>
                        <Style TargetType="Border">
                            <Style.Triggers>
                                <EventTrigger RoutedEvent="Loaded">
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                             From="0" To="1" Duration="0:0:0.22">
                                                <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)"
                                                             From="14" To="0" Duration="0:0:0.22">
                                                <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </EventTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <Border.RenderTransform><TranslateTransform/></Border.RenderTransform>

                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="54"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>  <!-- typing indicator -->
                            <RowDefinition Height="Auto"/>  <!-- input bar -->
                        </Grid.RowDefinitions>

                        <!-- Header -->
                        <Border Grid.Row="0" Background="{DynamicResource AccentBrush}"
                                CornerRadius="18,18,0,0" Cursor="SizeAll"
                                MouseLeftButtonDown="Header_MouseLeftButtonDown">
                            <Grid Margin="14,0,10,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <!-- Avatar with pulse ring -->
                                <Grid Width="34" Height="34">
                                    <Ellipse x:Name="PulseRing" Width="34" Height="34"
                                             Stroke="White" StrokeThickness="1.5" Opacity="0.4">
                                        <Ellipse.RenderTransform>
                                            <ScaleTransform CenterX="17" CenterY="17"/>
                                        </Ellipse.RenderTransform>
                                        <Ellipse.Triggers>
                                            <EventTrigger RoutedEvent="Loaded">
                                                <BeginStoryboard>
                                                    <Storyboard RepeatBehavior="Forever">
                                                        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                                                                         From="1" To="1.35" Duration="0:0:1.5" AutoReverse="True">
                                                            <DoubleAnimation.EasingFunction><SineEase EasingMode="EaseInOut"/></DoubleAnimation.EasingFunction>
                                                        </DoubleAnimation>
                                                        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                                                                         From="1" To="1.35" Duration="0:0:1.5" AutoReverse="True">
                                                            <DoubleAnimation.EasingFunction><SineEase EasingMode="EaseInOut"/></DoubleAnimation.EasingFunction>
                                                        </DoubleAnimation>
                                                        <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                         From="0.4" To="0" Duration="0:0:1.5" AutoReverse="True">
                                                            <DoubleAnimation.EasingFunction><SineEase EasingMode="EaseInOut"/></DoubleAnimation.EasingFunction>
                                                        </DoubleAnimation>
                                                    </Storyboard>
                                                </BeginStoryboard>
                                            </EventTrigger>
                                        </Ellipse.Triggers>
                                    </Ellipse>
                                    <Border Width="30" Height="30" CornerRadius="15"
                                            Background="#22FFFFFF" HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <TextBlock Text="🤖" FontSize="15"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </Grid>

                                <StackPanel Grid.Column="1" Margin="10,0,0,0" VerticalAlignment="Center">
                                    <TextBlock Text="CBT Assistant" Foreground="White"
                                               FontWeight="Bold" FontSize="13.5"/>
                                    <StackPanel Orientation="Horizontal">
                                        <Ellipse Width="6" Height="6" Fill="#4ADE80" Margin="0,0,4,0" VerticalAlignment="Center"/>
                                        <TextBlock Text="Online · Always ready" Foreground="White"
                                                   FontSize="10" Opacity="0.85"/>
                                    </StackPanel>
                                </StackPanel>

                                <!-- Clear -->
                                <Button Grid.Column="2" Style="{StaticResource HeaderIconBtn}"
                                        Command="{Binding ClearCommand}" ToolTip="Clear chat" Margin="0,0,2,0">
                                    <TextBlock Text="&#xE894;" FontFamily="Segoe MDL2 Assets"
                                               FontSize="12" Foreground="White" Opacity="0.85"/>
                                </Button>
                                <!-- Minimise panel (chevron down) -->
                                <Button Grid.Column="3" Style="{StaticResource HeaderIconBtn}"
                                        Command="{Binding ToggleCommand}" ToolTip="Minimise chat">
                                    <TextBlock Text="&#xE96E;" FontFamily="Segoe MDL2 Assets"
                                               FontSize="12" Foreground="White" Opacity="0.85"/>
                                </Button>
                            </Grid>
                        </Border>

                        <!-- Message list -->
                        <ScrollViewer Grid.Row="1" x:Name="MessageScroll"
                                      VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled"
                                      Padding="12,8"
                                      Background="{DynamicResource BgBrush}">
                            <ItemsControl ItemsSource="{Binding Messages}" x:Name="MessageList">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,2">
                                            <!-- User message -->
                                            <StackPanel HorizontalAlignment="Right"
                                                        Visibility="{Binding IsUser, Converter={StaticResource BoolToVis}}">
                                                <Border Style="{StaticResource UserBubble}">
                                                    <Border.Effect>
                                                        <DropShadowEffect BlurRadius="6" ShadowDepth="1" Opacity="0.12" Direction="270"/>
                                                    </Border.Effect>
                                                    <TextBlock Text="{Binding Text}" Foreground="White"
                                                               FontSize="13" TextWrapping="Wrap" LineHeight="20"/>
                                                </Border>
                                                <TextBlock Text="{Binding Time}" FontSize="9"
                                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                                           HorizontalAlignment="Right" Margin="0,1,6,2" Opacity="0.7"/>
                                            </StackPanel>

                                            <!-- Bot message -->
                                            <StackPanel HorizontalAlignment="Left"
                                                        Visibility="{Binding IsUser, Converter={StaticResource BoolToVisInverse}}">
                                                <Border Style="{StaticResource BotBubble}">
                                                    <Border.Effect>
                                                        <DropShadowEffect BlurRadius="6" ShadowDepth="1" Opacity="0.08" Direction="270"/>
                                                    </Border.Effect>
                                                    <TextBlock Text="{Binding Text}"
                                                               Foreground="{DynamicResource TextPrimaryBrush}"
                                                               FontSize="13" TextWrapping="Wrap" LineHeight="20"/>
                                                </Border>
                                                <TextBlock Text="{Binding Time}" FontSize="9"
                                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                                           HorizontalAlignment="Left" Margin="6,1,0,2" Opacity="0.7"/>
                                            </StackPanel>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>

                        <!-- Typing indicator -->
                        <Border Grid.Row="2"
                                Background="{DynamicResource BgBrush}"
                                Padding="16,4,12,6"
                                Visibility="{Binding IsTyping, Converter={StaticResource BoolToVis}}">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <Border Background="{DynamicResource FieldBg}"
                                        BorderBrush="{DynamicResource BorderBrush}"
                                        BorderThickness="1" CornerRadius="12" Padding="10,6">
                                    <StackPanel Orientation="Horizontal">
                                        <!-- Dot 1 -->
                                        <Ellipse x:Name="Dot1" Width="7" Height="7"
                                                 Fill="{DynamicResource TextSecondaryBrush}"
                                                 Margin="0,0,4,0">
                                            <Ellipse.RenderTransform><TranslateTransform/></Ellipse.RenderTransform>
                                            <Ellipse.Triggers>
                                                <EventTrigger RoutedEvent="Loaded">
                                                    <BeginStoryboard>
                                                        <Storyboard RepeatBehavior="Forever">
                                                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)"
                                                                             From="0" To="-5" Duration="0:0:0.4"
                                                                             AutoReverse="True" BeginTime="0:0:0">
                                                                <DoubleAnimation.EasingFunction><SineEase EasingMode="EaseInOut"/></DoubleAnimation.EasingFunction>
                                                            </DoubleAnimation>
                                                        </Storyboard>
                                                    </BeginStoryboard>
                                                </EventTrigger>
                                            </Ellipse.Triggers>
                                        </Ellipse>
                                        <!-- Dot 2 -->
                                        <Ellipse Width="7" Height="7"
                                                 Fill="{DynamicResource TextSecondaryBrush}"
                                                 Margin="0,0,4,0">
                                            <Ellipse.RenderTransform><TranslateTransform/></Ellipse.RenderTransform>
                                            <Ellipse.Triggers>
                                                <EventTrigger RoutedEvent="Loaded">
                                                    <BeginStoryboard>
                                                        <Storyboard RepeatBehavior="Forever">
                                                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)"
                                                                             From="0" To="-5" Duration="0:0:0.4"
                                                                             AutoReverse="True" BeginTime="0:0:0.13">
                                                                <DoubleAnimation.EasingFunction><SineEase EasingMode="EaseInOut"/></DoubleAnimation.EasingFunction>
                                                            </DoubleAnimation>
                                                        </Storyboard>
                                                    </BeginStoryboard>
                                                </EventTrigger>
                                            </Ellipse.Triggers>
                                        </Ellipse>
                                        <!-- Dot 3 -->
                                        <Ellipse Width="7" Height="7"
                                                 Fill="{DynamicResource TextSecondaryBrush}">
                                            <Ellipse.RenderTransform><TranslateTransform/></Ellipse.RenderTransform>
                                            <Ellipse.Triggers>
                                                <EventTrigger RoutedEvent="Loaded">
                                                    <BeginStoryboard>
                                                        <Storyboard RepeatBehavior="Forever">
                                                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)"
                                                                             From="0" To="-5" Duration="0:0:0.4"
                                                                             AutoReverse="True" BeginTime="0:0:0.26">
                                                                <DoubleAnimation.EasingFunction><SineEase EasingMode="EaseInOut"/></DoubleAnimation.EasingFunction>
                                                            </DoubleAnimation>
                                                        </Storyboard>
                                                    </BeginStoryboard>
                                                </EventTrigger>
                                            </Ellipse.Triggers>
                                        </Ellipse>
                                    </StackPanel>
                                </Border>
                                <TextBlock Text="Assistant is typing…"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           FontSize="10" Margin="8,0,0,0" VerticalAlignment="Center"
                                           FontStyle="Italic" Opacity="0.75"/>
                            </StackPanel>
                        </Border>

                        <!-- Input bar -->
                        <Border Grid.Row="3"
                                BorderBrush="{DynamicResource BorderBrush}"
                                BorderThickness="0,1,0,0"
                                Background="{DynamicResource CardBrush}"
                                CornerRadius="0,0,18,18"
                                Padding="10,8">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <Border Grid.Column="0"
                                        Background="{DynamicResource FieldBg}"
                                        BorderBrush="{DynamicResource BorderBrush}"
                                        BorderThickness="1" CornerRadius="19"
                                        Padding="14,7" Margin="0,0,8,0">
                                    <TextBox x:Name="InputBox"
                                             Text="{Binding InputText, UpdateSourceTrigger=PropertyChanged}"
                                             Background="Transparent"
                                             BorderThickness="0"
                                             Foreground="{DynamicResource TextPrimaryBrush}"
                                             CaretBrush="{DynamicResource AccentBrush}"
                                             FontSize="13"
                                             VerticalAlignment="Center"
                                             AcceptsReturn="False"
                                             MaxLength="500"
                                             KeyDown="InputBox_KeyDown">
                                        <TextBox.Style>
                                            <Style TargetType="TextBox">
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate TargetType="TextBox">
                                                            <Grid>
                                                                <TextBlock x:Name="ph"
                                                                           Text="Ask me anything…"
                                                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                                                           FontSize="13" VerticalAlignment="Center"
                                                                           IsHitTestVisible="False"
                                                                           Visibility="Collapsed" Opacity="0.6"/>
                                                                <ScrollViewer x:Name="PART_ContentHost" VerticalAlignment="Center"/>
                                                            </Grid>
                                                            <ControlTemplate.Triggers>
                                                                <Trigger Property="Text" Value="">
                                                                    <Setter TargetName="ph" Property="Visibility" Value="Visible"/>
                                                                </Trigger>
                                                            </ControlTemplate.Triggers>
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                            </Style>
                                        </TextBox.Style>
                                    </TextBox>
                                </Border>

                                <Button Grid.Column="1" Style="{StaticResource SendBtn}"
                                        Command="{Binding SendCommand}">
                                    <TextBlock Text="&#xE724;" FontFamily="Segoe MDL2 Assets"
                                               FontSize="14" Foreground="White"/>
                                </Button>
                            </Grid>
                        </Border>

                    </Grid>
                </Border>

                <!-- ── FAB row: dismiss X + FAB button ─────────────────── -->
                <Grid HorizontalAlignment="Right">
                    <!-- FAB -->
                    <Button Style="{StaticResource FabStyle}"
                            x:Name="FabButton"
                            HorizontalAlignment="Right"
                            ToolTip="CBT Assistant (T+C)"
                            Command="{Binding ToggleCommand}"
                            MouseLeftButtonDown="Fab_MouseLeftButtonDown">
                        <Grid Width="54" Height="54">
                            <!-- Chat icon when closed -->
                            <TextBlock Text="&#xE8BD;" FontFamily="Segoe MDL2 Assets" FontSize="22"
                                       Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"
                                       Visibility="{Binding IsClose, Converter={StaticResource BoolToVis}}"/>
                            <!-- Chevron down when open -->
                            <TextBlock Text="&#xE96E;" FontFamily="Segoe MDL2 Assets" FontSize="20"
                                       Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"
                                       Visibility="{Binding IsOpen, Converter={StaticResource BoolToVis}}"/>
                        </Grid>
                    </Button>

                    <!-- Dismiss X badge — top-right of FAB -->
                    <Button Style="{StaticResource DismissBtn}"
                            Command="{Binding HideFabCommand}"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Top"
                            Margin="0,-4,-4,0"/>
                </Grid>

            </StackPanel>
        </Grid>

    </Canvas>
</UserControl>
