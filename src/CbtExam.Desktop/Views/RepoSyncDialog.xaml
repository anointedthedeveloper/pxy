<Window x:Class="CbtExam.Desktop.Views.RepoSyncDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Sync Question Repository" Height="620" Width="560"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        FontFamily="Segoe UI"
        MinHeight="500">

    <Border Background="{DynamicResource BgBrush}" CornerRadius="20" BorderThickness="1"
            BorderBrush="{DynamicResource BorderBrush}">
        <Border.Effect>
            <DropShadowEffect BlurRadius="40" Color="Black" Opacity="0.15" ShadowDepth="10"/>
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Border Grid.Row="0" Background="{DynamicResource AccentBrush}" CornerRadius="20,20,0,0" Padding="28,20">
                <Grid>
                    <StackPanel>
                        <TextBlock Text="Sync Question Repository" FontSize="20" FontWeight="Black" Foreground="White"/>
                        <TextBlock Text="Choose which subjects to download and save offline." 
                                   FontSize="13" Foreground="White" Opacity="0.8" Margin="0,4,0,0"/>
                    </StackPanel>
                    <Button Width="28" Height="28" Background="#33FFFFFF" BorderThickness="0"
                            HorizontalAlignment="Right" VerticalAlignment="Top"
                            Click="CancelButton_Click" Cursor="Hand">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" CornerRadius="14">
                                    <TextBlock Text="&#xE8BB;" FontFamily="Segoe MDL2 Assets" FontSize="10"
                                               Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Grid>
            </Border>

            <!-- Content -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="28,20,28,0">

                    <!-- Step 1: Phase indicator -->
                    <Border x:Name="PhaseFetch" Visibility="Visible">
                        <StackPanel>
                            <TextBlock Text="STEP 1 — CONNECT TO PROXY" FontSize="10" FontWeight="Bold"
                                       Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,12" Opacity="0.6"/>

                            <TextBlock Text="Proxy Server URL" FontSize="12" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,6"/>
                            <Border BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                                    CornerRadius="6" Background="{DynamicResource InputBgBrush}">
                                <TextBox x:Name="ProxyUrlBox" Height="36" VerticalContentAlignment="Center"
                                         Padding="10,0" FontSize="13" BorderThickness="0" Background="Transparent"
                                         ToolTip="e.g. https://your-proxy.up.railway.app"/>
                            </Border>
                            <TextBlock Text="The URL of your deployed P4JQ proxy server."
                                       FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}"
                                       Margin="0,3,0,0" Opacity="0.7"/>

                            <TextBlock Text="API Key" FontSize="12" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,14,0,6"/>
                            <Border BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                                    CornerRadius="6" Background="{DynamicResource InputBgBrush}" Height="36">
                                <PasswordBox x:Name="ApiKeyBox" PasswordChar="●"
                                             Padding="10,0" FontSize="13"
                                             VerticalContentAlignment="Center"
                                             BorderThickness="0" Background="Transparent"
                                             ToolTip="The API_KEY you set in your proxy's environment variables"/>
                            </Border>
                            <TextBlock Text="Must match the API_KEY set on the proxy server."
                                       FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}"
                                       Margin="0,3,0,0" Opacity="0.7"/>

                            <Button x:Name="FetchBtn" Margin="0,18,0,0" HorizontalAlignment="Left"
                                    Style="{StaticResource PrimaryBtn}" Background="{DynamicResource AccentBrush}"
                                    Foreground="White" Padding="20,10" Click="FetchBtn_Click">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock x:Name="FetchBtnIcon" Text="&#xE72D;" FontFamily="Segoe MDL2 Assets"
                                               FontSize="14" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                    <TextBlock x:Name="FetchBtnText" Text="Fetch Available Subjects"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>

                            <TextBlock x:Name="FetchStatusText" Text="" FontSize="12" Margin="0,10,0,0"
                                       TextWrapping="Wrap" Foreground="#EF4444"/>
                        </StackPanel>
                    </Border>

                    <!-- Step 2: Subject selection (hidden until fetch completes) -->
                    <Border x:Name="PhaseSelect" Visibility="Collapsed" Margin="0,20,0,0">
                        <StackPanel>
                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="STEP 2 — SELECT SUBJECTS" FontSize="10" FontWeight="Bold"
                                           Foreground="{DynamicResource TextSecondaryBrush}" Opacity="0.6"
                                           VerticalAlignment="Center"/>
                                <Button Grid.Column="1" Content="All" Click="SelectAll_Click"
                                        Style="{StaticResource CardBtn}" Padding="12,5" Margin="0,0,6,0"
                                        FontSize="12"/>
                                <Button Grid.Column="2" Content="None" Click="SelectNone_Click"
                                        Style="{StaticResource CardBtn}" Padding="12,5" FontSize="12"/>
                            </Grid>

                            <Border Background="{DynamicResource FieldBg}" BorderBrush="{DynamicResource BorderBrush}"
                                    BorderThickness="1" CornerRadius="12" Padding="4" MaxHeight="320">
                                <ScrollViewer VerticalScrollBarVisibility="Auto">
                                    <ItemsControl x:Name="SubjectList">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Padding="12,9" Margin="2,1" CornerRadius="8" Cursor="Hand">
                                                    <Border.Style>
                                                        <Style TargetType="Border">
                                                            <Setter Property="Background" Value="Transparent"/>
                                                            <Style.Triggers>
                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                    <Setter Property="Background" Value="{DynamicResource NavHoverBrush}"/>
                                                                </Trigger>
                                                                <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                                    <Setter Property="Background" Value="{DynamicResource NavActiveBrush}"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>
                                                        <!-- Custom checkbox look -->
                                                        <Border Width="18" Height="18" CornerRadius="5" Margin="0,0,10,0"
                                                                VerticalAlignment="Center">
                                                            <Border.Style>
                                                                <Style TargetType="Border">
                                                                    <Setter Property="Background" Value="Transparent"/>
                                                                    <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
                                                                    <Setter Property="BorderThickness" Value="1.5"/>
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                                            <Setter Property="Background" Value="{DynamicResource AccentBrush}"/>
                                                                            <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </Border.Style>
                                                            <TextBlock Text="&#xE73E;" FontFamily="Segoe MDL2 Assets" FontSize="10"
                                                                       Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"
                                                                       Visibility="{Binding IsSelected, Converter={StaticResource BoolToVis}}"/>
                                                        </Border>
                                                        <!-- Subject name — clicking toggles selection -->
                                                        <TextBlock Grid.Column="1" Text="{Binding DisplayName}"
                                                                   FontSize="13" VerticalAlignment="Center"
                                                                   Foreground="{DynamicResource TextPrimaryBrush}"/>
                                                        <!-- Question count badge -->
                                                        <Border Grid.Column="2" CornerRadius="10" Padding="8,3"
                                                                Background="{DynamicResource NavActiveBrush}">
                                                            <TextBlock Text="{Binding CountLabel}"
                                                                       FontSize="11" FontWeight="Bold"
                                                                       Foreground="{DynamicResource AccentBrush}"/>
                                                        </Border>
                                                    </Grid>
                                                    <Border.InputBindings>
                                                        <MouseBinding MouseAction="LeftClick"
                                                                      Command="{Binding DataContext.ToggleSubjectCommand,
                                                                          RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                                      CommandParameter="{Binding}"/>
                                                    </Border.InputBindings>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>
                            </Border>

                            <TextBlock x:Name="SelectionCountText" FontSize="12" Margin="0,8,0,0"
                                       Foreground="{DynamicResource TextSecondaryBrush}"/>
                        </StackPanel>
                    </Border>

                    <!-- Progress (hidden until download starts) -->
                    <Border x:Name="PhaseProgress" Visibility="Collapsed" Margin="0,20,0,0">
                        <StackPanel>
                            <TextBlock Text="DOWNLOADING" FontSize="10" FontWeight="Bold"
                                       Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,12" Opacity="0.6"/>
                            <ProgressBar x:Name="ProgressBar" Height="6" Minimum="0" Maximum="100"
                                         Background="{DynamicResource BorderBrush}" BorderThickness="0"
                                         Foreground="{DynamicResource AccentBrush}" Value="0" Margin="0,0,0,10"/>
                            <TextBlock x:Name="ProgressText" FontSize="13" TextWrapping="Wrap"
                                       Foreground="{DynamicResource TextPrimaryBrush}"/>
                            <TextBlock x:Name="ProgressDetail" FontSize="11" TextWrapping="Wrap"
                                       Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Border>

                </StackPanel>
            </ScrollViewer>

            <!-- Footer actions -->
            <Border Grid.Row="2" Padding="28,16,28,24">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock x:Name="FooterStatus" Grid.Column="0" FontSize="12" VerticalAlignment="Center"
                               TextWrapping="Wrap" Foreground="{DynamicResource AccentBrush}"/>

                    <Button Grid.Column="1" Content="Cancel" Style="{StaticResource PrimaryBtn}"
                            Background="Transparent" BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="1" Foreground="{DynamicResource TextSecondaryBrush}"
                            Padding="20,10" Margin="0,0,12,0" Click="CancelButton_Click"
                            x:Name="CancelBtn"/>

                    <Button Grid.Column="2" x:Name="DownloadBtn" Content="Download Selected"
                            Style="{StaticResource PrimaryBtn}" Background="{DynamicResource AccentBrush}"
                            Foreground="White" Padding="24,10" Click="DownloadBtn_Click"
                            IsEnabled="False"/>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
