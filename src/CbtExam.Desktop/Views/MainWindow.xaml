<Window x:Class="CbtExam.Desktop.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:CbtExam.Desktop.ViewModels"
        xmlns:views="clr-namespace:CbtExam.Desktop.Views"
        Title="CBT Exam System - Admin" Height="720" Width="1240"
        MinHeight="640" MinWidth="1080"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized"
        Background="{DynamicResource BgBrush}"
        FontFamily="Segoe UI"
        Icon="pack://application:,,,/appicon.ico"
        Loaded="Window_Loaded">

    <Window.DataContext>
        <vm:MainViewModel/>
    </Window.DataContext>

    <Window.Resources>
        <Style x:Key="SidebarOnlyWhenOpen" TargetType="Border">
            <Setter Property="Visibility" Value="Visible"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding SidebarOpen}" Value="False">
                    <Setter Property="Visibility" Value="Collapsed"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="RailOnlyWhenClosed" TargetType="Border">
            <Setter Property="Visibility" Value="Collapsed"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding SidebarOpen}" Value="False">
                    <Setter Property="Visibility" Value="Visible"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="SideIcon" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe MDL2 Assets"/>
            <Setter Property="FontSize" Value="17"/>
            <Setter Property="Width" Value="28"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style x:Key="SideLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style x:Key="RailBtn" TargetType="Button" BasedOn="{StaticResource NavBtn}">
            <Setter Property="Width" Value="44"/>
            <Setter Property="Height" Value="42"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="FontFamily" Value="Segoe MDL2 Assets"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                CornerRadius="8" Margin="0,2" Padding="0"
                                Width="44" Height="42">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{DynamicResource NavHoverBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="{Binding SidebarWidth, Mode=OneWay}"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="{DynamicResource CardBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,1,0"
                Style="{StaticResource SidebarOnlyWhenOpen}">
            <DockPanel>
                <Border DockPanel.Dock="Top" Padding="16,18" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Image Source="pack://application:,,,/res/jamb.png" Width="42" Height="42" RenderOptions.BitmapScalingMode="HighQuality"/>
                        <StackPanel Grid.Column="1" Margin="10,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="CBT Exam" FontSize="16" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                            <TextBlock Text="Admin Console" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}"/>
                        </StackPanel>
                        <Button Grid.Column="2" Command="{Binding ToggleSidebarCommand}" Style="{StaticResource NavBtn}"
                                Padding="6" ToolTip="Collapse sidebar">
                            <TextBlock Text="&#xE76B;" FontFamily="Segoe MDL2 Assets"/>
                        </Button>
                    </Grid>
                </Border>

                <Border DockPanel.Dock="Bottom" Margin="12,0,12,6" Padding="12" CornerRadius="10"
                        BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Background" Value="#F0FDF4"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding ServerRunning}" Value="False">
                                    <Setter Property="Background" Value="#FEF2F2"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <Ellipse Width="8" Height="8" VerticalAlignment="Center" Margin="0,0,7,0"
                                     Fill="{Binding ServerRunning, Converter={StaticResource BoolToColor}}"/>
                            <TextBlock Text="{Binding ServerStatusText}" FontSize="12" FontWeight="Bold" VerticalAlignment="Center"
                                       Foreground="{Binding ServerRunning, Converter={StaticResource BoolToColor}}"/>
                        </StackPanel>
                        <Grid Margin="0,0,0,8"
                              Visibility="{Binding ServerRunning, Converter={StaticResource BoolToVis}}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Border Background="{DynamicResource InputBgBrush}" CornerRadius="6" BorderBrush="{DynamicResource InputBorderBrush}" BorderThickness="1" Padding="8,5">
                                <TextBlock Text="{Binding ServerUrl}" FontSize="11" Foreground="{DynamicResource AccentBrush}"
                                           TextTrimming="CharacterEllipsis" VerticalAlignment="Center"/>
                            </Border>
                            <Button Grid.Column="1" Command="{Binding CopyServerUrlCommand}" Style="{StaticResource NavBtn}"
                                    Padding="7" Margin="6,0,0,0" ToolTip="Copy URL">
                                <TextBlock Text="&#xE8C8;" FontFamily="Segoe MDL2 Assets" FontSize="13"/>
                            </Button>
                        </Grid>
                        <Button Command="{Binding ToggleServerCommand}" HorizontalAlignment="Stretch"
                                Padding="0,8" FontSize="12" FontWeight="SemiBold">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource PrimaryBtn}">
                                    <Setter Property="Background" Value="#DC2626"/>
                                    <Setter Property="Foreground" Value="White"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding ServerRunning}" Value="False">
                                            <Setter Property="Background" Value="#059669"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="12" Margin="0,0,7,0" VerticalAlignment="Center">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Text" Value="&#xE71A;"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding ServerRunning}" Value="False">
                                                    <Setter Property="Text" Value="&#xE768;"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                                <TextBlock VerticalAlignment="Center">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Text" Value="Stop Server"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding ServerRunning}" Value="False">
                                                    <Setter Property="Text" Value="Start Server"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Border>

                <Border DockPanel.Dock="Bottom" Margin="12" Padding="12" CornerRadius="10"
                        Background="{DynamicResource CardBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Border Width="34" Height="34" CornerRadius="17" Background="{DynamicResource AccentBrush}">
                            <TextBlock Text="A" Foreground="White" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel Grid.Column="1" Margin="10,0,0,0">
                            <TextBlock Text="Admin User" FontSize="12" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                            <TextBlock Text="Super Administrator" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}"/>
                        </StackPanel>
                        <TextBlock Grid.Column="2" Text="&#xE70D;" FontFamily="Segoe MDL2 Assets" Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                    </Grid>
                </Border>

                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Padding="0,0,4,0" Margin="4,0,0,0">
                    <StackPanel Margin="4,18,4,0">
                        <Button Command="{Binding NavigateCommand}" CommandParameter="Dashboard" HorizontalAlignment="Stretch" ToolTip="Dashboard">
                            <Button.Style><Style TargetType="Button" BasedOn="{StaticResource NavBtn}"><Setter Property="Padding" Value="14,13"/><Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/><Style.Triggers><DataTrigger Binding="{Binding CurrentPageKey}" Value="Dashboard"><Setter Property="Background" Value="{DynamicResource NavActiveBrush}"/><Setter Property="Foreground" Value="{DynamicResource NavActiveFgBrush}"/></DataTrigger></Style.Triggers></Style></Button.Style>
                            <StackPanel Orientation="Horizontal"><TextBlock Text="&#xE80F;" Style="{StaticResource SideIcon}"/><TextBlock Text="Dashboard" Style="{StaticResource SideLabel}"/></StackPanel>
                        </Button>
                        <Button Command="{Binding NavigateCommand}" CommandParameter="Exams" HorizontalAlignment="Stretch" ToolTip="Exams">
                            <Button.Style><Style TargetType="Button" BasedOn="{StaticResource NavBtn}"><Setter Property="Padding" Value="14,13"/><Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/><Style.Triggers><DataTrigger Binding="{Binding CurrentPageKey}" Value="Exams"><Setter Property="Background" Value="{DynamicResource NavActiveBrush}"/><Setter Property="Foreground" Value="{DynamicResource NavActiveFgBrush}"/></DataTrigger></Style.Triggers></Style></Button.Style>
                            <StackPanel Orientation="Horizontal"><TextBlock Text="&#xE8A5;" Style="{StaticResource SideIcon}"/><TextBlock Text="Exams" Style="{StaticResource SideLabel}"/></StackPanel>
                        </Button>
                        <Button Command="{Binding NavigateCommand}" CommandParameter="Questions" HorizontalAlignment="Stretch" ToolTip="Questions">
                            <Button.Style><Style TargetType="Button" BasedOn="{StaticResource NavBtn}"><Setter Property="Padding" Value="14,13"/><Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/><Style.Triggers><DataTrigger Binding="{Binding CurrentPageKey}" Value="Questions"><Setter Property="Background" Value="{DynamicResource NavActiveBrush}"/><Setter Property="Foreground" Value="{DynamicResource NavActiveFgBrush}"/></DataTrigger></Style.Triggers></Style></Button.Style>
                            <StackPanel Orientation="Horizontal"><TextBlock Text="&#xE8F1;" Style="{StaticResource SideIcon}"/><TextBlock Text="Questions" Style="{StaticResource SideLabel}"/></StackPanel>
                        </Button>
                        <Button Command="{Binding NavigateCommand}" CommandParameter="Students" HorizontalAlignment="Stretch" ToolTip="Students">
                            <Button.Style><Style TargetType="Button" BasedOn="{StaticResource NavBtn}"><Setter Property="Padding" Value="14,13"/><Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/><Style.Triggers><DataTrigger Binding="{Binding CurrentPageKey}" Value="Students"><Setter Property="Background" Value="{DynamicResource NavActiveBrush}"/><Setter Property="Foreground" Value="{DynamicResource NavActiveFgBrush}"/></DataTrigger></Style.Triggers></Style></Button.Style>
                            <StackPanel Orientation="Horizontal"><TextBlock Text="&#xE716;" Style="{StaticResource SideIcon}"/><TextBlock Text="Students" Style="{StaticResource SideLabel}"/></StackPanel>
                        </Button>
                        <Button Command="{Binding NavigateCommand}" CommandParameter="Sessions" HorizontalAlignment="Stretch" ToolTip="Sessions">
                            <Button.Style><Style TargetType="Button" BasedOn="{StaticResource NavBtn}"><Setter Property="Padding" Value="14,13"/><Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/><Style.Triggers><DataTrigger Binding="{Binding CurrentPageKey}" Value="Sessions"><Setter Property="Background" Value="{DynamicResource NavActiveBrush}"/><Setter Property="Foreground" Value="{DynamicResource NavActiveFgBrush}"/></DataTrigger></Style.Triggers></Style></Button.Style>
                            <StackPanel Orientation="Horizontal"><TextBlock Text="&#xE787;" Style="{StaticResource SideIcon}"/><TextBlock Text="Sessions" Style="{StaticResource SideLabel}"/></StackPanel>
                        </Button>
                        <Button Command="{Binding NavigateCommand}" CommandParameter="Results" HorizontalAlignment="Stretch" ToolTip="Results">
                            <Button.Style><Style TargetType="Button" BasedOn="{StaticResource NavBtn}"><Setter Property="Padding" Value="14,13"/><Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/><Style.Triggers><DataTrigger Binding="{Binding CurrentPageKey}" Value="Results"><Setter Property="Background" Value="{DynamicResource NavActiveBrush}"/><Setter Property="Foreground" Value="{DynamicResource NavActiveFgBrush}"/></DataTrigger></Style.Triggers></Style></Button.Style>
                            <StackPanel Orientation="Horizontal"><TextBlock Text="&#xE9D2;" Style="{StaticResource SideIcon}"/><TextBlock Text="Results" Style="{StaticResource SideLabel}"/></StackPanel>
                        </Button>
                        <Button Command="{Binding NavigateCommand}" CommandParameter="Reports" HorizontalAlignment="Stretch" ToolTip="Reports">
                            <Button.Style><Style TargetType="Button" BasedOn="{StaticResource NavBtn}"><Setter Property="Padding" Value="14,13"/><Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/><Style.Triggers><DataTrigger Binding="{Binding CurrentPageKey}" Value="Reports"><Setter Property="Background" Value="{DynamicResource NavActiveBrush}"/><Setter Property="Foreground" Value="{DynamicResource NavActiveFgBrush}"/></DataTrigger></Style.Triggers></Style></Button.Style>
                            <StackPanel Orientation="Horizontal"><TextBlock Text="&#xE9D9;" Style="{StaticResource SideIcon}"/><TextBlock Text="Reports" Style="{StaticResource SideLabel}"/></StackPanel>
                        </Button>
                        <Button Command="{Binding NavigateCommand}" CommandParameter="Notifications" HorizontalAlignment="Stretch" ToolTip="Notifications">
                            <Button.Style><Style TargetType="Button" BasedOn="{StaticResource NavBtn}"><Setter Property="Padding" Value="14,13"/><Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/><Style.Triggers><DataTrigger Binding="{Binding CurrentPageKey}" Value="Notifications"><Setter Property="Background" Value="{DynamicResource NavActiveBrush}"/><Setter Property="Foreground" Value="{DynamicResource NavActiveFgBrush}"/></DataTrigger></Style.Triggers></Style></Button.Style>
                            <StackPanel Orientation="Horizontal"><TextBlock Text="&#xE7ED;" Style="{StaticResource SideIcon}"/><TextBlock Text="Notifications" Style="{StaticResource SideLabel}"/></StackPanel>
                        </Button>
                        <Button Command="{Binding NavigateCommand}" CommandParameter="Settings" HorizontalAlignment="Stretch" ToolTip="Settings">
                            <Button.Style><Style TargetType="Button" BasedOn="{StaticResource NavBtn}"><Setter Property="Padding" Value="14,13"/><Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/><Style.Triggers><DataTrigger Binding="{Binding CurrentPageKey}" Value="Settings"><Setter Property="Background" Value="{DynamicResource NavActiveBrush}"/><Setter Property="Foreground" Value="{DynamicResource NavActiveFgBrush}"/></DataTrigger></Style.Triggers></Style></Button.Style>
                            <StackPanel Orientation="Horizontal"><TextBlock Text="&#xE713;" Style="{StaticResource SideIcon}"/><TextBlock Text="Settings" Style="{StaticResource SideLabel}"/></StackPanel>
                        </Button>
                    </StackPanel>
                </ScrollViewer>
            </DockPanel>
        </Border>

        <Border Grid.Column="0" Background="{DynamicResource CardBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,1,0"
                Style="{StaticResource RailOnlyWhenClosed}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <!-- Logo + expand toggle -->
                <StackPanel Grid.Row="0" HorizontalAlignment="Center" Margin="0,14,0,6">
                    <Image Source="pack://application:,,,/res/jamb.png" Width="36" Height="36"
                           RenderOptions.BitmapScalingMode="HighQuality" HorizontalAlignment="Center" Margin="0,0,0,4"/>
                    <Button Command="{Binding ToggleSidebarCommand}" Content="&#xE76C;"
                            ToolTip="Expand sidebar" Style="{StaticResource RailBtn}" HorizontalAlignment="Center"/>
                </StackPanel>
                <!-- Nav icons — no margin, truly centred in 64px column -->
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,4,0,0">
                        <Button Content="&#xE80F;" ToolTip="Dashboard" Command="{Binding NavigateCommand}" CommandParameter="Dashboard" Style="{StaticResource RailBtn}"/>
                        <Button Content="&#xE8A5;" ToolTip="Exams" Command="{Binding NavigateCommand}" CommandParameter="Exams" Style="{StaticResource RailBtn}"/>
                        <Button Content="&#xE8F1;" ToolTip="Questions" Command="{Binding NavigateCommand}" CommandParameter="Questions" Style="{StaticResource RailBtn}"/>
                        <Button Content="&#xE716;" ToolTip="Students" Command="{Binding NavigateCommand}" CommandParameter="Students" Style="{StaticResource RailBtn}"/>
                        <Button Content="&#xE787;" ToolTip="Sessions" Command="{Binding NavigateCommand}" CommandParameter="Sessions" Style="{StaticResource RailBtn}"/>
                        <Button Content="&#xE9D2;" ToolTip="Results" Command="{Binding NavigateCommand}" CommandParameter="Results" Style="{StaticResource RailBtn}"/>
                        <Button Content="&#xE9D9;" ToolTip="Reports" Command="{Binding NavigateCommand}" CommandParameter="Reports" Style="{StaticResource RailBtn}"/>
                        <Button Content="&#xE7ED;" ToolTip="Notifications" Command="{Binding NavigateCommand}" CommandParameter="Notifications" Style="{StaticResource RailBtn}"/>
                        <Button Content="&#xE713;" ToolTip="Settings" Command="{Binding NavigateCommand}" CommandParameter="Settings" Style="{StaticResource RailBtn}"/>
                    </StackPanel>
                </ScrollViewer>
                <!-- Server dot at bottom -->
                <Button Grid.Row="2" Command="{Binding ToggleServerCommand}" ToolTip="Start/Stop Server"
                        Style="{StaticResource RailBtn}" HorizontalAlignment="Center" Margin="0,0,0,12">
                    <Ellipse Width="10" Height="10" Fill="{Binding ServerRunning, Converter={StaticResource BoolToColor}}"/>
                </Button>
            </Grid>
        </Border>

        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="74"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="{DynamicResource CardBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1" Padding="26,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    
                    <!-- Breadcrumb and Quick Actions -->
                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="{Binding CurrentPath}" FontWeight="Bold" FontSize="26" Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center" Margin="0,0,24,0"/>
                        
                        <ToggleButton x:Name="QuickActionsToggle" Background="{DynamicResource FieldBg}" Foreground="{DynamicResource TextPrimaryBrush}" BorderBrush="{DynamicResource FieldBorder}" BorderThickness="1" Padding="16,8" VerticalAlignment="Center" Cursor="Hand">
                            <ToggleButton.Template>
                                <ControlTemplate TargetType="ToggleButton">
                                    <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="8" Padding="{TemplateBinding Padding}">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsChecked" Value="True">
                                            <Setter Property="Background" Value="{DynamicResource CardBrush}"/>
                                            <Setter Property="BorderBrush" Value="#10B981"/>
                                        </Trigger>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="{DynamicResource CardBrush}"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </ToggleButton.Template>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Quick Actions" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <TextBlock Text="&#xE70D;" FontFamily="Segoe MDL2 Assets" FontSize="10" VerticalAlignment="Center" FontWeight="Bold"/>
                            </StackPanel>
                        </ToggleButton>
                        
                        <Popup IsOpen="{Binding IsChecked, ElementName=QuickActionsToggle}" StaysOpen="False" PlacementTarget="{Binding ElementName=QuickActionsToggle}" Placement="Bottom" VerticalOffset="8">
                            <Border Background="{DynamicResource CardBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="8" Padding="4" Width="200">
                                <Border.Effect>
                                    <DropShadowEffect BlurRadius="15" ShadowDepth="4" Opacity="0.15" Direction="270" Color="Black"/>
                                </Border.Effect>
                                <StackPanel>
                                    <Button Command="{Binding NavigateCommand}" CommandParameter="Students" Background="Transparent" BorderThickness="0" HorizontalContentAlignment="Left" Padding="12,10" Cursor="Hand" Foreground="{DynamicResource TextPrimaryBrush}">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                                                    <ContentPresenter/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="{DynamicResource FieldBg}"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Button.Template>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="&#xE77B;" FontFamily="Segoe MDL2 Assets" FontSize="14" Margin="0,0,10,0" Foreground="#10B981"/>
                                            <TextBlock Text="Register Student" FontSize="13" FontWeight="Medium"/>
                                        </StackPanel>
                                    </Button>
                                    
                                    <Button Command="{Binding NavigateCommand}" CommandParameter="Questions" Background="Transparent" BorderThickness="0" HorizontalContentAlignment="Left" Padding="12,10" Cursor="Hand" Foreground="{DynamicResource TextPrimaryBrush}">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                                                    <ContentPresenter/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="{DynamicResource FieldBg}"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Button.Template>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="&#xE8D3;" FontFamily="Segoe MDL2 Assets" FontSize="14" Margin="0,0,10,0" Foreground="#3B82F6"/>
                                            <TextBlock Text="Import Questions" FontSize="13" FontWeight="Medium"/>
                                        </StackPanel>
                                    </Button>

                                    <Button Command="{Binding NavigateCommand}" CommandParameter="Sessions" Background="Transparent" BorderThickness="0" HorizontalContentAlignment="Left" Padding="12,10" Cursor="Hand" Foreground="{DynamicResource TextPrimaryBrush}">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                                                    <ContentPresenter/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="{DynamicResource FieldBg}"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Button.Template>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="&#xE81C;" FontFamily="Segoe MDL2 Assets" FontSize="14" Margin="0,0,10,0" Foreground="#F59E0B"/>
                                            <TextBlock Text="Manage Sessions" FontSize="13" FontWeight="Medium"/>
                                        </StackPanel>
                                    </Button>
                                    
                                    <Border Height="1" Background="{DynamicResource BorderBrush}" Margin="4,4"/>
                                    
                                    <Button Command="{Binding ToggleServerCommand}" Background="Transparent" BorderThickness="0" HorizontalContentAlignment="Left" Padding="12,10" Cursor="Hand" Foreground="{DynamicResource TextPrimaryBrush}">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                                                    <ContentPresenter/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="{DynamicResource FieldBg}"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Button.Template>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="&#xE7E8;" FontFamily="Segoe MDL2 Assets" FontSize="14" Margin="0,0,10,0" Foreground="#EF4444"/>
                                            <TextBlock Text="Toggle Server" FontSize="13" FontWeight="Medium"/>
                                        </StackPanel>
                                    </Button>
                                </StackPanel>
                            </Border>
                        </Popup>
                    </StackPanel>

                    <!-- Live Metric Ticker -->
                    <Border Grid.Column="1" Background="{DynamicResource FieldBg}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="8" Padding="16,8" Margin="40,0" HorizontalAlignment="Center" VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <TextBlock Text="&#xE81C;" FontFamily="Segoe MDL2 Assets" FontSize="16" Foreground="#10B981" VerticalAlignment="Center" Margin="0,0,10,0"/>
                            <TextBlock Text="{Binding LiveMetricText}" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="14" FontWeight="Medium" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <!-- User Profile and Actions -->
                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                        <Button Style="{StaticResource NavBtn}" Padding="10" ToolTip="Theme" Command="{Binding ToggleThemeCommand}">
                            <TextBlock Text="&#xE706;" FontFamily="Segoe MDL2 Assets" FontSize="16"/>
                        </Button>
                        <Grid Margin="8,0">
                            <Button Style="{StaticResource NavBtn}" Padding="10" ToolTip="Notifications" Command="{Binding OpenNotificationsCommand}">
                                <TextBlock Text="&#xE7ED;" FontFamily="Segoe MDL2 Assets" FontSize="16"/>
                            </Button>
                            <Border Width="18" Height="18" CornerRadius="9" Background="#F59E0B"
                                    HorizontalAlignment="Right" VerticalAlignment="Top">
                                <TextBlock Text="{Binding NotificationCount}" Foreground="White" FontSize="10" FontWeight="Bold"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </Grid>
                        <Border Width="40" Height="40" CornerRadius="20" Background="{DynamicResource AccentBrush}" Margin="8,0,12,0">
                            <TextBlock Text="A" Foreground="White" FontWeight="Bold" FontSize="18"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="Admin User" FontSize="14" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                            <TextBlock Text="Super Administrator" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}"/>
                        </StackPanel>
                        <TextBlock Text="&#xE70D;" FontFamily="Segoe MDL2 Assets" Foreground="{DynamicResource TextSecondaryBrush}" Margin="10,0,0,0"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Grid>
            </Border>

            <ContentControl Grid.Row="1" Content="{Binding CurrentPage, Mode=OneWay}">
                <ContentControl.Resources>
                    <DataTemplate DataType="{x:Type vm:DashboardViewModel}"><views:DashboardView/></DataTemplate>
                    <DataTemplate DataType="{x:Type vm:CreateExamViewModel}"><views:CreateExamView/></DataTemplate>
                    <DataTemplate DataType="{x:Type vm:ExamsViewModel}"><views:ExamsView/></DataTemplate>
                    <DataTemplate DataType="{x:Type vm:QuestionsViewModel}"><views:QuestionsView/></DataTemplate>
                    <DataTemplate DataType="{x:Type vm:SearchResultsViewModel}"><views:SearchResultsView/></DataTemplate>
                    <DataTemplate DataType="{x:Type vm:ErrorGuideViewModel}"><views:ErrorGuideView/></DataTemplate>
                    <DataTemplate DataType="{x:Type vm:SessionViewModel}"><views:SessionView/></DataTemplate>
                    <DataTemplate DataType="{x:Type vm:MonitorViewModel}"><views:MonitorView/></DataTemplate>
                    <DataTemplate DataType="{x:Type vm:StudentsViewModel}"><views:StudentsView/></DataTemplate>
                    <DataTemplate DataType="{x:Type vm:DevicesViewModel}"><views:DevicesView/></DataTemplate>
                    <DataTemplate DataType="{x:Type vm:ResultsViewModel}"><views:ResultsView/></DataTemplate>
                    <DataTemplate DataType="{x:Type vm:ReportsViewModel}"><views:ReportsView/></DataTemplate>
                    <DataTemplate DataType="{x:Type vm:NotificationsViewModel}"><views:NotificationsView/></DataTemplate>
                    <DataTemplate DataType="{x:Type vm:SettingsViewModel}"><views:SettingsView/></DataTemplate>
                </ContentControl.Resources>
                <ContentControl.Style>
                    <Style TargetType="ContentControl">
                        <Setter Property="Opacity" Value="1"/>
                        <Style.Triggers>
                            <Trigger Property="Content" Value="{x:Null}">
                                <Setter Property="Opacity" Value="0"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </ContentControl.Style>
            </ContentControl>
        </Grid>
    </Grid>
</Window>
