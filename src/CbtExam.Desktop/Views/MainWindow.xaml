<Window x:Class="CbtExam.Desktop.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:CbtExam.Desktop.ViewModels"
        xmlns:views="clr-namespace:CbtExam.Desktop.Views"
        Title="CBT Exam System - Admin" Height="720" Width="1240"
        MinHeight="640" MinWidth="1080"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BgBrush}"
        FontFamily="Segoe UI"
        Loaded="Window_Loaded">

    <Window.DataContext>
        <vm:MainViewModel/>
    </Window.DataContext>

    <Window.Resources>
        <Style x:Key="SidebarOnlyWhenOpen" TargetType="Border">
            <Setter Property="Visibility" Value="Visible"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding SidebarOpen}" Value="False">
                    <Setter Property="Visibility" Value="Collapsed"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="RailOnlyWhenClosed" TargetType="Border">
            <Setter Property="Visibility" Value="Collapsed"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding SidebarOpen}" Value="False">
                    <Setter Property="Visibility" Value="Visible"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="SideIcon" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe MDL2 Assets"/>
            <Setter Property="FontSize" Value="17"/>
            <Setter Property="Width" Value="28"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style x:Key="SideLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style x:Key="RailBtn" TargetType="Button" BasedOn="{StaticResource NavBtn}">
            <Setter Property="Width" Value="44"/>
            <Setter Property="Height" Value="42"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="FontFamily" Value="Segoe MDL2 Assets"/>
            <Setter Property="FontSize" Value="16"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="{Binding SidebarWidth, Mode=OneWay}"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="White" BorderBrush="#E5E7EB" BorderThickness="0,0,1,0"
                Style="{StaticResource SidebarOnlyWhenOpen}">
            <DockPanel>
                <Border DockPanel.Dock="Top" Padding="16,18" BorderBrush="#E5E7EB" BorderThickness="0,0,0,1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Border Width="42" Height="42" CornerRadius="12" Background="#ECFDF5" BorderBrush="#BBF7D0" BorderThickness="1">
                            <TextBlock Text="CB" FontWeight="Bold" Foreground="#047857" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel Grid.Column="1" Margin="10,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="CBT Exam System" FontSize="16" FontWeight="Bold" Foreground="#111827"/>
                            <TextBlock Text="Admin Console" FontSize="12" Foreground="#6B7280"/>
                        </StackPanel>
                        <Button Grid.Column="2" Command="{Binding ToggleSidebarCommand}" Style="{StaticResource NavBtn}"
                                Padding="6" ToolTip="Collapse sidebar">
                            <TextBlock Text="&#xE72B;" FontFamily="Segoe MDL2 Assets"/>
                        </Button>
                    </Grid>
                </Border>

                <Border DockPanel.Dock="Bottom" Margin="12" Padding="12" CornerRadius="10"
                        Background="#FFFFFF" BorderBrush="#E5E7EB" BorderThickness="1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Border Width="34" Height="34" CornerRadius="17" Background="#059669">
                            <TextBlock Text="A" Foreground="White" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel Grid.Column="1" Margin="10,0,0,0">
                            <TextBlock Text="Admin User" FontSize="12" FontWeight="Bold" Foreground="#111827"/>
                            <TextBlock Text="Super Administrator" FontSize="11" Foreground="#6B7280"/>
                        </StackPanel>
                        <TextBlock Grid.Column="2" Text="&#xE70D;" FontFamily="Segoe MDL2 Assets" Foreground="#6B7280" VerticalAlignment="Center"/>
                    </Grid>
                </Border>

                <StackPanel Margin="8,18,8,0">
                    <Button Command="{Binding NavigateCommand}" CommandParameter="Dashboard" HorizontalAlignment="Stretch" ToolTip="Dashboard">
                        <Button.Style><Style TargetType="Button" BasedOn="{StaticResource NavBtn}"><Setter Property="Padding" Value="14,13"/><Setter Property="Foreground" Value="#111827"/><Style.Triggers><DataTrigger Binding="{Binding CurrentPageKey}" Value="Dashboard"><Setter Property="Background" Value="#ECFDF5"/><Setter Property="Foreground" Value="#047857"/></DataTrigger></Style.Triggers></Style></Button.Style>
                        <StackPanel Orientation="Horizontal"><TextBlock Text="&#xE80F;" Style="{StaticResource SideIcon}"/><TextBlock Text="Dashboard" Style="{StaticResource SideLabel}"/></StackPanel>
                    </Button>
                    <Button Command="{Binding NavigateCommand}" CommandParameter="Exams" HorizontalAlignment="Stretch" ToolTip="Exams">
                        <Button.Style><Style TargetType="Button" BasedOn="{StaticResource NavBtn}"><Setter Property="Padding" Value="14,13"/><Setter Property="Foreground" Value="#111827"/><Style.Triggers><DataTrigger Binding="{Binding CurrentPageKey}" Value="Exams"><Setter Property="Background" Value="#ECFDF5"/><Setter Property="Foreground" Value="#047857"/></DataTrigger></Style.Triggers></Style></Button.Style>
                        <StackPanel Orientation="Horizontal"><TextBlock Text="&#xE8A5;" Style="{StaticResource SideIcon}"/><TextBlock Text="Exams" Style="{StaticResource SideLabel}"/></StackPanel>
                    </Button>
                    <Button Command="{Binding NavigateCommand}" CommandParameter="Students" HorizontalAlignment="Stretch" ToolTip="Students">
                        <Button.Style><Style TargetType="Button" BasedOn="{StaticResource NavBtn}"><Setter Property="Padding" Value="14,13"/><Setter Property="Foreground" Value="#111827"/><Style.Triggers><DataTrigger Binding="{Binding CurrentPageKey}" Value="Students"><Setter Property="Background" Value="#ECFDF5"/><Setter Property="Foreground" Value="#047857"/></DataTrigger></Style.Triggers></Style></Button.Style>
                        <StackPanel Orientation="Horizontal"><TextBlock Text="&#xE716;" Style="{StaticResource SideIcon}"/><TextBlock Text="Students" Style="{StaticResource SideLabel}"/></StackPanel>
                    </Button>
                    <Button Command="{Binding NavigateCommand}" CommandParameter="Sessions" HorizontalAlignment="Stretch" ToolTip="Sessions">
                        <Button.Style><Style TargetType="Button" BasedOn="{StaticResource NavBtn}"><Setter Property="Padding" Value="14,13"/><Setter Property="Foreground" Value="#111827"/><Style.Triggers><DataTrigger Binding="{Binding CurrentPageKey}" Value="Sessions"><Setter Property="Background" Value="#ECFDF5"/><Setter Property="Foreground" Value="#047857"/></DataTrigger></Style.Triggers></Style></Button.Style>
                        <StackPanel Orientation="Horizontal"><TextBlock Text="&#xE787;" Style="{StaticResource SideIcon}"/><TextBlock Text="Sessions" Style="{StaticResource SideLabel}"/></StackPanel>
                    </Button>
                    <Button Command="{Binding NavigateCommand}" CommandParameter="Results" HorizontalAlignment="Stretch" ToolTip="Results">
                        <Button.Style><Style TargetType="Button" BasedOn="{StaticResource NavBtn}"><Setter Property="Padding" Value="14,13"/><Setter Property="Foreground" Value="#111827"/><Style.Triggers><DataTrigger Binding="{Binding CurrentPageKey}" Value="Results"><Setter Property="Background" Value="#ECFDF5"/><Setter Property="Foreground" Value="#047857"/></DataTrigger></Style.Triggers></Style></Button.Style>
                        <StackPanel Orientation="Horizontal"><TextBlock Text="&#xE9D2;" Style="{StaticResource SideIcon}"/><TextBlock Text="Results" Style="{StaticResource SideLabel}"/></StackPanel>
                    </Button>
                    <Button Command="{Binding NavigateCommand}" CommandParameter="Reports" HorizontalAlignment="Stretch" ToolTip="Reports">
                        <Button.Style><Style TargetType="Button" BasedOn="{StaticResource NavBtn}"><Setter Property="Padding" Value="14,13"/><Setter Property="Foreground" Value="#111827"/><Style.Triggers><DataTrigger Binding="{Binding CurrentPageKey}" Value="Reports"><Setter Property="Background" Value="#ECFDF5"/><Setter Property="Foreground" Value="#047857"/></DataTrigger></Style.Triggers></Style></Button.Style>
                        <StackPanel Orientation="Horizontal"><TextBlock Text="&#xE9D9;" Style="{StaticResource SideIcon}"/><TextBlock Text="Reports" Style="{StaticResource SideLabel}"/></StackPanel>
                    </Button>
                    <Button Command="{Binding NavigateCommand}" CommandParameter="Settings" HorizontalAlignment="Stretch" ToolTip="Settings">
                        <Button.Style><Style TargetType="Button" BasedOn="{StaticResource NavBtn}"><Setter Property="Padding" Value="14,13"/><Setter Property="Foreground" Value="#111827"/><Style.Triggers><DataTrigger Binding="{Binding CurrentPageKey}" Value="Settings"><Setter Property="Background" Value="#ECFDF5"/><Setter Property="Foreground" Value="#047857"/></DataTrigger></Style.Triggers></Style></Button.Style>
                        <StackPanel Orientation="Horizontal"><TextBlock Text="&#xE713;" Style="{StaticResource SideIcon}"/><TextBlock Text="Settings" Style="{StaticResource SideLabel}"/></StackPanel>
                    </Button>
                </StackPanel>
            </DockPanel>
        </Border>

        <Border Grid.Column="0" Background="White" BorderBrush="#E5E7EB" BorderThickness="0,0,1,0"
                Style="{StaticResource RailOnlyWhenClosed}">
            <DockPanel>
                <Button DockPanel.Dock="Top" Command="{Binding ToggleSidebarCommand}" Content="&#xE72A;"
                        ToolTip="Expand sidebar" Style="{StaticResource RailBtn}" Margin="10,16,10,12"/>
                <StackPanel Margin="10,8,10,0">
                    <Button Content="&#xE80F;" ToolTip="Dashboard" Command="{Binding NavigateCommand}" CommandParameter="Dashboard" Style="{StaticResource RailBtn}"/>
                    <Button Content="&#xE8A5;" ToolTip="Exams" Command="{Binding NavigateCommand}" CommandParameter="Exams" Style="{StaticResource RailBtn}"/>
                    <Button Content="&#xE716;" ToolTip="Students" Command="{Binding NavigateCommand}" CommandParameter="Students" Style="{StaticResource RailBtn}"/>
                    <Button Content="&#xE787;" ToolTip="Sessions" Command="{Binding NavigateCommand}" CommandParameter="Sessions" Style="{StaticResource RailBtn}"/>
                    <Button Content="&#xE9D2;" ToolTip="Results" Command="{Binding NavigateCommand}" CommandParameter="Results" Style="{StaticResource RailBtn}"/>
                    <Button Content="&#xE9D9;" ToolTip="Reports" Command="{Binding NavigateCommand}" CommandParameter="Reports" Style="{StaticResource RailBtn}"/>
                    <Button Content="&#xE713;" ToolTip="Settings" Command="{Binding NavigateCommand}" CommandParameter="Settings" Style="{StaticResource RailBtn}"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="74"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="White" BorderBrush="#E5E7EB" BorderThickness="0,0,0,1" Padding="26,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="360"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Grid Grid.Column="1" VerticalAlignment="Center" Height="42">
                        <TextBox Padding="40,8,12,8"/>
                        <TextBlock Text="&#xE721;" FontFamily="Segoe MDL2 Assets" FontSize="15" Foreground="#6B7280"
                                   VerticalAlignment="Center" HorizontalAlignment="Left" Margin="14,0,0,0"/>
                        <TextBlock Text="Search anything..." Foreground="#6B7280" FontSize="13"
                                   VerticalAlignment="Center" HorizontalAlignment="Left" Margin="40,0,0,0"
                                   IsHitTestVisible="False"/>
                    </Grid>
                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" Margin="24,0,0,0">
                        <Button Style="{StaticResource NavBtn}" Padding="10" ToolTip="Theme">
                            <TextBlock Text="&#xE706;" FontFamily="Segoe MDL2 Assets" FontSize="16"/>
                        </Button>
                        <Grid Margin="8,0">
                            <Button Style="{StaticResource NavBtn}" Padding="10" ToolTip="Notifications">
                                <TextBlock Text="&#xE7ED;" FontFamily="Segoe MDL2 Assets" FontSize="16"/>
                            </Button>
                            <Border Width="18" Height="18" CornerRadius="9" Background="#F59E0B"
                                    HorizontalAlignment="Right" VerticalAlignment="Top">
                                <TextBlock Text="3" Foreground="White" FontSize="10" FontWeight="Bold"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </Grid>
                        <Border Width="36" Height="36" CornerRadius="18" Background="#059669" Margin="8,0,10,0">
                            <TextBlock Text="A" Foreground="White" FontWeight="Bold" FontSize="16"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="Admin User" FontSize="12" FontWeight="Bold" Foreground="#111827"/>
                            <TextBlock Text="Super Administrator" FontSize="11" Foreground="#6B7280"/>
                        </StackPanel>
                        <TextBlock Text="&#xE70D;" FontFamily="Segoe MDL2 Assets" Foreground="#111827" Margin="10,0,0,0"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Grid>
            </Border>

            <ContentControl Grid.Row="1" Content="{Binding CurrentPage, Mode=OneWay}">
                <ContentControl.Resources>
                    <DataTemplate DataType="{x:Type vm:DashboardViewModel}"><views:DashboardView/></DataTemplate>
                    <DataTemplate DataType="{x:Type vm:CreateExamViewModel}"><views:CreateExamView/></DataTemplate>
                    <DataTemplate DataType="{x:Type vm:ExamsViewModel}"><views:ExamsView/></DataTemplate>
                    <DataTemplate DataType="{x:Type vm:SessionViewModel}"><views:SessionView/></DataTemplate>
                    <DataTemplate DataType="{x:Type vm:MonitorViewModel}"><views:MonitorView/></DataTemplate>
                    <DataTemplate DataType="{x:Type vm:DevicesViewModel}"><views:DevicesView/></DataTemplate>
                    <DataTemplate DataType="{x:Type vm:ResultsViewModel}"><views:ResultsView/></DataTemplate>
                    <DataTemplate DataType="{x:Type vm:ReportsViewModel}"><views:ReportsView/></DataTemplate>
                    <DataTemplate DataType="{x:Type vm:SettingsViewModel}"><views:SettingsView/></DataTemplate>
                </ContentControl.Resources>
            </ContentControl>
        </Grid>
    </Grid>
</Window>
