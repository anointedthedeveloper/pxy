<Window x:Class="CbtExam.Desktop.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:CbtExam.Desktop.ViewModels"
        xmlns:views="clr-namespace:CbtExam.Desktop.Views"
        Title="CBT Exam System - Admin" Height="720" Width="1240"
        MinHeight="640" MinWidth="1080"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized"
        Background="{DynamicResource BgBrush}"
        Icon="pack://application:,,,/Resources/appicon.ico"
        FontFamily="Segoe UI"
        Loaded="Window_Loaded">

    <Window.DataContext>
        <vm:MainViewModel/>
    </Window.DataContext>

    <Window.Resources>
        <Style x:Key="SidebarOnlyWhenOpen" TargetType="Border">
            <Setter Property="Visibility" Value="Visible"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding SidebarOpen}" Value="False">
                    <Setter Property="Visibility" Value="Collapsed"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="RailOnlyWhenClosed" TargetType="Border">
            <Setter Property="Visibility" Value="Collapsed"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding SidebarOpen}" Value="False">
                    <Setter Property="Visibility" Value="Visible"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="SideIcon" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe MDL2 Assets"/>
            <Setter Property="FontSize" Value="17"/>
            <Setter Property="Width" Value="28"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style x:Key="SideLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style x:Key="RailBtn" TargetType="Button" BasedOn="{StaticResource NavBtn}">
            <Setter Property="Width" Value="44"/>
            <Setter Property="Height" Value="42"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="FontFamily" Value="Segoe MDL2 Assets"/>
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                CornerRadius="8" Margin="0,2" Padding="0"
                                Width="44" Height="42">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center">
                                <ContentPresenter.Resources>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="TextAlignment" Value="Center"/>
                                    </Style>
                                </ContentPresenter.Resources>
                            </ContentPresenter>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{DynamicResource NavHoverBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="{Binding SidebarWidth, Mode=OneWay}"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="{DynamicResource CardBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,1,0"
                Style="{StaticResource SidebarOnlyWhenOpen}">
            <DockPanel>
                <Border DockPanel.Dock="Top" Padding="16,24" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Border Width="48" Height="48" CornerRadius="14" Background="{DynamicResource PremiumGradient}">
                            <Image Source="pack://application:,,,/Resources/prep4jamb.png" Width="32" Height="32" RenderOptions.BitmapScalingMode="HighQuality" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                        </Border>
                        <StackPanel Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="CBT Exam" FontSize="18" FontWeight="Black" Foreground="{DynamicResource TextPrimaryBrush}"/>
                            <TextBlock Text="Admin Console" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" FontWeight="SemiBold"/>
                        </StackPanel>
                        <Button Grid.Column="2" Command="{Binding ToggleSidebarCommand}" Style="{StaticResource NavBtn}"
                                Padding="8" ToolTip="Collapse sidebar" VerticalAlignment="Center">
                            <TextBlock Text="&#xE76B;" FontFamily="Segoe MDL2 Assets" FontSize="14"/>
                        </Button>
                    </Grid>
                </Border>

                <!-- Sidebar Body -->
                <ScrollViewer DockPanel.Dock="Top" Style="{StaticResource AutoHidingScrollViewer}" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Padding="0,0,0,0">
                    <StackPanel Margin="12,24,12,0">
                        <TextBlock Text="MAIN MENU" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource TextSecondaryBrush}" Margin="14,0,0,12" Opacity="0.6"/>
                        
                        <Button Command="{Binding NavigateCommand}" CommandParameter="Dashboard" HorizontalAlignment="Stretch" ToolTip="Dashboard">
                            <Button.Style><Style TargetType="Button" BasedOn="{StaticResource NavBtn}"><Setter Property="Padding" Value="14,13"/><Setter Property="Margin" Value="0,2"/><Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/><Style.Triggers><DataTrigger Binding="{Binding CurrentPageKey}" Value="Dashboard"><Setter Property="Background" Value="{DynamicResource NavActiveBrush}"/><Setter Property="Foreground" Value="{DynamicResource NavActiveFgBrush}"/></DataTrigger></Style.Triggers></Style></Button.Style>
                            <StackPanel Orientation="Horizontal"><TextBlock Text="&#xE80F;" Style="{StaticResource SideIcon}"/><TextBlock Text="Dashboard" Style="{StaticResource SideLabel}"/></StackPanel>
                        </Button>
                        <Button Command="{Binding NavigateCommand}" CommandParameter="Exams" HorizontalAlignment="Stretch" ToolTip="Exams">
                            <Button.Style><Style TargetType="Button" BasedOn="{StaticResource NavBtn}"><Setter Property="Padding" Value="14,13"/><Setter Property="Margin" Value="0,2"/><Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/><Style.Triggers><DataTrigger Binding="{Binding CurrentPageKey}" Value="Exams"><Setter Property="Background" Value="{DynamicResource NavActiveBrush}"/><Setter Property="Foreground" Value="{DynamicResource NavActiveFgBrush}"/></DataTrigger></Style.Triggers></Style></Button.Style>
                            <StackPanel Orientation="Horizontal"><TextBlock Text="&#xE82D;" Style="{StaticResource SideIcon}"/><TextBlock Text="Exams" Style="{StaticResource SideLabel}"/></StackPanel>
                        </Button>
                        <Button Command="{Binding NavigateCommand}" CommandParameter="Questions" HorizontalAlignment="Stretch" ToolTip="Questions">
                            <Button.Style><Style TargetType="Button" BasedOn="{StaticResource NavBtn}"><Setter Property="Padding" Value="14,13"/><Setter Property="Margin" Value="0,2"/><Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/><Style.Triggers><DataTrigger Binding="{Binding CurrentPageKey}" Value="Questions"><Setter Property="Background" Value="{DynamicResource NavActiveBrush}"/><Setter Property="Foreground" Value="{DynamicResource NavActiveFgBrush}"/></DataTrigger></Style.Triggers></Style></Button.Style>
                            <StackPanel Orientation="Horizontal"><TextBlock Text="&#xE897;" Style="{StaticResource SideIcon}"/><TextBlock Text="Questions" Style="{StaticResource SideLabel}"/></StackPanel>
                        </Button>
                        <Button Command="{Binding NavigateCommand}" CommandParameter="Students" HorizontalAlignment="Stretch" ToolTip="Students">
                            <Button.Style><Style TargetType="Button" BasedOn="{StaticResource NavBtn}"><Setter Property="Padding" Value="14,13"/><Setter Property="Margin" Value="0,2"/><Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/><Style.Triggers><DataTrigger Binding="{Binding CurrentPageKey}" Value="Students"><Setter Property="Background" Value="{DynamicResource NavActiveBrush}"/><Setter Property="Foreground" Value="{DynamicResource NavActiveFgBrush}"/></DataTrigger></Style.Triggers></Style></Button.Style>
                            <StackPanel Orientation="Horizontal"><TextBlock Text="&#xE716;" Style="{StaticResource SideIcon}"/><TextBlock Text="Students" Style="{StaticResource SideLabel}"/></StackPanel>
                        </Button>
                        <Button Command="{Binding NavigateCommand}" CommandParameter="Devices" HorizontalAlignment="Stretch" ToolTip="Connected Devices">
                            <Button.Style><Style TargetType="Button" BasedOn="{StaticResource NavBtn}"><Setter Property="Padding" Value="14,13"/><Setter Property="Margin" Value="0,2"/><Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/><Style.Triggers><DataTrigger Binding="{Binding CurrentPageKey}" Value="Devices"><Setter Property="Background" Value="{DynamicResource NavActiveBrush}"/><Setter Property="Foreground" Value="{DynamicResource NavActiveFgBrush}"/></DataTrigger></Style.Triggers></Style></Button.Style>
                            <StackPanel Orientation="Horizontal"><TextBlock Text="&#xE964;" Style="{StaticResource SideIcon}"/><TextBlock Text="Devices" Style="{StaticResource SideLabel}"/></StackPanel>
                        </Button>
                        <Button Command="{Binding NavigateCommand}" CommandParameter="Sessions" HorizontalAlignment="Stretch" ToolTip="Sessions">
                            <Button.Style><Style TargetType="Button" BasedOn="{StaticResource NavBtn}"><Setter Property="Padding" Value="14,13"/><Setter Property="Margin" Value="0,2"/><Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/><Style.Triggers><DataTrigger Binding="{Binding CurrentPageKey}" Value="Sessions"><Setter Property="Background" Value="{DynamicResource NavActiveBrush}"/><Setter Property="Foreground" Value="{DynamicResource NavActiveFgBrush}"/></DataTrigger></Style.Triggers></Style></Button.Style>
                            <StackPanel Orientation="Horizontal"><TextBlock Text="&#xE8F9;" Style="{StaticResource SideIcon}"/><TextBlock Text="Sessions" Style="{StaticResource SideLabel}"/></StackPanel>
                        </Button>

                        <TextBlock Text="ANALYTICS" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource TextSecondaryBrush}" Margin="14,24,0,12" Opacity="0.6"/>
                        <Button Command="{Binding NavigateCommand}" CommandParameter="Results" HorizontalAlignment="Stretch" ToolTip="Results">
                            <Button.Style><Style TargetType="Button" BasedOn="{StaticResource NavBtn}"><Setter Property="Padding" Value="14,13"/><Setter Property="Margin" Value="0,2"/><Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/><Style.Triggers><DataTrigger Binding="{Binding CurrentPageKey}" Value="Results"><Setter Property="Background" Value="{DynamicResource NavActiveBrush}"/><Setter Property="Foreground" Value="{DynamicResource NavActiveFgBrush}"/></DataTrigger></Style.Triggers></Style></Button.Style>
                            <StackPanel Orientation="Horizontal"><TextBlock Text="&#xE9D2;" Style="{StaticResource SideIcon}"/><TextBlock Text="Results" Style="{StaticResource SideLabel}"/></StackPanel>
                        </Button>
                        <Button Command="{Binding NavigateCommand}" CommandParameter="Reports" HorizontalAlignment="Stretch" ToolTip="Reports">
                            <Button.Style><Style TargetType="Button" BasedOn="{StaticResource NavBtn}"><Setter Property="Padding" Value="14,13"/><Setter Property="Margin" Value="0,2"/><Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/><Style.Triggers><DataTrigger Binding="{Binding CurrentPageKey}" Value="Reports"><Setter Property="Background" Value="{DynamicResource NavActiveBrush}"/><Setter Property="Foreground" Value="{DynamicResource NavActiveFgBrush}"/></DataTrigger></Style.Triggers></Style></Button.Style>
                            <StackPanel Orientation="Horizontal"><TextBlock Text="&#xE9D9;" Style="{StaticResource SideIcon}"/><TextBlock Text="Reports" Style="{StaticResource SideLabel}"/></StackPanel>
                        </Button>

                        <TextBlock Text="SYSTEM" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource TextSecondaryBrush}" Margin="14,24,0,12" Opacity="0.6"/>
                        <Button Command="{Binding NavigateCommand}" CommandParameter="Notifications" HorizontalAlignment="Stretch" ToolTip="Notifications">
                            <Button.Style><Style TargetType="Button" BasedOn="{StaticResource NavBtn}"><Setter Property="Padding" Value="14,13"/><Setter Property="Margin" Value="0,2"/><Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/><Style.Triggers><DataTrigger Binding="{Binding CurrentPageKey}" Value="Notifications"><Setter Property="Background" Value="{DynamicResource NavActiveBrush}"/><Setter Property="Foreground" Value="{DynamicResource NavActiveFgBrush}"/></DataTrigger></Style.Triggers></Style></Button.Style>
                            <StackPanel Orientation="Horizontal"><TextBlock Text="&#xE7ED;" Style="{StaticResource SideIcon}"/><TextBlock Text="Notifications" Style="{StaticResource SideLabel}"/></StackPanel>
                        </Button>
                        <Button Command="{Binding NavigateCommand}" CommandParameter="Settings" HorizontalAlignment="Stretch" ToolTip="Settings">
                            <Button.Style><Style TargetType="Button" BasedOn="{StaticResource NavBtn}"><Setter Property="Padding" Value="14,13"/><Setter Property="Margin" Value="0,2"/><Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/><Style.Triggers><DataTrigger Binding="{Binding CurrentPageKey}" Value="Settings"><Setter Property="Background" Value="{DynamicResource NavActiveBrush}"/><Setter Property="Foreground" Value="{DynamicResource NavActiveFgBrush}"/></DataTrigger></Style.Triggers></Style></Button.Style>
                            <StackPanel Orientation="Horizontal"><TextBlock Text="&#xE713;" Style="{StaticResource SideIcon}"/><TextBlock Text="Settings" Style="{StaticResource SideLabel}"/></StackPanel>
                        </Button>
                    </StackPanel>
                </ScrollViewer>

                <Border DockPanel.Dock="Bottom" Margin="12,12,12,12" Padding="16" CornerRadius="16"
                        BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Background" Value="#F8FAFC"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding ServerRunning}" Value="False">
                                    <Setter Property="Background" Value="#FEF2F2"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding ServerRunning}" Value="True">
                                    <Setter Property="Background" Value="#F0FDF4"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <StackPanel>
                        <TextBlock Text="SERVER STATUS" FontSize="10" FontWeight="Black" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,10" Opacity="0.5"/>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                            <Border Width="10" Height="10" CornerRadius="5" VerticalAlignment="Center" Margin="0,0,10,0"
                                     Background="{Binding ServerRunning, Converter={StaticResource BoolToColor}}">
                                <Border.Effect>
                                    <DropShadowEffect BlurRadius="8" ShadowDepth="0" Color="{Binding ServerRunning, Converter={StaticResource BoolToColor}}" Opacity="0.6"/>
                                </Border.Effect>
                            </Border>
                            <TextBlock Text="{Binding ServerStatusText}" FontSize="13" FontWeight="Bold" VerticalAlignment="Center"
                                       Foreground="{Binding ServerRunning, Converter={StaticResource BoolToColor}}"/>
                        </StackPanel>

                        <!-- Server URL Display -->
                        <Border Background="{DynamicResource BgBrush}" CornerRadius="8" Margin="0,0,0,12" Padding="10,6"
                                Visibility="{Binding ServerRunning, Converter={StaticResource BoolToVis}}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="{Binding ServerUrl}" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}" 
                                           VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                <Button Grid.Column="1" Command="{Binding CopyServerUrlCommand}" Background="Transparent" BorderThickness="0"
                                        Padding="4" Margin="6,0,0,0" ToolTip="Copy URL" Cursor="Hand">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="bd" Background="Transparent" CornerRadius="4">
                                                <ContentPresenter/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="bd" Property="Background" Value="{DynamicResource NavHoverBrush}"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>
                                    <TextBlock Text="&#xE8C8;" FontFamily="Segoe MDL2 Assets" FontSize="12" Foreground="{DynamicResource AccentBrush}"/>
                                </Button>
                            </Grid>
                        </Border>
                        
                        <Button Command="{Binding ToggleServerCommand}" HorizontalAlignment="Stretch"
                                Padding="0,10" FontSize="13" FontWeight="Bold" BorderThickness="0" Cursor="Hand">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource PrimaryBtn}">
                                    <Setter Property="Background" Value="#DC2626"/>
                                    <Setter Property="Foreground" Value="White"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding ServerRunning}" Value="False">
                                            <Setter Property="Background" Value="#059669"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                            <Grid>
                                <TextBlock Text="STOP SERVER" Visibility="{Binding ServerRunning, Converter={StaticResource BoolToVis}}"/>
                                <TextBlock Text="START SERVER" Visibility="{Binding ServerRunning, Converter={StaticResource BoolToVisInverse}}"/>
                            </Grid>
                        </Button>
                    </StackPanel>
                </Border>
            </DockPanel>
        </Border>

        <Border Grid.Column="0" Background="{DynamicResource CardBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,1,0"
                Style="{StaticResource RailOnlyWhenClosed}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <!-- Logo + expand toggle -->
                <StackPanel Grid.Row="0" HorizontalAlignment="Center" Margin="0,24,0,12">
                    <Border Width="40" Height="40" CornerRadius="12" Background="{DynamicResource PremiumGradient}" Margin="0,0,0,12">
                        <Image Source="pack://application:,,,/Resources/prep4jamb.png" Width="26" Height="26"
                               RenderOptions.BitmapScalingMode="HighQuality" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <Button Command="{Binding ToggleSidebarCommand}" Style="{StaticResource RailBtn}" HorizontalAlignment="Center" ToolTip="Expand sidebar">
                        <TextBlock Text="&#xE76C;" FontFamily="Segoe MDL2 Assets" FontSize="14"/>
                    </Button>
                </StackPanel>
                <!-- Nav icons -->
                <ScrollViewer Grid.Row="1" Style="{StaticResource AutoHidingScrollViewer}" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,12,0,0">
                        <Button Content="&#xE80F;" ToolTip="Dashboard" Command="{Binding NavigateCommand}" CommandParameter="Dashboard">
                            <Button.Style><Style TargetType="Button" BasedOn="{StaticResource RailBtn}"><Setter Property="Margin" Value="0,4"/><Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/><Style.Triggers><DataTrigger Binding="{Binding CurrentPageKey}" Value="Dashboard"><Setter Property="Background" Value="{DynamicResource NavActiveBrush}"/><Setter Property="Foreground" Value="{DynamicResource NavActiveFgBrush}"/></DataTrigger></Style.Triggers></Style></Button.Style>
                        </Button>
                        <Button Content="&#xE82D;" ToolTip="Exams" Command="{Binding NavigateCommand}" CommandParameter="Exams">
                            <Button.Style><Style TargetType="Button" BasedOn="{StaticResource RailBtn}"><Setter Property="Margin" Value="0,4"/><Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/><Style.Triggers><DataTrigger Binding="{Binding CurrentPageKey}" Value="Exams"><Setter Property="Background" Value="{DynamicResource NavActiveBrush}"/><Setter Property="Foreground" Value="{DynamicResource NavActiveFgBrush}"/></DataTrigger></Style.Triggers></Style></Button.Style>
                        </Button>
                        <Button Content="&#xE897;" ToolTip="Questions" Command="{Binding NavigateCommand}" CommandParameter="Questions">
                            <Button.Style><Style TargetType="Button" BasedOn="{StaticResource RailBtn}"><Setter Property="Margin" Value="0,4"/><Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/><Style.Triggers><DataTrigger Binding="{Binding CurrentPageKey}" Value="Questions"><Setter Property="Background" Value="{DynamicResource NavActiveBrush}"/><Setter Property="Foreground" Value="{DynamicResource NavActiveFgBrush}"/></DataTrigger></Style.Triggers></Style></Button.Style>
                        </Button>
                        <Button Content="&#xE716;" ToolTip="Students" Command="{Binding NavigateCommand}" CommandParameter="Students">
                            <Button.Style><Style TargetType="Button" BasedOn="{StaticResource RailBtn}"><Setter Property="Margin" Value="0,4"/><Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/><Style.Triggers><DataTrigger Binding="{Binding CurrentPageKey}" Value="Students"><Setter Property="Background" Value="{DynamicResource NavActiveBrush}"/><Setter Property="Foreground" Value="{DynamicResource NavActiveFgBrush}"/></DataTrigger></Style.Triggers></Style></Button.Style>
                        </Button>
                        <Button Content="&#xE964;" ToolTip="Devices" Command="{Binding NavigateCommand}" CommandParameter="Devices">
                            <Button.Style><Style TargetType="Button" BasedOn="{StaticResource RailBtn}"><Setter Property="Margin" Value="0,4"/><Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/><Style.Triggers><DataTrigger Binding="{Binding CurrentPageKey}" Value="Devices"><Setter Property="Background" Value="{DynamicResource NavActiveBrush}"/><Setter Property="Foreground" Value="{DynamicResource NavActiveFgBrush}"/></DataTrigger></Style.Triggers></Style></Button.Style>
                        </Button>
                        <Button Content="&#xE8F9;" ToolTip="Sessions" Command="{Binding NavigateCommand}" CommandParameter="Sessions">
                            <Button.Style><Style TargetType="Button" BasedOn="{StaticResource RailBtn}"><Setter Property="Margin" Value="0,4"/><Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/><Style.Triggers><DataTrigger Binding="{Binding CurrentPageKey}" Value="Sessions"><Setter Property="Background" Value="{DynamicResource NavActiveBrush}"/><Setter Property="Foreground" Value="{DynamicResource NavActiveFgBrush}"/></DataTrigger></Style.Triggers></Style></Button.Style>
                        </Button>
                        <Button Content="&#xE9D2;" ToolTip="Results" Command="{Binding NavigateCommand}" CommandParameter="Results">
                            <Button.Style><Style TargetType="Button" BasedOn="{StaticResource RailBtn}"><Setter Property="Margin" Value="0,4"/><Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/><Style.Triggers><DataTrigger Binding="{Binding CurrentPageKey}" Value="Results"><Setter Property="Background" Value="{DynamicResource NavActiveBrush}"/><Setter Property="Foreground" Value="{DynamicResource NavActiveFgBrush}"/></DataTrigger></Style.Triggers></Style></Button.Style>
                        </Button>
                        <Button Content="&#xE9D9;" ToolTip="Reports" Command="{Binding NavigateCommand}" CommandParameter="Reports">
                            <Button.Style><Style TargetType="Button" BasedOn="{StaticResource RailBtn}"><Setter Property="Margin" Value="0,4"/><Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/><Style.Triggers><DataTrigger Binding="{Binding CurrentPageKey}" Value="Reports"><Setter Property="Background" Value="{DynamicResource NavActiveBrush}"/><Setter Property="Foreground" Value="{DynamicResource NavActiveFgBrush}"/></DataTrigger></Style.Triggers></Style></Button.Style>
                        </Button>
                        <Button Content="&#xE7ED;" ToolTip="Notifications" Command="{Binding NavigateCommand}" CommandParameter="Notifications">
                            <Button.Style><Style TargetType="Button" BasedOn="{StaticResource RailBtn}"><Setter Property="Margin" Value="0,4"/><Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/><Style.Triggers><DataTrigger Binding="{Binding CurrentPath}" Value="Notifications"><Setter Property="Background" Value="{DynamicResource NavActiveBrush}"/><Setter Property="Foreground" Value="{DynamicResource NavActiveFgBrush}"/></DataTrigger></Style.Triggers></Style></Button.Style>
                        </Button>
                        <Button Content="&#xE713;" ToolTip="Settings" Command="{Binding NavigateCommand}" CommandParameter="Settings">
                            <Button.Style><Style TargetType="Button" BasedOn="{StaticResource RailBtn}"><Setter Property="Margin" Value="0,4"/><Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/><Style.Triggers><DataTrigger Binding="{Binding CurrentPageKey}" Value="Settings"><Setter Property="Background" Value="{DynamicResource NavActiveBrush}"/><Setter Property="Foreground" Value="{DynamicResource NavActiveFgBrush}"/></DataTrigger></Style.Triggers></Style></Button.Style>
                        </Button>
                    </StackPanel>
                </ScrollViewer>
                <!-- Server dot -->
                <Button Grid.Row="2" Command="{Binding ToggleServerCommand}" ToolTip="Server Status"
                        Style="{StaticResource RailBtn}" HorizontalAlignment="Center" Margin="0,0,0,16">
                    <Border Width="12" Height="12" CornerRadius="6" Background="{Binding ServerRunning, Converter={StaticResource BoolToColor}}">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="8" ShadowDepth="0" Color="{Binding ServerRunning, Converter={StaticResource BoolToColor}}" Opacity="0.6"/>
                        </Border.Effect>
                    </Border>
                </Button>
            </Grid>
        </Border>

        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="74"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="{DynamicResource CardBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1" Padding="12,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    
                    <!-- Breadcrumb and Quick Actions -->
                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="{Binding CurrentPath}" FontWeight="Bold" FontSize="20" Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center" Margin="0,0,12,0"/>
                        
                        <ToggleButton x:Name="QuickActionsToggle" IsChecked="{Binding IsQuickActionsOpen, Mode=TwoWay}" Background="{DynamicResource FieldBg}" Foreground="{DynamicResource TextPrimaryBrush}" BorderBrush="{DynamicResource FieldBorder}" BorderThickness="1" Padding="10,6" VerticalAlignment="Center" Cursor="Hand">
                            <ToggleButton.Template>
                                <ControlTemplate TargetType="ToggleButton">
                                    <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="8" Padding="{TemplateBinding Padding}">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsChecked" Value="True">
                                            <Setter Property="Background" Value="{DynamicResource CardBrush}"/>
                                            <Setter Property="BorderBrush" Value="#10B981"/>
                                        </Trigger>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="{DynamicResource CardBrush}"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </ToggleButton.Template>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Quick Actions" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <TextBlock Text="&#xE70D;" FontFamily="Segoe MDL2 Assets" FontSize="10" VerticalAlignment="Center" FontWeight="Bold">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
                                            <Setter Property="RenderTransform">
                                                <Setter.Value>
                                                    <RotateTransform Angle="0"/>
                                                </Setter.Value>
                                            </Setter>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsQuickActionsOpen}" Value="True">
                                                    <DataTrigger.EnterActions>
                                                        <BeginStoryboard>
                                                            <Storyboard>
                                                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(RotateTransform.Angle)" To="180" Duration="0:0:0.2"/>
                                                            </Storyboard>
                                                        </BeginStoryboard>
                                                    </DataTrigger.EnterActions>
                                                    <DataTrigger.ExitActions>
                                                        <BeginStoryboard>
                                                            <Storyboard>
                                                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(RotateTransform.Angle)" To="0" Duration="0:0:0.2"/>
                                                            </Storyboard>
                                                        </BeginStoryboard>
                                                    </DataTrigger.ExitActions>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </StackPanel>
                        </ToggleButton>
                        
                        <Popup IsOpen="{Binding IsQuickActionsOpen}" StaysOpen="False" PlacementTarget="{Binding ElementName=QuickActionsToggle}" Placement="Bottom" VerticalOffset="8" PopupAnimation="Slide">
                            <Border Background="{DynamicResource CardBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="12" Padding="6" Width="220">
                                <Border.Effect>
                                    <DropShadowEffect BlurRadius="25" ShadowDepth="8" Opacity="0.15" Direction="270" Color="Black"/>
                                </Border.Effect>
                                <StackPanel>
                                    <Button Command="{Binding NavigateCommand}" CommandParameter="Students" Background="Transparent" BorderThickness="0" HorizontalContentAlignment="Left" Padding="14,12" Cursor="Hand" Foreground="{DynamicResource TextPrimaryBrush}">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="btnBorder" Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                                                    <ContentPresenter/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="btnBorder" Property="Background" Value="{DynamicResource NavActiveBrush}"/>
                                                        <Setter Property="Foreground" Value="{DynamicResource NavActiveFgBrush}"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Button.Template>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="&#xE77B;" FontFamily="Segoe MDL2 Assets" FontSize="16" Margin="0,0,12,0" Foreground="#10B981"/>
                                            <TextBlock Text="Register Student" FontSize="14" FontWeight="Medium"/>
                                        </StackPanel>
                                    </Button>
                                    
                                    <Button Command="{Binding NavigateCommand}" CommandParameter="Questions" Background="Transparent" BorderThickness="0" HorizontalContentAlignment="Left" Padding="14,12" Cursor="Hand" Foreground="{DynamicResource TextPrimaryBrush}">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="btnBorder" Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                                                    <ContentPresenter/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="btnBorder" Property="Background" Value="{DynamicResource NavActiveBrush}"/>
                                                        <Setter Property="Foreground" Value="{DynamicResource NavActiveFgBrush}"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Button.Template>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="&#xE8D3;" FontFamily="Segoe MDL2 Assets" FontSize="16" Margin="0,0,12,0" Foreground="#3B82F6"/>
                                            <TextBlock Text="Import Questions" FontSize="14" FontWeight="Medium"/>
                                        </StackPanel>
                                    </Button>

                                    <Button Command="{Binding NavigateCommand}" CommandParameter="Sessions" Background="Transparent" BorderThickness="0" HorizontalContentAlignment="Left" Padding="14,12" Cursor="Hand" Foreground="{DynamicResource TextPrimaryBrush}">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="btnBorder" Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                                                    <ContentPresenter/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="btnBorder" Property="Background" Value="{DynamicResource NavActiveBrush}"/>
                                                        <Setter Property="Foreground" Value="{DynamicResource NavActiveFgBrush}"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Button.Template>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="&#xE81C;" FontFamily="Segoe MDL2 Assets" FontSize="16" Margin="0,0,12,0" Foreground="#F59E0B"/>
                                            <TextBlock Text="Manage Sessions" FontSize="14" FontWeight="Medium"/>
                                        </StackPanel>
                                    </Button>
                                    
                                    <Border Height="1" Background="{DynamicResource BorderBrush}" Margin="6,6"/>
                                    
                                    <Button Command="{Binding ToggleServerCommand}" Background="Transparent" BorderThickness="0" HorizontalContentAlignment="Left" Padding="14,12" Cursor="Hand" Foreground="{DynamicResource TextPrimaryBrush}">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="btnBorder" Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                                                    <ContentPresenter/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="btnBorder" Property="Background" Value="{DynamicResource NavActiveBrush}"/>
                                                        <Setter Property="Foreground" Value="{DynamicResource NavActiveFgBrush}"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Button.Template>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="&#xE7E8;" FontFamily="Segoe MDL2 Assets" FontSize="16" Margin="0,0,12,0" Foreground="#EF4444"/>
                                            <TextBlock Text="Toggle Server" FontSize="14" FontWeight="Medium"/>
                                        </StackPanel>
                                    </Button>
                                </StackPanel>
                            </Border>
                        </Popup>
                    </StackPanel>
                    <!-- Live Metric Ticker -->
                    <Border Grid.Column="1" Background="{DynamicResource FieldBg}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="8" Padding="12,8" Margin="8,0" HorizontalAlignment="Stretch" VerticalAlignment="Center" MaxWidth="500">
                        <Grid HorizontalAlignment="Center">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="{Binding LiveMetricIcon}" FontFamily="Segoe MDL2 Assets" FontSize="16" Foreground="#10B981" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <TextBlock Grid.Column="1" Text="{Binding LiveMetricText}" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="14" FontWeight="Medium" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                        </Grid>
                    </Border>

                    <!-- Persistent Server Info Header -->
                    <Border Grid.Column="2" Background="{DynamicResource FieldBg}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="8" Padding="8,4" Margin="0,0,6,0" 
                            VerticalAlignment="Center" Visibility="{Binding ServerRunning, Converter={StaticResource BoolToVis}}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="IP:" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center" Margin="0,0,4,0" FontWeight="Bold"/>
                            <TextBlock Text="{Binding ServerUrl}" FontSize="11" Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center" FontWeight="SemiBold"/>
                            <Button Command="{Binding CopyServerUrlCommand}" Background="Transparent" BorderThickness="0" Padding="4" Margin="4,0,0,0" ToolTip="Copy URL" Cursor="Hand">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="bd" Background="Transparent" CornerRadius="4">
                                            <ContentPresenter/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="bd" Property="Background" Value="{DynamicResource NavHoverBrush}"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                                <TextBlock Text="&#xE8C8;" FontFamily="Segoe MDL2 Assets" FontSize="11" Foreground="{DynamicResource AccentBrush}"/>
                            </Button>
                        </StackPanel>
                    </Border>

                    <!-- User Profile and Actions -->
                    <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Center">
                        <Button Style="{StaticResource NavBtn}" Padding="6" ToolTip="Theme" Command="{Binding ToggleThemeCommand}">
                            <TextBlock Text="&#xE706;" FontFamily="Segoe MDL2 Assets" FontSize="16"/>
                        </Button>
                        <Grid Margin="4,0">
                            <Button Style="{StaticResource NavBtn}" Padding="6" ToolTip="Notifications" Command="{Binding OpenNotificationsCommand}">
                                <TextBlock Text="&#xE7ED;" FontFamily="Segoe MDL2 Assets" FontSize="16"/>
                            </Button>
                            <Border Width="16" Height="16" CornerRadius="8" Background="#F59E0B"
                                    HorizontalAlignment="Right" VerticalAlignment="Top">
                                <TextBlock Text="{Binding NotificationCount}" Foreground="White" FontSize="9" FontWeight="Bold"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </Grid>
                        <Border Width="30" Height="30" CornerRadius="15" Background="{DynamicResource AccentBrush}" Margin="4,0,6,0">
                            <TextBlock Text="A" Foreground="White" FontWeight="Bold" FontSize="14"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="Admin User" FontSize="12" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                            <TextBlock Text="Mock CBT" FontSize="10" Foreground="{DynamicResource TextSecondaryBrush}"/>
                        </StackPanel>
                        <TextBlock Text="&#xE70D;" FontFamily="Segoe MDL2 Assets" Foreground="{DynamicResource TextSecondaryBrush}" Margin="4,0,0,0"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Grid>
            </Border>

            <ContentControl Grid.Row="1" Content="{Binding CurrentPage, Mode=OneWay}">
                <ContentControl.Resources>
                    <DataTemplate DataType="{x:Type vm:DashboardViewModel}"><views:DashboardView/></DataTemplate>
                    <DataTemplate DataType="{x:Type vm:CreateExamViewModel}"><views:CreateExamView/></DataTemplate>
                    <DataTemplate DataType="{x:Type vm:ExamsViewModel}"><views:ExamsView/></DataTemplate>
                    <DataTemplate DataType="{x:Type vm:QuestionsViewModel}"><views:QuestionsView/></DataTemplate>
                    <DataTemplate DataType="{x:Type vm:SearchResultsViewModel}"><views:SearchResultsView/></DataTemplate>
                    <DataTemplate DataType="{x:Type vm:ErrorGuideViewModel}"><views:ErrorGuideView/></DataTemplate>
                    <DataTemplate DataType="{x:Type vm:SessionViewModel}"><views:SessionView/></DataTemplate>
                    <DataTemplate DataType="{x:Type vm:MonitorViewModel}"><views:MonitorView/></DataTemplate>
                    <DataTemplate DataType="{x:Type vm:StudentsViewModel}"><views:StudentsView/></DataTemplate>
                    <DataTemplate DataType="{x:Type vm:DevicesViewModel}"><views:DevicesView/></DataTemplate>
                    <DataTemplate DataType="{x:Type vm:ResultsViewModel}"><views:ResultsView/></DataTemplate>
                    <DataTemplate DataType="{x:Type vm:ReportsViewModel}"><views:ReportsView/></DataTemplate>
                    <DataTemplate DataType="{x:Type vm:NotificationsViewModel}"><views:NotificationsView/></DataTemplate>
                    <DataTemplate DataType="{x:Type vm:SettingsViewModel}"><views:SettingsView/></DataTemplate>
                </ContentControl.Resources>
                <ContentControl.Style>
                    <Style TargetType="ContentControl">
                        <Setter Property="Opacity" Value="1"/>
                        <Style.Triggers>
                            <Trigger Property="Content" Value="{x:Null}">
                                <Setter Property="Opacity" Value="0"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </ContentControl.Style>
            </ContentControl>
        </Grid>
        
        <!-- Global Loading Overlay -->
        <Border Grid.ColumnSpan="2" Background="#F8FAFC" Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <Grid Width="100" Height="100" Margin="0,0,0,24">
                    <Ellipse Stroke="{DynamicResource AccentBrush}" StrokeThickness="4" StrokeDashArray="6,2" Opacity="0.3"/>
                    <Ellipse Stroke="{DynamicResource AccentBrush}" StrokeThickness="4" StrokeDashArray="2,10">
                        <Ellipse.RenderTransform>
                            <RotateTransform x:Name="Rotator" Angle="0" CenterX="50" CenterY="50"/>
                        </Ellipse.RenderTransform>
                        <Ellipse.Triggers>
                            <EventTrigger RoutedEvent="Loaded">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="Rotator" Storyboard.TargetProperty="Angle" From="0" To="360" Duration="0:0:1" RepeatBehavior="Forever"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                        </Ellipse.Triggers>
                    </Ellipse>
                    <Image Source="pack://application:,,,/Resources/prep4jamb.png" Width="50" Height="50" RenderOptions.BitmapScalingMode="HighQuality"/>
                </Grid>
                <TextBlock Text="{Binding BusyMessage}" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center"/>
                <TextBlock Text="Please wait while we prepare your workspace..." Foreground="{DynamicResource TextSecondaryBrush}" FontSize="14" Margin="0,8,0,0" HorizontalAlignment="Center"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
